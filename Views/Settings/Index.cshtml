@model TrailGuard.Models.UpdateProfileViewModel
@{
    ViewData["Title"] = "Settings";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

<div class="pt-24 px-4 max-w-6xl mx-auto min-h-screen text-white pb-12">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Settings</h1>
        <p class="text-gray-400 mt-1 text-sm">Manage your profile and account settings.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 relative overflow-hidden">
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-orange-500/5 rounded-full blur-3xl"></div>
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-user text-orange-400 mr-2"></i>Profile Information</h2>

                <form id="profileForm" asp-controller="Settings" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="confirmPassword" id="profileConfirmPassword" value="" />

                    <div class="flex items-center gap-6 mb-6">
                        <div class="relative shrink-0">
                            @if (!string.IsNullOrEmpty(Model.CurrentProfilePictureUrl))
                            {
                                <img id="currentAvatar" src="@Model.CurrentProfilePictureUrl" alt="Profile" class="w-24 h-24 rounded-full object-cover border-2 border-orange-500/30">
                            }
                            else
                            {
                                <div id="defaultAvatar" class="w-24 h-24 rounded-full bg-linear-to-r from-orange-500 to-purple-600 flex items-center justify-center text-3xl font-bold text-white">
                                    @{
                                        var firstInit = string.IsNullOrEmpty(Model.FirstName) ? '?' : Model.FirstName[0];
                                        var lastInit = string.IsNullOrEmpty(Model.LastName) ? ' ' : Model.LastName[0];
                                    }
                                    @firstInit.ToString().ToUpper()@lastInit.ToString().ToUpper()
                                </div>
                            }
                            <div id="previewContainer" class="hidden relative">
                                <img id="previewImage" class="w-24 h-24 rounded-full object-cover border-2 border-orange-500/30" />
                                <button type="button" onclick="removePreview()" class="absolute -top-1 -right-1 w-6 h-6 bg-red-500 rounded-full flex items-center justify-center text-white text-xs hover:bg-red-600 transition-colors shadow-lg">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                            <label for="profileImageInput" class="absolute bottom-0 right-0 w-8 h-8 rounded-full bg-orange-500 hover:bg-orange-600 cursor-pointer flex items-center justify-center text-white text-xs transition-colors shadow-lg border-2 border-[#0B1325]">
                                <i class="fa-solid fa-camera"></i>
                                <input type="file" id="profileImageInput" name="ProfileImage" accept="image/*" class="hidden" onchange="previewProfileImage(event)" />
                            </label>
                        </div>
                        <div>
                            <p class="text-gray-300 text-sm font-medium">Profile Photo</p>
                            <p class="text-gray-500 text-xs">Click the camera icon to upload a new photo.</p>
                            <p class="text-gray-500 text-xs">JPG, PNG up to 5MB</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label asp-for="FirstName" class="block text-sm font-medium text-gray-300 mb-2">First Name</label>
                            <input asp-for="FirstName" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" />
                            <span asp-validation-for="FirstName" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="block text-sm font-medium text-gray-300 mb-2">Last Name</label>
                            <input asp-for="LastName" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" />
                            <span asp-validation-for="LastName" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <div class="mb-6">
                        <label asp-for="MiddleName" class="block text-sm font-medium text-gray-300 mb-2">Middle Name <span class="text-gray-500 text-xs">(Optional)</span></label>
                        <input asp-for="MiddleName" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" />
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label asp-for="Email" class="block text-sm font-medium text-gray-300 mb-2">Email Address</label>
                            <input asp-for="Email" type="email" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" />
                            <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-300 mb-2">Phone Number <span class="text-gray-500 text-xs">(Optional)</span></label>
                            <input asp-for="PhoneNumber" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" placeholder="+63 912 345 6789" />
                        </div>
                    </div>

                    <div class="mb-6">
                        <label asp-for="FacebookLink" class="block text-sm font-medium text-gray-300 mb-2">Facebook Link <span class="text-gray-500 text-xs">(Optional)</span></label>
                        <input asp-for="FacebookLink" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors" placeholder="https://facebook.com/username" />
                        <span asp-validation-for="FacebookLink" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Bio" class="block text-sm font-medium text-gray-300 mb-2">Bio <span class="text-gray-500 text-xs">(Optional)</span></label>
                        <textarea asp-for="Bio" rows="3" class="w-full bg-black/20 border border-white/10 text-white rounded-2xl px-5 py-3 focus:border-orange-500 focus:outline-none transition-colors resize-none" placeholder="Tell us a bit about yourself..."></textarea>
                        <span asp-validation-for="Bio" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div class="mt-6">
                        <button type="button" onclick="showPasswordModal()" class="bg-linear-to-r from-orange-500 to-purple-600 hover:from-orange-400 hover:to-purple-500 text-white px-8 py-3 rounded-full font-bold shadow-[0_0_20px_rgba(249,115,22,0.4)] transition-all transform hover:-translate-y-0.5">
                            <i class="fa-regular fa-floppy-disk mr-2"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>

            <!-- Security Container -->
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 relative overflow-hidden">
                <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-purple-500/5 rounded-full blur-3xl"></div>
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-lock text-orange-400 mr-2"></i>Security</h2>
                <p class="text-gray-400 text-sm mb-4">Change your password.</p>

                <form asp-controller="Settings" asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-6">
                        <label asp-for="CurrentPassword" class="block text-sm font-medium text-gray-300 mb-2">Current Password</label>
                        <div class="relative">
                            <input asp-for="CurrentPassword" type="password" id="currentPassword" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 pr-12 focus:border-orange-500 focus:outline-none transition-colors" />
                            <button type="button" onclick="togglePassword('currentPassword')" class="absolute inset-y-0 right-4 text-gray-400 hover:text-white transition-colors">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="NewPassword" class="block text-sm font-medium text-gray-300 mb-2">New Password</label>
                            <div class="relative">
                                <input asp-for="NewPassword" type="password" id="newPassword" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 pr-12 focus:border-orange-500 focus:outline-none transition-colors" />
                                <button type="button" onclick="togglePassword('newPassword')" class="absolute inset-y-0 right-4 text-gray-400 hover:text-white transition-colors">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ConfirmPassword" class="block text-sm font-medium text-gray-300 mb-2">Confirm New Password</label>
                            <div class="relative">
                                <input asp-for="ConfirmPassword" type="password" id="confirmPassword" class="w-full bg-black/20 border border-white/10 text-white rounded-full px-5 py-3 pr-12 focus:border-orange-500 focus:outline-none transition-colors" />
                                <button type="button" onclick="togglePassword('confirmPassword')" class="absolute inset-y-0 right-4 text-gray-400 hover:text-white transition-colors">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <div class="mt-6">
                        <button type="submit" class="bg-white/10 hover:bg-white/20 border border-white/20 text-gray-300 hover:text-white px-8 py-3 rounded-full font-medium transition-all">
                            <i class="fa-solid fa-key mr-2"></i> Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 sticky top-24 overflow-hidden">
                <div class="absolute -right-20 -top-20 w-64 h-64 bg-green-500/5 rounded-full blur-3xl"></div>
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-circle-info text-orange-400 mr-2"></i>Account Information</h2>

                <div class="space-y-4 text-sm">
                    <div class="bg-white/5 rounded-xl p-4">
                        <p class="text-gray-500 text-xs">Role</p>
                        <p class="text-white font-semibold">@ViewBag.Role</p>
                    </div>
                    <div class="bg-white/5 rounded-xl p-4">
                        <p class="text-gray-500 text-xs">Date Joined</p>
                        <p class="text-white font-semibold">@ViewBag.DateJoined</p>
                    </div>
                    <div class="bg-white/5 rounded-xl p-4">
                        <p class="text-gray-500 text-xs">Account Status</p>
                        <p class="text-white font-semibold">
                            @if (ViewBag.IsActive != null && (bool)ViewBag.IsActive)
                            {
                                <span class="text-green-400"><i class="fa-solid fa-circle-check mr-1"></i> Active</span>
                            }
                            else
                            {
                                <span class="text-red-400"><i class="fa-solid fa-circle-xmark mr-1"></i> Disabled</span>
                            }
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="passwordModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closePasswordModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-md overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-orange-500/20 flex items-center justify-center">
                    <i class="fa-solid fa-lock text-orange-400 text-sm"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Confirm Password</h2>
            </div>
            <button onclick="closePasswordModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>
        <div class="p-6">
            <p class="text-gray-400 text-sm mb-4">Please enter your current password to save profile changes.</p>
            <div class="relative">
                <input type="password" id="modalPasswordInput" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-3 pr-12 focus:border-orange-500 focus:outline-none transition-colors" placeholder="Enter your password" />
                <button type="button" onclick="togglePassword('modalPasswordInput')" class="absolute inset-y-0 right-4 text-gray-400 hover:text-white transition-colors">
                    <i class="fa-solid fa-eye"></i>
                </button>
            </div>
            <p id="modalError" class="text-red-400 text-xs mt-2 hidden">Password is required.</p>
        </div>
        <div class="px-6 py-4 border-t border-gray-800 shrink-0 flex justify-end gap-3 bg-[#0B1325]">
            <button type="button" onclick="closePasswordModal()" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white bg-gray-800 hover:bg-gray-700 transition-colors">
                Cancel
            </button>
            <button type="button" onclick="confirmPassword()" class="px-5 py-2 rounded-lg text-sm font-medium text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all">
                Confirm
            </button>
        </div>
    </div>
</div>

<script>
    // Toggle password visibility
    function togglePassword(inputId) {
        const input = document.getElementById(inputId);
        const icon = input.nextElementSibling?.querySelector('i') || input.parentElement.querySelector('button i');
        if (!icon) return;
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    // Profile photo preview
    function previewProfileImage(event) {
        const file = event.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = function(e) {
            const previewContainer = document.getElementById('previewContainer');
            const previewImage = document.getElementById('previewImage');
            const defaultAvatar = document.getElementById('defaultAvatar');
            const currentAvatar = document.getElementById('currentAvatar');

            previewImage.src = e.target.result;
            previewContainer.classList.remove('hidden');
            if (defaultAvatar) defaultAvatar.classList.add('hidden');
            if (currentAvatar) currentAvatar.classList.add('hidden');
        };
        reader.readAsDataURL(file);
    }

    function removePreview() {
        const previewContainer = document.getElementById('previewContainer');
        const defaultAvatar = document.getElementById('defaultAvatar');
        const currentAvatar = document.getElementById('currentAvatar');

        previewContainer.classList.add('hidden');
        document.getElementById('profileImageInput').value = '';

        if (currentAvatar && currentAvatar.src && currentAvatar.src !== window.location.href) {
            currentAvatar.classList.remove('hidden');
        } else if (defaultAvatar) {
            defaultAvatar.classList.remove('hidden');
        }
    }

    // Password modal
    function showPasswordModal() {
        document.getElementById('passwordModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        document.getElementById('modalPasswordInput').value = '';
        document.getElementById('modalError').classList.add('hidden');
        document.getElementById('modalPasswordInput').focus();
    }

    function closePasswordModal() {
        document.getElementById('passwordModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
        document.getElementById('modalError').classList.add('hidden');
    }

    function confirmPassword() {
        const password = document.getElementById('modalPasswordInput').value;
        if (!password) {
            document.getElementById('modalError').classList.remove('hidden');
            return;
        }
        document.getElementById('modalError').classList.add('hidden');
        document.getElementById('profileConfirmPassword').value = password;
        document.getElementById('profileForm').submit();
    }

    // Close modal on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closePasswordModal();
        }
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}