@model IEnumerable<TrailGuard.Models.RegistrationWithAssessmentViewModel>
@{
    ViewData["Title"] = "Registrations";

    var totalRegistrations = Model.Count();
    var goodMatchCount = Model.Count(r => r.AssessmentResult == "Good-Match");
    var borderlineCount = Model.Count(r => r.AssessmentResult == "Borderline");
    var notRecommendedCount = Model.Count(r => r.AssessmentResult == "Not Recommended");
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-400">Registrations</h1>
            <p class="text-gray-400 mt-1 text-sm">Manage participant registrations and assessment results.</p>
        </div>
        <div class="bg-white/5 border border-white/10 px-4 py-2 rounded-full flex items-center gap-2">
            <i class="fa-regular fa-clipboard text-blue-400"></i>
            <span class="text-sm text-gray-300">@totalRegistrations registration(s)</span>
        </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@totalRegistrations</p>
            <p class="text-gray-400 text-xs">Total Registrations</p>
        </div>
        <div class="bg-green-500/10 border border-green-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-green-400">@goodMatchCount</p>
            <p class="text-gray-400 text-xs">Good-Match</p>
        </div>
        <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-yellow-400">@borderlineCount</p>
            <p class="text-gray-400 text-xs">Borderline</p>
        </div>
        <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-red-400">@notRecommendedCount</p>
            <p class="text-gray-400 text-xs">Not Recommended</p>
        </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-white/10 shadow-2xl">
        <div class="relative grow">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
            <input type="text" id="searchInput" placeholder="Search by participant or event..." 
                   class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-blue-500 focus:outline-none transition-colors placeholder-gray-500">
        </div>

        <div class="flex flex-wrap sm:flex-nowrap gap-3">
            <div class="relative inline-block">
                <select id="statusFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-blue-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white">All Status</option>
                    <option value="Pending" class="bg-[#0b1329] text-white">Pending</option>
                    <option value="Accepted" class="bg-[#0b1329] text-white">Accepted</option>
                    <option value="Rejected" class="bg-[#0b1329] text-white">Rejected</option>
                    <option value="Cancelled" class="bg-[#0b1329] text-white">Cancelled</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="assessmentFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-blue-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white">All Results</option>
                    <option value="Good-Match" class="bg-[#0b1329] text-white">Good-Match</option>
                    <option value="Borderline" class="bg-[#0b1329] text-white">Borderline</option>
                    <option value="Not Recommended" class="bg-[#0b1329] text-white">Not Recommended</option>
                    <option value="N/A" class="bg-[#0b1329] text-white">No Assessment</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="sortFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-blue-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="date_desc" class="bg-[#0b1329] text-white">Sort by: Newest</option>
                    <option value="date_asc" class="bg-[#0b1329] text-white">Sort by: Oldest</option>
                    <option value="participant_asc" class="bg-[#0b1329] text-white">Participant (A-Z)</option>
                    <option value="participant_desc" class="bg-[#0b1329] text-white">Participant (Z-A)</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden h-125 flex flex-col">
            <div class="overflow-x-auto flex-1">
                <table class="w-full text-left">
                    <thead class="border-b border-gray-700 sticky top-0 bg-[#0B1325] z-10">
                        <tr>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Participant</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Event</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Pickup Point</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Assessment</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Status</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Registered</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusColor = item.Status switch
                            {
                                "Pending" => "text-yellow-400 bg-yellow-500/20",
                                "Accepted" => "text-green-400 bg-green-500/20",
                                "Rejected" => "text-red-400 bg-red-500/20",
                                "Cancelled" => "text-gray-400 bg-gray-500/20",
                                _ => "text-gray-400 bg-gray-500/20"
                            };

                            var resultColor = item.AssessmentResult switch
                            {
                                "Good-Match" => "text-green-400",
                                "Borderline" => "text-yellow-400",
                                "Not Recommended" => "text-red-400",
                                _ => "text-gray-400"
                            };

                            <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div>
                                        <p class="text-white font-medium">@item.ParticipantName</p>
                                        <p class="text-gray-500 text-xs">@item.Email</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div>
                                        <p class="text-white font-medium">@item.EventTitle</p>
                                        <p class="text-gray-500 text-xs">
                                            <i class="fa-regular fa-calendar mr-1"></i>@item.EventDate
                                            <span class="mx-1">•</span>
                                            <i class="fa-regular fa-clock mr-1"></i>@item.EventTime
                                        </p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-300 text-sm">
                                    @item.PickupPoint
                                </td>
                                <td class="px-6 py-4">
                                    <div>
                                        <span class="text-xs font-semibold @resultColor">@(item.AssessmentResult ?? "N/A")</span>
                                        @if (item.AssessmentTotalScore.HasValue)
                                        {
                                            <span class="text-gray-500 text-xs ml-1">(@item.AssessmentTotalScore/44)</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold @statusColor">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-gray-400 text-sm">
                                    @item.RegisteredAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <a asp-controller="Organizer" asp-action="RegistrationDetails" asp-route-id="@item.RegistrationId" 
                                    class="px-4 py-2 rounded-lg text-xs font-medium text-white bg-blue-500 hover:bg-blue-600 transition-colors inline-block">
                                        <i class="fa-regular fa-eye mr-1"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl">
            <i class="fa-regular fa-clipboard text-5xl text-gray-500 mb-4"></i>
            <h3 class="text-xl font-bold text-gray-300">No registrations found</h3>
            <p class="text-gray-500 mt-2">Registrations will appear here once participants sign up for your events.</p>
        </div>
    }
</div>

<div id="registrationModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeRegistrationModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-linear-to-r from-blue-500 to-cyan-500 flex items-center justify-center">
                    <i class="fa-regular fa-clipboard text-white text-sm"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Registration Details</h2>
            </div>
            <button onclick="closeRegistrationModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>
        <div class="overflow-y-auto p-6 custom-scrollbar" id="modalContent">
            <div class="text-center py-8">
                <div class="inline-block w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-gray-400 mt-2">Loading...</p>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const statusFilter = document.getElementById('statusFilter');
        const assessmentFilter = document.getElementById('assessmentFilter');
        const sortFilter = document.getElementById('sortFilter');
        
        // ✅ I-refresh ang rows every time may filter
        function filterAndSort() {
            const tableBody = document.querySelector('table tbody');
            if (!tableBody) return;

            let rows = Array.from(tableBody.querySelectorAll('tr'));
            if (rows.length === 0) return;

            const searchTerm = searchInput.value.toLowerCase().trim();
            const status = statusFilter.value;
            const assessment = assessmentFilter.value;
            const sort = sortFilter.value;

            let visibleRows = rows.filter(row => {
                // ✅ KUNIN ANG DATA PER COLUMN
                const participantName = row.querySelector('td:nth-child(1) .text-white')?.textContent?.toLowerCase() || '';
                const participantEmail = row.querySelector('td:nth-child(1) .text-gray-500')?.textContent?.toLowerCase() || '';
                const eventTitle = row.querySelector('td:nth-child(2) .text-white')?.textContent?.toLowerCase() || '';
                
                // ✅ STATUS (column 5)
                const statusSpan = row.querySelector('td:nth-child(5) .px-3');
                const statusText = statusSpan?.textContent?.trim() || '';
                
                // ✅ ASSESSMENT RESULT (column 4)
                const assessmentSpan = row.querySelector('td:nth-child(4) .text-xs');
                let assessmentText = assessmentSpan?.textContent?.trim() || 'N/A';
                // Remove the score part (e.g., "(22/44)")
                assessmentText = assessmentText.replace(/\(.*\)/, '').trim();
                
                // ✅ SEARCH MATCH
                const matchesSearch = participantName.includes(searchTerm) || 
                                     participantEmail.includes(searchTerm) || 
                                     eventTitle.includes(searchTerm);
                
                // ✅ STATUS MATCH
                const matchesStatus = status === 'All' || statusText === status;
                
                // ✅ ASSESSMENT MATCH
                let matchesAssessment = false;
                if (assessment === 'All') {
                    matchesAssessment = true;
                } else if (assessment === 'N/A') {
                    matchesAssessment = assessmentText === 'N/A' || assessmentText === '';
                } else {
                    matchesAssessment = assessmentText === assessment;
                }

                const shouldShow = matchesSearch && matchesStatus && matchesAssessment;
                row.style.display = shouldShow ? '' : 'none';
                return shouldShow;
            });

            // ✅ SORT VISIBLE ROWS
            visibleRows.sort((a, b) => {
                const nameA = a.querySelector('td:nth-child(1) .text-white')?.textContent || '';
                const nameB = b.querySelector('td:nth-child(1) .text-white')?.textContent || '';
                const dateA = a.querySelector('td:nth-child(6)')?.textContent?.trim() || '';
                const dateB = b.querySelector('td:nth-child(6)')?.textContent?.trim() || '';

                if (sort === 'participant_asc') return nameA.localeCompare(nameB);
                if (sort === 'participant_desc') return nameB.localeCompare(nameA);
                if (sort === 'date_asc') return new Date(dateA) - new Date(dateB);
                if (sort === 'date_desc') return new Date(dateB) - new Date(dateA);
                return 0;
            });

            // ✅ RE-APPEND SORTED ROWS
            visibleRows.forEach(row => tableBody.appendChild(row));

            // ✅ UPDATE COUNTER
            const totalSpan = document.querySelector('.bg-white\\/5 .text-gray-300');
            if (totalSpan) {
                const visibleCount = visibleRows.length;
                totalSpan.textContent = visibleCount + ' registration(s)';
            }
        }

        // ✅ ATTACH EVENTS
        searchInput.addEventListener('input', filterAndSort);
        statusFilter.addEventListener('change', filterAndSort);
        assessmentFilter.addEventListener('change', filterAndSort);
        sortFilter.addEventListener('change', filterAndSort);

        // ✅ INITIAL FILTER
        setTimeout(filterAndSort, 100);
    });

    // ============================================================
    // VIEW REGISTRATION DETAILS
    // ============================================================
    function viewRegistration(id) {
        const modal = document.getElementById('registrationModal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        
        document.getElementById('modalContent').innerHTML = `
            <div class="text-center py-8">
                <div class="inline-block w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-gray-400 mt-2">Loading...</p>
            </div>
        `;

        // TODO: Implement full registration details
        setTimeout(() => {
            document.getElementById('modalContent').innerHTML = `
                <div class="space-y-6">
                    <div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4">
                        <p class="text-blue-300 text-sm font-medium">Registration ID: ${id}</p>
                        <p class="text-gray-400 text-sm">Loading registration details...</p>
                    </div>
                    
                    <div class="flex flex-wrap gap-3">
                        <button onclick="updateStatus(${id}, 'Accepted')" 
                                class="px-6 py-2.5 rounded-xl text-white text-sm font-medium bg-green-500 hover:bg-green-600 transition-colors">
                            <i class="fa-solid fa-check mr-2"></i> Accept
                        </button>
                        <button onclick="updateStatus(${id}, 'Rejected')" 
                                class="px-6 py-2.5 rounded-xl text-white text-sm font-medium bg-red-500 hover:bg-red-600 transition-colors">
                            <i class="fa-solid fa-xmark mr-2"></i> Decline
                        </button>
                        <button onclick="recommendAlternative(${id})" 
                                class="px-6 py-2.5 rounded-xl text-white text-sm font-medium bg-blue-500 hover:bg-blue-600 transition-colors">
                            <i class="fa-solid fa-arrows-rotate mr-2"></i> Recommend Alternative
                        </button>
                        <button onclick="closeRegistrationModal()" 
                                class="px-6 py-2.5 rounded-xl text-gray-300 text-sm font-medium bg-gray-700 hover:bg-gray-600 transition-colors">
                            Close
                        </button>
                    </div>
                </div>
            `;
        }, 500);
    }

    // ============================================================
    // UPDATE STATUS
    // ============================================================
    function updateStatus(id, status) {
        if (!confirm(`Are you sure you want to change status to ${status}?`)) return;

        fetch('/Organizer/UpdateRegistrationStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: id, status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Error updating status', 'error');
        });
    }

    // ============================================================
    // RECOMMEND ALTERNATIVE
    // ============================================================
    function recommendAlternative(id) {
        showToast('Recommend Alternative feature coming soon!', 'info');
    }

    // ============================================================
    // CLOSE MODAL
    // ============================================================
    function closeRegistrationModal() {
        const modal = document.getElementById('registrationModal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    // ============================================================
    // TOAST MESSAGES
    // ============================================================
    function showToast(message, type) {
        const existingToast = document.querySelector('.toast-message');
        if (existingToast) existingToast.remove();
        
        const toast = document.createElement('div');
        toast.className = `toast-message fixed top-24 right-4 z-50 ${type === 'success' ? 'bg-green-500/90' : type === 'error' ? 'bg-red-500/90' : 'bg-blue-500/90'} text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3`;
        toast.innerHTML = `
            <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-triangle' : 'fa-info-circle'}"></i>
            <span>${message}</span>
            <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        `;
        document.body.appendChild(toast);
        
        setTimeout(() => {
            if (toast) toast.remove();
        }, 3000);
    }
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(59, 130, 246, 0.3);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(59, 130, 246, 0.6);
    }
</style>