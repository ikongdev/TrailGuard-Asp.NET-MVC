@model IEnumerable<TrailGuard.Models.RegistrationWithAssessmentViewModel>
@{
    ViewData["Title"] = "Registrations";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-400">Registrations</h1>
            <p class="text-gray-400 mt-1 text-sm">Manage participant registrations and assessment results.</p>
        </div>
        <div class="bg-white/5 border border-white/10 px-4 py-2 rounded-full flex items-center gap-2">
            <i class="fa-regular fa-clipboard text-blue-400"></i>
            <span class="text-sm text-gray-300">@Model.Count() registration(s)</span>
        </div>
    </div>

    <!-- Filters -->
    <div class="flex flex-col lg:flex-row gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-white/10 shadow-2xl">
        <div class="relative grow">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
            <input type="text" id="searchInput" placeholder="Search by participant or event..." 
                   class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-blue-500 focus:outline-none transition-colors placeholder-gray-500">
        </div>

        <div class="flex flex-wrap sm:flex-nowrap gap-3">
            <div class="relative inline-block">
                <select id="statusFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-blue-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white">All Status</option>
                    <option value="Pending" class="bg-[#0b1329] text-white">Pending</option>
                    <option value="Accepted" class="bg-[#0b1329] text-white">Accepted</option>
                    <option value="Rejected" class="bg-[#0b1329] text-white">Rejected</option>
                    <option value="Cancelled" class="bg-[#0b1329] text-white">Cancelled</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="sortFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-blue-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="date_desc" class="bg-[#0b1329] text-white">Sort by: Newest</option>
                    <option value="date_asc" class="bg-[#0b1329] text-white">Sort by: Oldest</option>
                    <option value="participant_asc" class="bg-[#0b1329] text-white">Participant (A-Z)</option>
                    <option value="participant_desc" class="bg-[#0b1329] text-white">Participant (Z-A)</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Registrations Table -->
    @if (Model.Any())
    {
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="border-b border-gray-700">
                        <tr>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Event</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Participant</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Pickup Point</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Assessment</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Status</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Registered</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var statusColor = item.Status switch
                            {
                                "Pending" => "text-yellow-400 bg-yellow-500/20",
                                "Accepted" => "text-green-400 bg-green-500/20",
                                "Rejected" => "text-red-400 bg-red-500/20",
                                "Cancelled" => "text-gray-400 bg-gray-500/20",
                                _ => "text-gray-400 bg-gray-500/20"
                            };

                            var resultColor = item.AssessmentResult switch
                            {
                                "Good-Match" => "text-green-400",
                                "Borderline" => "text-yellow-400",
                                "Not Recommended" => "text-red-400",
                                _ => "text-gray-400"
                            };

                            <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                                <td class="px-6 py-4">
                                    <div>
                                        <p class="text-white font-medium">@item.EventTitle</p>
                                        <p class="text-gray-500 text-xs">
                                            <i class="fa-regular fa-calendar mr-1"></i>@item.EventDate
                                            <span class="mx-1">•</span>
                                            <i class="fa-regular fa-clock mr-1"></i>@item.EventTime
                                        </p>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <div>
                                        <p class="text-white font-medium">@item.ParticipantName</p>
                                        <p class="text-gray-500 text-xs">@item.Email</p>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-300 text-sm">
                                    @item.PickupPoint
                                </td>
                                <td class="px-6 py-4">
                                    <div>
                                        <span class="text-xs font-semibold @resultColor">@(item.AssessmentResult ?? "N/A")</span>
                                        @if (item.AssessmentTotalScore.HasValue)
                                        {
                                            <span class="text-gray-500 text-xs ml-1">(@item.AssessmentTotalScore/44)</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold @statusColor">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-gray-400 text-sm">
                                    @item.RegisteredAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        @if (item.Status == "Pending")
                                        {
                                            <button onclick="updateStatus(@item.RegistrationId, 'Accepted')" 
                                                    class="text-green-400 hover:text-green-300 transition-colors text-sm">
                                                <i class="fa-solid fa-check"></i>
                                            </button>
                                            <button onclick="updateStatus(@item.RegistrationId, 'Rejected')" 
                                                    class="text-red-400 hover:text-red-300 transition-colors text-sm">
                                                <i class="fa-solid fa-xmark"></i>
                                            </button>
                                        }
                                        <button onclick="viewRegistration(@item.RegistrationId)" 
                                                class="text-blue-400 hover:text-blue-300 transition-colors text-sm">
                                            <i class="fa-regular fa-eye"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl">
            <i class="fa-regular fa-clipboard text-5xl text-gray-500 mb-4"></i>
            <h3 class="text-xl font-bold text-gray-300">No registrations found</h3>
            <p class="text-gray-500 mt-2">Registrations will appear here once participants sign up for your events.</p>
        </div>
    }
</div>

<!-- Registration Details Modal -->
<div id="registrationModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeRegistrationModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-linear-to-r from-blue-500 to-cyan-500 flex items-center justify-center">
                    <i class="fa-regular fa-clipboard text-white text-sm"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Registration Details</h2>
            </div>
            <button onclick="closeRegistrationModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>
        <div class="overflow-y-auto p-6 custom-scrollbar" id="modalContent">
            <div class="text-center py-8">
                <div class="inline-block w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-gray-400 mt-2">Loading...</p>
            </div>
        </div>
    </div>
</div>

<script>
    function updateStatus(id, status) {
        if (!confirm(`Are you sure you want to change status to ${status}?`)) return;

        fetch('/Organizer/UpdateRegistrationStatus', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ id: id, status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showToast(data.message, 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast(data.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Error updating status', 'error');
        });
    }

    function viewRegistration(id) {
        const modal = document.getElementById('registrationModal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        
        document.getElementById('modalContent').innerHTML = `
            <div class="text-center py-8">
                <div class="inline-block w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-gray-400 mt-2">Loading...</p>
            </div>
        `;

        // TODO: Implement registration details view
        setTimeout(() => {
            document.getElementById('modalContent').innerHTML = `
                <div class="text-center py-8">
                    <i class="fa-regular fa-file-lines text-3xl text-gray-500 mb-2"></i>
                    <p class="text-gray-400">Registration details for ID: ${id}</p>
                    <p class="text-gray-500 text-sm mt-2">Feature coming soon...</p>
                </div>
            `;
        }, 500);
    }

    function closeRegistrationModal() {
        const modal = document.getElementById('registrationModal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    function showToast(message, type) {
        const existingToast = document.querySelector('.toast-message');
        if (existingToast) existingToast.remove();
        
        const toast = document.createElement('div');
        toast.className = `toast-message fixed top-24 right-4 z-50 ${type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90'} text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3`;
        toast.innerHTML = `
            <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
            <span>${message}</span>
            <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        `;
        document.body.appendChild(toast);
        
        setTimeout(() => {
            if (toast) toast.remove();
        }, 3000);
    }
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(59, 130, 246, 0.3);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(59, 130, 246, 0.6);
    }
</style>