@model List<TrailGuard.Models.ComparisonResult>
@{
    ViewData["Title"] = "Event Comparison";
    var eventItem = ViewBag.Event as TrailGuard.Models.Event;
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    
    <div class="mb-6">
        <a asp-controller="Event" asp-action="Details" asp-route-id="@eventItem?.Id" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Back to Event Details
        </a>
    </div>

    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8">
        <!-- Header -->
        <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full bg-linear-to-r from-blue-500 to-cyan-500 flex items-center justify-center">
                <i class="fa-solid fa-chart-simple text-white text-2xl"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-white">Pre-Hike vs Post-Hike Comparison</h1>
                <p class="text-gray-400 text-sm">Compare assessment accuracy for @eventItem?.EventTitle</p>
            </div>
        </div>

        <!-- Event Info -->
        <div class="bg-blue-500/10 border border-blue-500/30 rounded-xl p-4 mb-6">
            <p class="text-blue-300 text-sm">
                <i class="fa-solid fa-info-circle mr-2"></i>
                <span class="font-semibold">Event:</span> @eventItem?.EventTitle
            </p>
            <div class="flex flex-wrap gap-4 text-blue-300/70 text-sm mt-1">
                <span><i class="fa-regular fa-calendar mr-2"></i>@eventItem?.EventDate.ToString("MMMM dd, yyyy")</span>
                <span><i class="fa-regular fa-clock mr-2"></i>@eventItem?.FormattedEventTime</span>
                <span><i class="fa-solid fa-users mr-2"></i>@Model.Count participants</span>
            </div>
        </div>

        @if (Model.Any())
        {
            <!-- Summary Cards -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                <div class="bg-green-500/10 border border-green-500/30 rounded-xl p-4 text-center hover:bg-green-500/20 transition-colors">
                    <div class="flex items-center justify-center gap-2">
                        <i class="fa-solid fa-check-circle text-green-400 text-xl"></i>
                        <p class="text-2xl font-bold text-green-400">@Model.Count(m => m.Comparison.Contains("Accurate"))</p>
                    </div>
                    <p class="text-gray-400 text-xs mt-1">Accurate</p>
                </div>
                <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 text-center hover:bg-yellow-500/20 transition-colors">
                    <div class="flex items-center justify-center gap-2">
                        <i class="fa-solid fa-triangle-exclamation text-yellow-400 text-xl"></i>
                        <p class="text-2xl font-bold text-yellow-400">@Model.Count(m => m.Comparison.Contains("Overestimated"))</p>
                    </div>
                    <p class="text-gray-400 text-xs mt-1">Overestimated</p>
                </div>
                <div class="bg-orange-500/10 border border-orange-500/30 rounded-xl p-4 text-center hover:bg-orange-500/20 transition-colors">
                    <div class="flex items-center justify-center gap-2">
                        <i class="fa-solid fa-arrow-trend-up text-orange-400 text-xl"></i>
                        <p class="text-2xl font-bold text-orange-400">@Model.Count(m => m.Comparison.Contains("Underestimated"))</p>
                    </div>
                    <p class="text-gray-400 text-xs mt-1">Underestimated</p>
                </div>
                <div class="bg-gray-500/10 border border-gray-500/30 rounded-xl p-4 text-center hover:bg-gray-500/20 transition-colors">
                    <div class="flex items-center justify-center gap-2">
                        <i class="fa-solid fa-minus-circle text-gray-400 text-xl"></i>
                        <p class="text-2xl font-bold text-gray-400">@Model.Count(m => m.Comparison.Contains("Insufficient"))</p>
                    </div>
                    <p class="text-gray-400 text-xs mt-1">Insufficient Data</p>
                </div>
            </div>

            <!-- Table -->
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="border-b border-gray-700">
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider">
                                <i class="fa-regular fa-user mr-1"></i> Participant
                            </th>
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider">
                                <i class="fa-regular fa-clipboard mr-1"></i> Pre-Hike
                            </th>
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider">
                                <i class="fa-regular fa-comment mr-1"></i> Participant Feedback
                            </th>
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider">
                                <i class="fa-regular fa-pen-to-square mr-1"></i> Organizer Assessment
                            </th>
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider">
                                <i class="fa-solid fa-flag-checkered mr-1"></i> Final Result
                            </th>
                            <th class="px-4 py-3 text-xs font-medium text-gray-400 uppercase tracking-wider text-center">
                                <i class="fa-solid fa-arrows-left-right mr-1"></i> Comparison
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var preHikeColor = item.PreHikeAssessment == "Good-Match" ? "bg-green-500/20 text-green-400" : 
                                               item.PreHikeAssessment == "Borderline" ? "bg-yellow-500/20 text-yellow-400" : 
                                               item.PreHikeAssessment == "Not Recommended" ? "bg-red-500/20 text-red-400" : 
                                               "bg-gray-500/20 text-gray-400";
                            
                            var finalResultColor = item.FinalResult == "Much easier than expected" || item.FinalResult == "Matched perfectly" ? "bg-green-500/20 text-green-400" : 
                                                   item.FinalResult == "Matched but challenging" || item.FinalResult == "Harder than expected" ? "bg-yellow-500/20 text-yellow-400" : 
                                                   "bg-red-500/20 text-red-400";

                            <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors group">
                                <td class="px-4 py-3">
                                    <span class="text-white font-medium">@item.ParticipantName</span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold @preHikeColor inline-block min-w-25 text-center">
                                        @item.PreHikeAssessment
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="text-gray-300 text-sm">@item.ParticipantFeedback</span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="text-gray-300 text-sm">@item.OrganizerAssessment</span>
                                </td>
                                <td class="px-4 py-3">
                                    <span class="px-3 py-1 rounded-full text-xs font-semibold @finalResultColor inline-block min-w-30 text-center">
                                        @item.FinalResult
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-center gap-2">
                                        <i class="fa-solid @item.ComparisonIcon text-lg @item.ComparisonColor"></i>
                                        <span class="text-sm font-semibold @item.ComparisonColor">@item.Comparison</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Legend -->
            <div class="mt-6 p-4 bg-white/5 border border-white/10 rounded-xl">
                <p class="text-xs font-medium text-gray-400 mb-2">
                    <i class="fa-regular fa-circle-question mr-1"></i> Legend
                </p>
                <div class="flex flex-wrap gap-4 text-xs">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-check-circle text-green-400"></i>
                        <span class="text-gray-300">Accurate</span>
                        <span class="text-gray-500">- Assessment matched actual experience</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-triangle-exclamation text-yellow-400"></i>
                        <span class="text-gray-300">Overestimated</span>
                        <span class="text-gray-500">- Expected harder than actual</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-arrow-trend-up text-orange-400"></i>
                        <span class="text-gray-300">Underestimated</span>
                        <span class="text-gray-500">- Expected easier than actual</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-minus-circle text-gray-400"></i>
                        <span class="text-gray-300">Insufficient Data</span>
                        <span class="text-gray-500">- Missing feedback or assessment</span>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-16">
                <div class="w-20 h-20 rounded-full bg-gray-500/10 flex items-center justify-center mx-auto mb-4">
                    <i class="fa-regular fa-users-slash text-3xl text-gray-500"></i>
                </div>
                <p class="text-gray-400 text-sm">No comparison data available for this event.</p>
                <p class="text-gray-500 text-xs mt-1">Complete post-event assessments to see comparison data.</p>
            </div>
        }
    </div>
</div>