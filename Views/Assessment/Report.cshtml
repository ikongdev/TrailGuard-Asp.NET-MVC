@model TrailGuard.Models.AssessmentResultViewModel
@{
    ViewData["Title"] = "Assessment Report";
    var isGoodMatch = Model?.Result == "Good-Match";
    var isBorderline = Model?.Result == "Borderline";
    var isNotRecommended = Model?.Result == "Not Recommended";
    
    var resultColor = isGoodMatch ? "text-green-400" : isBorderline ? "text-yellow-400" : "text-red-400";
    var resultBg = isGoodMatch ? "bg-green-500/20 border-green-500/50" : isBorderline ? "bg-yellow-500/20 border-yellow-500/50" : "bg-red-500/20 border-red-500/50";
    var resultIcon = isGoodMatch ? "fa-check-circle" : isBorderline ? "fa-triangle-exclamation" : "fa-xmark-circle";
    
    var eventItem = ViewBag.Assessment?.Event as TrailGuard.Models.Event;
    var trail = eventItem?.Trail;
    var score = Model?.TotalScore ?? 0;
    var maxScore = Model?.MaxScore ?? 44;
    var threshold = Model?.Threshold ?? 32;
    var remaining = maxScore - score;
    var thresholdRemaining = maxScore - threshold;
    var percentage = Math.Min((score * 100) / maxScore, 100);
}

<div class="pt-24 px-4 max-w-6xl mx-auto min-h-screen text-white pb-12">
    
    <div class="mb-6">
        <a asp-controller="Participant" asp-action="Events" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Back to Events
        </a>
    </div>

    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8 mb-8">
        <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="relative shrink-0" style="width: 120px; height: 120px;">
                <canvas id="resultDonutChart"></canvas>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-xl font-bold text-white">@score</span>
                    <span class="text-[8px] text-gray-400">/@maxScore</span>
                </div>
            </div>
            <div class="text-center md:text-left flex-1">
                <div class="flex items-center gap-3 justify-center md:justify-start">
                    <div class="w-10 h-10 rounded-full @resultBg flex items-center justify-center shrink-0">
                        <i class="fa-solid @resultIcon text-xl @resultColor"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold @resultColor">@Model?.Result</h1>
                        <p class="text-gray-400 text-sm">
                            <span class="font-semibold text-white">@Model?.EventTitle</span>
                            <span class="mx-2">•</span>
                            <span class="text-gray-500">Difficulty: @Model?.EventDifficulty</span>
                        </p>
                    </div>
                </div>
                <div class="flex flex-wrap gap-4 mt-3 text-sm">
                    <span class="text-gray-400">Total Score: <span class="text-white font-semibold">@score / @maxScore</span></span>
                    <span class="text-gray-400">Required: <span class="text-white font-semibold">@threshold / @maxScore</span></span>
                    <span class="text-gray-400">Assessment ID: <span class="text-white font-semibold">#@Model?.AssessmentId</span></span>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                @if (isGoodMatch || isBorderline)
                {
                    <a asp-controller="Registration" asp-action="Register" asp-route-eventId="@Model?.EventId" asp-route-assessmentId="@Model?.AssessmentId"
                       class="px-6 py-3 rounded-xl text-white font-bold bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 hover:scale-105 transition-all text-center" id="headerProceedBtn">
                        <i class="fa-regular fa-clipboard mr-2"></i> Proceed to Registration
                    </a>
                }
                @if (isBorderline || isNotRecommended)
                {
                    <a asp-controller="Assessment" asp-action="Form" asp-route-eventId="@Model?.EventId"
                       class="px-6 py-2 rounded-xl text-yellow-400 font-medium bg-yellow-500/10 border border-yellow-500/30 hover:bg-yellow-500/20 transition-colors text-center text-sm">
                        <i class="fa-solid fa-rotate mr-2"></i> Retake Assessment
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-6">
            
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-chart-bar text-orange-400 mr-2"></i>Category Scores</h2>
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Fitness & Endurance</span>
                            <span class="text-white font-semibold">@Model?.FitnessScore / @Model?.FitnessMax</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 bg-blue-500" 
                                 style="width: @((Model?.FitnessScore ?? 0) * 100 / (Model?.FitnessMax ?? 1))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Hiking Experience</span>
                            <span class="text-white font-semibold">@Model?.ExperienceScore / @Model?.ExperienceMax</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 bg-green-500" 
                                 style="width: @((Model?.ExperienceScore ?? 0) * 100 / (Model?.ExperienceMax ?? 1))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Health & Physical</span>
                            <span class="text-white font-semibold">@Model?.HealthScore / @Model?.HealthMax</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 bg-purple-500" 
                                 style="width: @((Model?.HealthScore ?? 0) * 100 / (Model?.HealthMax ?? 1))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Gear Preparedness</span>
                            <span class="text-white font-semibold">@Model?.GearScore / @Model?.GearMax</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 bg-orange-500" 
                                 style="width: @((Model?.GearScore ?? 0) * 100 / (Model?.GearMax ?? 1))%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-mountain text-orange-400 mr-2"></i>Trail Demands</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Distance</span>
                            <span class="text-white font-semibold">@(trail?.DistanceKm ?? 0) km</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 @((trail?.DistanceKm ?? 0) >= 15 ? "bg-red-500" : (trail?.DistanceKm ?? 0) >= 10 ? "bg-yellow-500" : "bg-green-500")" 
                                 style="width: @(Math.Min(((trail?.DistanceKm ?? 0) / 20) * 100, 100))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Elevation Gain</span>
                            <span class="text-white font-semibold">@(trail?.ElevationGainMeters ?? 0) m</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 @((trail?.ElevationGainMeters ?? 0) >= 1000 ? "bg-red-500" : (trail?.ElevationGainMeters ?? 0) >= 600 ? "bg-yellow-500" : "bg-green-500")" 
                                 style="width: @(Math.Min(((trail?.ElevationGainMeters ?? 0) / 1500) * 100, 100))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Estimated Duration</span>
                            <span class="text-white font-semibold">@(eventItem?.EstimatedDuration ?? 0) hrs</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 @((eventItem?.EstimatedDuration ?? 0) >= 8 ? "bg-red-500" : (eventItem?.EstimatedDuration ?? 0) >= 6 ? "bg-yellow-500" : "bg-green-500")" 
                                 style="width: @(Math.Min(((eventItem?.EstimatedDuration ?? 0) / 10) * 100, 100))%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between text-sm mb-1">
                            <span class="text-gray-300">Terrain Type</span>
                            <span class="text-white font-semibold">@(trail?.Terrain ?? "N/A")</span>
                        </div>
                        <div class="w-full h-2.5 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 @(trail?.Terrain == "Technical" ? "bg-red-500" : trail?.Terrain == "Difficult" ? "bg-yellow-500" : "bg-green-500")" 
                                 style="width: @(trail?.Terrain == "Technical" ? 100 : trail?.Terrain == "Difficult" ? 75 : trail?.Terrain == "Moderate" ? 50 : 25)%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-flag text-orange-400 mr-2"></i>Risk Flags</h2>
                @if (Model?.RiskFlags != null && Model.RiskFlags.Any())
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var flag in Model.RiskFlags)
                        {
                            <span class="px-3 py-1 rounded-full text-xs font-medium bg-red-500/20 text-red-400 border border-red-500/30">
                                <i class="fa-solid fa-circle-exclamation mr-1"></i> @flag
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">No significant risk flags identified.</p>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-lightbulb text-orange-400 mr-2"></i>Recommendations</h2>
                @if (Model?.Recommendations != null && Model.Recommendations.Any())
                {
                    <ul class="space-y-2">
                        @foreach (var rec in Model.Recommendations)
                        {
                            <li class="flex items-start gap-2 text-gray-300 text-sm">
                                <i class="fa-solid fa-check-circle text-green-400 mt-0.5"></i>
                                <span>@rec</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-gray-500 text-sm">No recommendations available.</p>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4">
                    <i class="fa-solid fa-arrows-rotate text-orange-400 mr-2"></i>
                    @if (isGoodMatch)
                    {
                        <span>Other Events for You</span>
                    }
                    else
                    {
                        <span>Recommended Alternatives</span>
                    }
                </h2>
                @if (Model?.AlternativeEvents != null && Model.AlternativeEvents.Any())
                {
                    <div class="space-y-3">
                        @foreach (var altEvent in Model.AlternativeEvents)
                        {
                            <div class="bg-white/5 rounded-xl p-3 hover:bg-white/10 transition-colors">
                                <div class="flex items-center justify-between">
                                    <p class="text-white font-medium text-sm">@altEvent.EventTitle</p>
                                    <a asp-controller="Participant" asp-action="Details" asp-route-id="@altEvent.Id"
                                       class="text-xs text-orange-400 hover:text-orange-300 transition-colors">
                                        View <i class="fa-solid fa-arrow-right ml-1"></i>
                                    </a>
                                </div>
                                <div class="flex flex-wrap gap-2 mt-1">
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-blue-500/20 text-blue-300">
                                        <i class="fa-regular fa-calendar mr-1"></i>@altEvent.EventDate.ToString("MMM dd")
                                    </span>
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-300">
                                        <i class="fa-solid fa-signal mr-1"></i>@altEvent.Difficulty
                                    </span>
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-green-500/20 text-green-300">
                                        <i class="fa-regular fa-clock mr-1"></i>@altEvent.EstimatedDuration hrs
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center text-gray-500 text-sm py-4">
                        <i class="fa-regular fa-calendar-plus text-2xl block mb-2 opacity-50"></i>
                        No alternative events available at this time.
                    </div>
                }
            </div>
        </div>

        <div class="space-y-6 flex flex-col">

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-chart-simple text-orange-400 mr-2"></i>Result Summary</h2>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-gray-400">Result</span>
                        <span class="font-bold @resultColor">@Model?.Result</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Total Score</span>
                        <span class="text-white font-semibold">@score / @maxScore</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Required Score</span>
                        <span class="text-white font-semibold">@threshold / @maxScore</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Fitness</span>
                        <span class="text-white font-semibold">@Model?.FitnessScore / @Model?.FitnessMax</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Experience</span>
                        <span class="text-white font-semibold">@Model?.ExperienceScore / @Model?.ExperienceMax</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Health</span>
                        <span class="text-white font-semibold">@Model?.HealthScore / @Model?.HealthMax</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400">Gear</span>
                        <span class="text-white font-semibold">@Model?.GearScore / @Model?.GearMax</span>
                    </div>
                    <div class="flex justify-between border-t border-white/10 pt-3">
                        <span class="text-gray-400">Risk Flags</span>
                        <span class="text-white font-semibold">@(Model?.RiskFlags?.Count ?? 0)</span>
                    </div>
                    <div class="mt-3 pt-3 border-t border-white/10">
                        <div class="flex justify-between text-xs text-gray-400 mb-1">
                            <span>Score: @score</span>
                            <span>Required: @threshold</span>
                        </div>
                        <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-700 @(score >= threshold ? "bg-green-500" : "bg-yellow-500")" 
                                 style="width: @(Math.Min((score * 100) / (maxScore), 100))%"></div>
                        </div>
                        <div class="flex justify-between text-xs text-gray-500 mt-1">
                            <span>@Model?.Result</span>
                            <span>@(score >= threshold ? "✅ Meets requirement" : "❌ Below requirement")</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex flex-col flex-1">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-file-signature text-orange-400 mr-2"></i>Acknowledgement</h2>
                
                @if (isGoodMatch)
                {
                    <div class="flex items-start gap-3 p-4 bg-green-500/10 border border-green-500/30 rounded-xl">
                        <input type="checkbox" id="acknowledgeGoodMatch" class="w-5 h-5 mt-0.5 accent-green-500 cursor-pointer shrink-0" />
                        <label for="acknowledgeGoodMatch" class="text-gray-300 text-sm cursor-pointer">
                            <span class="font-medium text-green-400">I acknowledge my Good-Match assessment result</span> and confirm that I am prepared for this event. I understand the trail demands and agree to follow all safety guidelines.
                        </label>
                    </div>
                }
                else if (isBorderline)
                {
                    <div class="flex items-start gap-3 p-4 bg-yellow-500/10 border border-yellow-500/30 rounded-xl">
                        <input type="checkbox" id="acknowledgeBorderline" class="w-5 h-5 mt-0.5 accent-yellow-500 cursor-pointer shrink-0" />
                        <label for="acknowledgeBorderline" class="text-gray-300 text-sm cursor-pointer">
                            <span class="font-medium text-yellow-400">I acknowledge my Borderline assessment result</span> and understand the recommended preparation steps before continuing. I agree to take necessary precautions and follow the organizer's advice.
                        </label>
                    </div>
                }
                else if (isNotRecommended)
                {
                    <div class="flex items-start gap-3 p-4 bg-red-500/10 border border-red-500/30 rounded-xl">
                        <input type="checkbox" id="acknowledgeNotRecommended" class="w-5 h-5 mt-0.5 accent-red-500 cursor-pointer shrink-0" />
                        <label for="acknowledgeNotRecommended" class="text-gray-300 text-sm cursor-pointer">
                            <span class="font-medium text-red-400">I acknowledge my Not Recommended assessment result</span> and understand the significant risks involved. I accept full responsibility for my decision to proceed and agree to follow all safety guidelines.
                        </label>
                    </div>
                }

                <p class="mt-2 text-xs text-gray-500">
                    <i class="fa-regular fa-circle-check mr-1"></i> 
                    Please check the box to confirm your acknowledgement before proceeding to registration.
                </p>

                <div class="mt-4 pt-4 border-t border-white/10 space-y-2">
                    @if (isGoodMatch || isBorderline)
                    {
                        <a asp-controller="Registration" asp-action="Register" asp-route-eventId="@Model?.EventId" asp-route-assessmentId="@Model?.AssessmentId"
                           class="w-full px-6 py-3 rounded-xl text-white font-bold bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 hover:scale-105 transition-all text-center block" id="proceedButton">
                            <i class="fa-regular fa-clipboard mr-2"></i> Proceed to Registration
                        </a>
                    }
                    else
                    {
                        <button disabled class="w-full px-6 py-3 rounded-xl text-gray-500 font-bold bg-gray-700/50 border border-gray-700 cursor-not-allowed text-center block">
                            <i class="fa-solid fa-lock mr-2"></i> Registration Not Recommended
                        </button>
                    }
                    <a asp-controller="Assessment" asp-action="Form" asp-route-eventId="@Model?.EventId"
                       class="w-full px-6 py-2.5 rounded-xl text-gray-300 font-medium bg-gray-800 hover:bg-gray-700 transition-colors text-center block text-sm">
                        <i class="fa-solid fa-rotate mr-2"></i> Retake Assessment
                    </a>
                    <a asp-controller="Participant" asp-action="Events"
                       class="w-full px-6 py-2.5 rounded-xl text-gray-400 font-medium hover:text-white transition-colors text-center block text-sm">
                        <i class="fa-solid fa-arrow-left mr-2"></i> Back to Events
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var ctx = document.getElementById('resultDonutChart')?.getContext('2d');
        if (ctx) {
            var score = @score;
            var maxScore = @maxScore;
            var remaining = maxScore - score;
            var threshold = @threshold;
            var thresholdRemaining = maxScore - threshold;
            var color = '@(isGoodMatch ? "#10b981" : isBorderline ? "#f59e0b" : "#ef4444")';
            
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Your Score', 'Required Threshold'],
                    datasets: [{
                        data: [score, thresholdRemaining],
                        backgroundColor: [color, '#374151'],
                        borderWidth: 0,
                        cutout: '72%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    var label = context.label || '';
                                    var value = context.parsed || 0;
                                    return label + ': ' + value + ' / ' + maxScore;
                                }
                            }
                        }
                    }
                }
            });
        }

        var acknowledgeCheckbox = document.querySelector('input[id^="acknowledge"]');
        var proceedButton = document.getElementById('proceedButton');
        var headerProceedBtn = document.getElementById('headerProceedBtn');
        
        if (acknowledgeCheckbox && proceedButton) {
            proceedButton.style.opacity = '0.5';
            proceedButton.style.pointerEvents = 'none';
            if (headerProceedBtn) {
                headerProceedBtn.style.opacity = '0.5';
                headerProceedBtn.style.pointerEvents = 'none';
            }
            
            acknowledgeCheckbox.addEventListener('change', function() {
                if (this.checked) {
                    proceedButton.style.opacity = '1';
                    proceedButton.style.pointerEvents = 'auto';
                    if (headerProceedBtn) {
                        headerProceedBtn.style.opacity = '1';
                        headerProceedBtn.style.pointerEvents = 'auto';
                    }
                } else {
                    proceedButton.style.opacity = '0.5';
                    proceedButton.style.pointerEvents = 'none';
                    if (headerProceedBtn) {
                        headerProceedBtn.style.opacity = '0.5';
                        headerProceedBtn.style.pointerEvents = 'none';
                    }
                }
            });
        }
    });
</script>

<style>
    .primary-btn {
        background: linear-gradient(to right, #f97316, #9333ea);
    }
    .primary-btn:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
</style>