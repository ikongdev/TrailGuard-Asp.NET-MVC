@model TrailGuard.Models.Event
@{
    ViewData["Title"] = "Suitability Assessment";
    var eventItem = ViewBag.Event as TrailGuard.Models.Event;
    var isRetake = ViewBag.RetakeMode ?? false;
}

<div class="pt-24 px-4 max-w-4xl mx-auto min-h-screen text-white pb-12">
    
    <div class="mb-6">
        <a asp-controller="Participant" asp-action="Events" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Back to Events
        </a>
    </div>

    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full bg-gradient-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                <i class="fa-solid fa-clipboard-check text-white text-2xl"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-white">
                    @if (isRetake)
                    {
                        <span>Retake Suitability Assessment</span>
                    }
                    else
                    {
                        <span>Suitability Assessment</span>
                    }
                </h1>
                <p class="text-gray-400 text-sm">
                    @if (isRetake)
                    {
                        <span>You are retaking the assessment. Your previous answers will be replaced.</span>
                    }
                    else
                    {
                        <span>Please answer all questions honestly to help us assess your suitability for this event.</span>
                    }
                </p>
            </div>
        </div>

        @if (isRetake)
        {
            <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 mb-6">
                <p class="text-yellow-300 text-sm flex items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span>Your previous assessment will be replaced with your new answers.</span>
                </p>
            </div>
        }

        <div class="bg-orange-500/10 border border-orange-500/30 rounded-xl p-4 mb-6">
            <p class="text-orange-300 text-sm">
                <i class="fa-solid fa-info-circle mr-2"></i>
                <span class="font-semibold">Event:</span> @eventItem?.EventTitle
            </p>
            <div class="flex flex-wrap gap-4 text-orange-300/70 text-sm mt-1">
                <span><i class="fa-regular fa-calendar mr-2"></i>@eventItem?.EventDate.ToString("MMMM dd, yyyy")</span>
                <span><i class="fa-solid fa-mountain mr-2"></i>@eventItem?.Difficulty</span>
                <span><i class="fa-regular fa-clock mr-2"></i>@eventItem?.EstimatedDuration hrs</span>
                <span><i class="fa-solid fa-route mr-2"></i>@eventItem?.Trail?.DistanceKm km</span>
                <span><i class="fa-solid fa-arrow-trend-up mr-2"></i>@eventItem?.Trail?.ElevationGainMeters m</span>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- PROGRESS BAR & STEP INDICATOR                                 -->
        <!-- ============================================================ -->
        <div class="mb-8">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-gray-400">Step <span id="currentStepDisplay">1</span> of 3</span>
                <span class="text-sm text-gray-400" id="stepLabel">Personal & Physical Profile</span>
            </div>
            <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                <div id="progressBar" class="h-full bg-gradient-to-r from-orange-500 to-purple-600 rounded-full transition-all duration-500" style="width: 33.33%"></div>
            </div>
            <div class="flex justify-between mt-1 text-xs text-gray-500">
                <span class="text-orange-400" id="step1Label">● Step 1</span>
                <span id="step2Label">○ Step 2</span>
                <span id="step3Label">○ Step 3</span>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- FORM STARTS HERE                                              -->
        <!-- ============================================================ -->
        <form method="post" asp-action="Form" asp-route-eventId="@(eventItem?.Id)" id="assessmentForm">
            @Html.AntiForgeryToken()

            <!-- ============================================================ -->
            <!-- STEP 1: Personal and Physical Profile                        -->
            <!-- ============================================================ -->
            <div id="step1" class="step-content">
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">1</span>
                        Personal and Physical Profile
                    </h2>

                    <div class="space-y-4">
                        <!-- Q1: Age -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">1. How old are you? <span class="text-red-400">*</span></label>
                            <input type="number" name="age" id="age" required min="10" max="100" 
                                   class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                   placeholder="Enter your age" />
                        </div>

                        <!-- Q2: Gender -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">2. What is your Gender? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="gender" value="Male" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Male</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="gender" value="Female" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Female</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="gender" value="Prefer not to answer" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Prefer not to answer</span>
                                </label>
                            </div>
                        </div>

                        <!-- Q3: Height & Weight with BMI -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">3. What is your current height and weight? <span class="text-red-400">*</span></label>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <div>
                                    <input type="number" name="heightCm" id="heightCm" required step="0.1" min="100" max="250" 
                                           class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                           placeholder="Height (cm)" oninput="calculateBMI()" />
                                </div>
                                <div>
                                    <input type="number" name="weightKg" id="weightKg" required step="0.1" min="30" max="200" 
                                           class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                           placeholder="Weight (kg)" oninput="calculateBMI()" />
                                </div>
                                <div>
                                    <div class="bg-[#0B1325] border border-gray-700 rounded-xl px-4 py-3 h-full flex items-center">
                                        <span class="text-gray-400 text-sm">BMI: </span>
                                        <span id="bmiDisplay" class="text-white font-semibold ml-2">—</span>
                                        <span id="bmiCategory" class="text-xs ml-2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Q4: Medical Conditions -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">4. Do you have any of the following medical conditions? <span class="text-red-400">*</span></label>
                            <div class="space-y-2 bg-[#0B1325] border border-gray-700 rounded-xl p-4">
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" name="medicalConditions" value="Asthma / lung-related condition" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Asthma / lung-related condition</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" name="medicalConditions" value="Hypertension / heart-related condition" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Hypertension / heart-related condition</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" name="medicalConditions" value="Joint or knee injury" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Joint or knee injury</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" name="medicalConditions" value="Vertigo / frequent dizziness" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Vertigo / frequent dizziness</span>
                                </label>
                                <label class="flex items-center gap-3 cursor-pointer">
                                    <input type="checkbox" name="medicalConditions" value="None of the above" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None of the above</span>
                                </label>
                            </div>
                            <p class="text-gray-500 text-xs mt-1">Select all that apply. If none, select "None of the above".</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- STEP 2: Fitness & Endurance + Hiking Experience              -->
            <!-- ============================================================ -->
            <div id="step2" class="step-content hidden">
                <!-- Fitness & Endurance -->
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6 mb-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">2</span>
                        Fitness and Endurance
                    </h2>

                    <div class="space-y-4">
                        <!-- Q5: Exercise Frequency -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">5. In the past 3 months, how often did you exercise or do physical activities in a typical week? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseFrequency" value="I do not exercise / Sedentary" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">I do not exercise / Sedentary</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseFrequency" value="1 to 2 times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">1 to 2 times per week</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseFrequency" value="3 to 4 times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">3 to 4 times per week</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseFrequency" value="5 or more times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">5 or more times per week</span>
                                </label>
                            </div>
                        </div>

                        <!-- Q6: Exercise Type -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">6. What is the main type of exercise you usually do? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseType" value="None / No specific exercise" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None / No specific exercise</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseType" value="Cardio or endurance only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Cardio or endurance only (running, cycling, swimming)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseType" value="Strength or resistance only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Strength or resistance only (weight training, calisthenics)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="exerciseType" value="Combination of cardio and strength training" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Combination of cardio and strength training</span>
                                </label>
                            </div>
                        </div>

                        <!-- Q7: Cardio Endurance -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">7. If you were to run or walk briskly on a flat road, how long can you do it continuously without stopping to rest? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="cardioEndurance" value="Less than 15 minutes" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Less than 15 minutes</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="cardioEndurance" value="15 to 30 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">15 to 30 minutes</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="cardioEndurance" value="31 to 60 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">31 to 60 minutes</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="cardioEndurance" value="More than 60 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">More than 60 minutes</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Hiking Experience -->
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">3</span>
                        Hiking Experience
                    </h2>

                    <div class="space-y-4">
                        <!-- Q8: Mountains Climbed -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">8. How many mountains have you climbed in your lifetime? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="mountainsClimbed" value="This will be my first time / First-timer" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">This will be my first time / First-timer</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="mountainsClimbed" value="1 to 3 mountains / Beginner" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">1 to 3 mountains / Beginner</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="mountainsClimbed" value="4 to 10 mountains / Intermediate" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">4 to 10 mountains / Intermediate</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="mountainsClimbed" value="More than 10 mountains / Experienced" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">More than 10 mountains / Experienced</span>
                                </label>
                            </div>
                        </div>

                        <!-- Q9: Recency of Hike -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">9. When was your most recent mountain hike? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="recencyOfHike" value="I have never climbed a mountain before" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">I have never climbed a mountain before</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="recencyOfHike" value="More than 1 year ago" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">More than 1 year ago</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="recencyOfHike" value="Within the past 4 to 12 months" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Within the past 4 to 12 months</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="recencyOfHike" value="Within the past 1 to 3 months" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Within the past 1 to 3 months</span>
                                </label>
                            </div>
                        </div>

                        <!-- Q10: Trail Difficulty Completed -->
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">10. What is the highest or most difficult type of trail you have completed before? <span class="text-red-400">*</span></label>
                            <div class="space-y-2">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="trailDifficultyCompleted" value="None / I have never climbed before" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None / I have never climbed before</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="trailDifficultyCompleted" value="Minor day hikes only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Minor day hikes only</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="trailDifficultyCompleted" value="Major hikes with steep assault sections" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Major hikes with steep assault sections</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="trailDifficultyCompleted" value="Multi-day or overnight expeditions" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Multi-day or overnight expeditions</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- STEP 3: Gear Preparedness + Consent                          -->
            <!-- ============================================================ -->
            <div id="step3" class="step-content hidden">
                <!-- Gear Preparedness -->
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6 mb-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">4</span>
                        Gear Preparedness
                    </h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">11. Which of the following items will you definitely bring or have already packed for this hike? <span class="text-red-400">*</span></label>
                        <div class="space-y-2 bg-[#0B1325] border border-gray-700 rounded-xl p-4">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Enough water" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Enough water, minimum of 2 liters or based on trail requirement</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Trail food" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Trail food, such as nuts, chocolates, jelly pouches, or energy snacks</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="First aid kit" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Personal first aid kit and personal medicine, such as antihistamine, inhaler, or band-aid</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Flashlight" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Flashlight or headlamp with extra battery</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Whistle" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Whistle for emergency signaling</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Raincoat" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Raincoat or poncho</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Navigation tool" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Navigation tool, such as offline map, powerbank, or compass</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="gearItems" value="Proper hiking shoes" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Proper hiking shoes or trail runners with good grip</span>
                            </label>
                        </div>
                        <p class="text-gray-500 text-xs mt-1">Select all items you will bring.</p>
                    </div>
                </div>

                <!-- Consent Section -->
                <div class="space-y-4">
                    <!-- Certification -->
                    <div class="bg-yellow-500/5 border border-yellow-500/30 rounded-xl p-4">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="consentGiven" value="true" required class="w-5 h-5 mt-0.5 accent-orange-500" />
                            <div>
                                <p class="text-gray-300 text-sm font-medium">I certify that the information I provided is true and accurate.</p>
                                <p class="text-gray-400 text-sm">I understand that false or misleading answers may affect my safety and may result in rejection, waisting, or removal from the event.</p>
                            </div>
                        </label>
                    </div>

                    <!-- Data Privacy Consent -->
                    <div class="bg-blue-500/5 border border-blue-500/30 rounded-xl p-4">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="dataPrivacyConsent" value="true" required class="w-5 h-5 mt-0.5 accent-orange-500" />
                            <div>
                                <p class="text-gray-300 text-sm font-medium">I have read and understood the Data Privacy Consent Statement.</p>
                                <p class="text-gray-400 text-sm">
                                    I voluntarily give my consent to the collection, processing, storage, and use of my personal information for the purposes stated above.
                                    <button type="button" onclick="openPrivacyModal()" class="text-orange-400 hover:text-orange-300 underline ml-1">
                                        Read more
                                    </button>
                                </p>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Summary Preview -->
                <div class="mt-6 bg-green-500/5 border border-green-500/30 rounded-xl p-4">
                    <p class="text-green-300 text-sm font-medium flex items-center gap-2">
                        <i class="fa-solid fa-check-circle"></i>
                        Ready to submit!
                    </p>
                    <p class="text-gray-400 text-sm mt-1">Please review your answers before submitting.</p>
                </div>
            </div>

            <!-- ============================================================ -->
            <!-- NAVIGATION BUTTONS                                           -->
            <!-- ============================================================ -->
            <div class="flex justify-between mt-8 pt-4 border-t border-white/10">
                <button type="button" id="prevBtn" onclick="prevStep()" class="px-6 py-3 rounded-xl text-gray-300 font-medium bg-gray-800 hover:bg-gray-700 transition-colors hidden">
                    <i class="fa-solid fa-arrow-left mr-2"></i> Previous
                </button>
                <div class="flex-1"></div>
                <button type="button" id="nextBtn" onclick="nextStep()" class="px-6 py-3 rounded-xl text-white font-bold bg-gradient-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all">
                    Next <i class="fa-solid fa-arrow-right ml-2"></i>
                </button>
                <button type="submit" id="submitBtn" class="px-6 py-3 rounded-xl text-white font-bold bg-gradient-to-r from-green-500 to-emerald-600 hover:opacity-90 transition-all hidden">
                    <i class="fa-regular fa-paper-plane mr-2"></i> Submit Assessment
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ============================================================ -->
<!-- DATA PRIVACY MODAL                                           -->
<!-- ============================================================ -->
<div id="privacyModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closePrivacyModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-700 rounded-2xl shadow-2xl w-full max-w-3xl max-h-[85vh] overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-700 shrink-0 bg-[#0B1325]">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-orange-500/20 flex items-center justify-center">
                    <i class="fa-solid fa-shield-halved text-orange-400"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Data Privacy Consent Statement</h2>
            </div>
            <button onclick="closePrivacyModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <div class="overflow-y-auto p-6 custom-scrollbar flex-1">
            <div class="prose prose-invert max-w-none">
                <p class="text-gray-300 leading-relaxed">
                    In accordance with the <strong>Data Privacy Act of 2012 (Republic Act No. 10173)</strong>, I voluntarily agree to provide my personal information and participate in the assessment conducted through the TrailGuard system.
                </p>

                <p class="text-gray-300 leading-relaxed mt-4">
                    I understand that the information collected, including but not limited to my name, email address, contact information, and responses to the assessment form, shall be used solely for the purposes of account registration, assessment, system operation, research, and the development and evaluation of the TrailGuard capstone project.
                </p>

                <p class="text-gray-300 leading-relaxed mt-4 font-semibold">I further understand that:</p>

                <ol class="list-decimal list-inside space-y-2 text-gray-300 mt-2">
                    <li>My participation in the assessment and use of the TrailGuard system is voluntary.</li>
                    <li>All information that I provide shall be treated with strict confidentiality and shall only be accessed by the authorized proponents, advisers, and personnel directly involved in the implementation and evaluation of the system.</li>
                    <li>Appropriate technical and organizational measures shall be employed to safeguard my personal information against unauthorized access, disclosure, alteration, misuse, or destruction.</li>
                    <li>My personal information shall not be shared with any unauthorized third party without my consent, except when required by law.</li>
                    <li>The data gathered may be used for academic research, statistical analysis, and system improvement purposes. Any reports, presentations, or publications resulting from this study shall present only aggregated or anonymized information to ensure that my identity remains protected.</li>
                    <li>I may request access to, correction of, or deletion of my personal information, subject to the applicable provisions of the Data Privacy Act of 2012 and the policies governing the TrailGuard system.</li>
                </ol>

                <p class="text-gray-300 leading-relaxed mt-4">
                    TrailGuard is a capstone project developed for academic and research purposes. The information collected through this system shall be used exclusively for the conduct of the study, evaluation of the system, and improvement of its features and services.
                </p>

                <div class="mt-6 p-4 bg-white/5 rounded-xl border border-white/10">
                    <p class="text-gray-400 text-sm">
                        <strong>Reference:</strong><br />
                        National Privacy Commission. (2012). Republic Act 10173 – Data Privacy Act of 2012. National Privacy Commission.
                        <a href="https://privacy.gov.ph/data-privacy-act/" target="_blank" class="text-orange-400 hover:text-orange-300 underline">
                            https://privacy.gov.ph/data-privacy-act/
                        </a>
