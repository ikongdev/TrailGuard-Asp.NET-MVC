@model TrailGuard.Models.Event
@{
    ViewData["Title"] = "Suitability Assessment";
    var eventItem = ViewBag.Event as TrailGuard.Models.Event;
    var isRetake = ViewBag.RetakeMode ?? false;
}

<div class="pt-24 px-4 max-w-4xl mx-auto min-h-screen text-white pb-12">
    
    <div class="mb-6">
        <a asp-controller="Participant" asp-action="Events" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Back to Events
        </a>
    </div>

    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-8">
        <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                <i class="fa-solid fa-clipboard-check text-white text-2xl"></i>
            </div>
            <div>
                <h1 class="text-2xl font-bold text-white">
                    @if (isRetake)
                    {
                        <span>Retake Suitability Assessment</span>
                    }
                    else
                    {
                        <span>Suitability Assessment</span>
                    }
                </h1>
                <p class="text-gray-400 text-sm">
                    @if (isRetake)
                    {
                        <span>You are retaking the assessment. Your previous answers will be replaced.</span>
                    }
                    else
                    {
                        <span>Please answer all questions honestly to help us assess your suitability for this event.</span>
                    }
                </p>
            </div>
        </div>

        @if (isRetake)
        {
            <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 mb-6">
                <p class="text-yellow-300 text-sm flex items-center gap-2">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <span>Your previous assessment will be replaced with your new answers.</span>
                </p>
            </div>
        }

        <div class="bg-orange-500/10 border border-orange-500/30 rounded-xl p-4 mb-6">
            <p class="text-orange-300 text-sm">
                <i class="fa-solid fa-info-circle mr-2"></i>
                <span class="font-semibold">Event:</span> @eventItem?.EventTitle
            </p>
            <div class="flex flex-wrap gap-4 text-orange-300/70 text-sm mt-1">
                <span><i class="fa-regular fa-calendar mr-2"></i>@eventItem?.EventDate.ToString("MMMM dd, yyyy")</span>
                <span><i class="fa-solid fa-mountain mr-2"></i>@eventItem?.Difficulty</span>
                <span><i class="fa-regular fa-clock mr-2"></i>@eventItem?.EstimatedDuration hrs</span>
                <span><i class="fa-solid fa-route mr-2"></i>@eventItem?.Trail?.DistanceKm km</span>
                <span><i class="fa-solid fa-arrow-trend-up mr-2"></i>@eventItem?.Trail?.ElevationGainMeters m</span>
            </div>
        </div>

        <div class="mb-8">
            <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-gray-400">Step <span id="currentStepDisplay">1</span> of 3</span>
                <span class="text-sm text-gray-400" id="stepLabel">Personal & Physical Profile</span>
            </div>
            <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                <div id="progressBar" class="h-full bg-linear-to-r from-orange-500 to-purple-600 rounded-full transition-all duration-500" style="width: 33.33%"></div>
            </div>
            <div class="flex justify-between mt-1 text-xs text-gray-500">
                <span class="text-orange-400" id="step1Label">● Step 1</span>
                <span id="step2Label">○ Step 2</span>
                <span id="step3Label">○ Step 3</span>
            </div>
        </div>

        <form method="post" asp-action="Form" asp-route-eventId="@(eventItem?.Id)" id="assessmentForm">
            @Html.AntiForgeryToken()

            <div id="step1" class="step-content">
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">1</span>
                        Personal and Physical Profile
                    </h2>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">1. How old are you? <span class="text-red-400">*</span></label>
                            <input type="number" name="age" id="age" required min="10" max="100" 
                                   class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                   placeholder="Enter your age" />
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">2. What is your Gender? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="gender" value="Male" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Male</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="gender" value="Female" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Female</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="gender" value="Prefer not to answer" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Prefer not to answer</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">3. What is your current height and weight? <span class="text-red-400">*</span></label>
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                <div>
                                    <input type="number" name="heightCm" id="heightCm" required step="0.1" min="100" max="250" 
                                           class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                           placeholder="Height (cm)" oninput="calculateBMI()" />
                                </div>
                                <div>
                                    <input type="number" name="weightKg" id="weightKg" required step="0.1" min="30" max="200" 
                                           class="w-full bg-[#0B1325] border border-gray-700 text-white rounded-xl px-4 py-3 focus:border-orange-500 focus:outline-none transition-colors" 
                                           placeholder="Weight (kg)" oninput="calculateBMI()" />
                                </div>
                                <div>
                                    <div class="bg-[#0B1325] border border-gray-700 rounded-xl px-4 py-3 h-full flex items-center">
                                        <span class="text-gray-400 text-sm">BMI: </span>
                                        <span id="bmiDisplay" class="text-white font-semibold ml-2">—</span>
                                        <span id="bmiCategory" class="text-xs ml-2"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">4. Do you have any of the following medical conditions? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2 bg-[#0B1325] border border-gray-700 rounded-xl p-4">
                                <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="checkbox" name="medicalConditions" value="Asthma / lung-related condition" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Asthma</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="checkbox" name="medicalConditions" value="Hypertension / heart-related condition" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Hypertension</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="checkbox" name="medicalConditions" value="Joint or knee injury" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Joint / Knee Injury</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="checkbox" name="medicalConditions" value="Vertigo / frequent dizziness" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Vertigo / Dizziness</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="checkbox" name="medicalConditions" value="None of the above" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None of the above</span>
                                </label>
                            </div>
                            <p class="text-gray-500 text-xs mt-1">Select all that apply. If none, select "None of the above".</p>
                        </div>
                    </div>
                </div>
            </div>

            <div id="step2" class="step-content hidden">
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6 mb-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">2</span>
                        Fitness and Endurance
                    </h2>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">5. In the past 3 months, how often did you exercise or do physical activities in a typical week? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseFrequency" value="I do not exercise / Sedentary" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Sedentary</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseFrequency" value="1 to 2 times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">1-2x / week</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseFrequency" value="3 to 4 times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">3-4x / week</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseFrequency" value="5 or more times per week" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">5+ / week</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">6. What is the main type of exercise you usually do? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseType" value="None / No specific exercise" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseType" value="Cardio or endurance only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Cardio Only</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseType" value="Strength or resistance only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Strength Only</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="exerciseType" value="Combination of cardio and strength training" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Combination</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">7. If you were to run or walk briskly on a flat road, how long can you do it continuously without stopping to rest? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="cardioEndurance" value="Less than 15 minutes" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">&lt;15 min</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="cardioEndurance" value="15 to 30 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">15-30 min</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="cardioEndurance" value="31 to 60 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">31-60 min</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="cardioEndurance" value="More than 60 minutes" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">&gt;60 min</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">3</span>
                        Hiking Experience
                    </h2>

                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">8. How many mountains have you climbed in your lifetime? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="mountainsClimbed" value="This will be my first time / First-timer" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">First-timer</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="mountainsClimbed" value="1 to 3 mountains / Beginner" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Beginner (1-3)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="mountainsClimbed" value="4 to 10 mountains / Intermediate" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Intermediate (4-10)</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="mountainsClimbed" value="More than 10 mountains / Experienced" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Experienced (10+)</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">9. When was your most recent mountain hike? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="recencyOfHike" value="I have never climbed a mountain before" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Never climbed</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="recencyOfHike" value="More than 1 year ago" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">&gt;1 year ago</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="recencyOfHike" value="Within the past 4 to 12 months" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">4-12 months</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="recencyOfHike" value="Within the past 1 to 3 months" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">1-3 months</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">10. What is the highest or most difficult type of trail you have completed before? <span class="text-red-400">*</span></label>
                            <div class="flex flex-wrap gap-2">
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="trailDifficultyCompleted" value="None / I have never climbed before" required class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">None</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="trailDifficultyCompleted" value="Minor day hikes only" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Minor hikes</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="trailDifficultyCompleted" value="Major hikes with steep assault sections" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Major hikes</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer px-4 py-2 rounded-xl border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                    <input type="radio" name="trailDifficultyCompleted" value="Multi-day or overnight expeditions" class="w-4 h-4 accent-orange-500" />
                                    <span class="text-gray-300 text-sm">Multi-day</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="step3" class="step-content hidden">
                <div class="bg-[#111A2E]/50 border border-white/5 rounded-2xl p-6 mb-6">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
                        <span class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500 text-white text-xs font-bold">4</span>
                        Gear Preparedness
                    </h2>

                    <div>
                        <label class="block text-sm font-medium text-gray-300 mb-2">11. Which of the following items will you definitely bring or have already packed for this hike? <span class="text-red-400">*</span></label>
                        <div class="flex flex-wrap gap-2 bg-[#0B1325] border border-gray-700 rounded-xl p-4">
                            <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                <input type="checkbox" name="gearItems" value="Enough water" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Water</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                <input type="checkbox" name="gearItems" value="Trail food" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">Trail food</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer px-3 py-1.5 rounded-lg border border-gray-700 hover:border-orange-500 transition-all has-checked:border-orange-500 has-checked:bg-orange-500/10">
                                <input type="checkbox" name="gearItems" value="First aid kit" class="w-4 h-4 accent-orange-500" />
                                <span class="text-gray-300 text-sm">First aid kit</span>
                            </label>
