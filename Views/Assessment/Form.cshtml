        <div class="px-6 py-4 border-t border-gray-700 shrink-0 flex justify-end bg-[#0B1325]">
            <button onclick="closePrivacyModal()" class="px-6 py-2.5 rounded-xl text-white font-medium bg-gradient-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all">
                I Understand
            </button>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
    .primary-btn {
        background: linear-gradient(to right, #f97316, #9333ea);
    }
    .primary-btn:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
</style>

<script>
    // ============================================================
    // Step Navigation
    // ============================================================
    var currentStep = 1;
    var totalSteps = 3;

    function updateStepUI() {
        // Show/hide steps
        for (var i = 1; i <= totalSteps; i++) {
            var step = document.getElementById('step' + i);
            if (step) {
                if (i === currentStep) {
                    step.classList.remove('hidden');
                } else {
                    step.classList.add('hidden');
                }
            }
        }

        // Update progress bar
        var progress = (currentStep / totalSteps) * 100;
        document.getElementById('progressBar').style.width = progress + '%';

        // Update step display
        document.getElementById('currentStepDisplay').textContent = currentStep;

        // Update step labels
        var labels = ['Personal & Physical Profile', 'Fitness & Experience', 'Gear & Consent'];
        document.getElementById('stepLabel').textContent = labels[currentStep - 1];

        // Update step indicators
        for (var i = 1; i <= totalSteps; i++) {
            var label = document.getElementById('step' + i + 'Label');
            if (label) {
                if (i < currentStep) {
                    label.className = 'text-green-400';
                    label.textContent = '✓ Step ' + i;
                } else if (i === currentStep) {
                    label.className = 'text-orange-400';
                    label.textContent = '● Step ' + i;
                } else {
                    label.className = 'text-gray-500';
                    label.textContent = '○ Step ' + i;
                }
            }
        }

        // Show/hide navigation buttons
        var prevBtn = document.getElementById('prevBtn');
        var nextBtn = document.getElementById('nextBtn');
        var submitBtn = document.getElementById('submitBtn');

        if (currentStep === 1) {
            prevBtn.classList.add('hidden');
        } else {
            prevBtn.classList.remove('hidden');
        }

        if (currentStep === totalSteps) {
            nextBtn.classList.add('hidden');
            submitBtn.classList.remove('hidden');
        } else {
            nextBtn.classList.remove('hidden');
            submitBtn.classList.add('hidden');
        }

        // Scroll to top of form
        document.querySelector('.bg-white/5')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function nextStep() {
        if (validateStep(currentStep)) {
            if (currentStep < totalSteps) {
                currentStep++;
                updateStepUI();
            }
        }
    }

    function prevStep() {
        if (currentStep > 1) {
            currentStep--;
            updateStepUI();
        }
    }

    // ============================================================
    // Validation per Step
    // ============================================================
    function validateStep(step) {
        var stepElement = document.getElementById('step' + step);
        var requiredInputs = stepElement.querySelectorAll('[required]');
        var isValid = true;
        var firstInvalid = null;

        requiredInputs.forEach(function(input) {
            // Skip hidden inputs
            if (input.type === 'hidden') return;
            
            // Check if input is visible
            var isVisible = true;
            var parent = input.closest('.step-content');
            if (parent && parent.classList.contains('hidden')) {
                isVisible = false;
            }
            
            if (!isVisible) return;

            // Check radio buttons (at least one selected)
            if (input.type === 'radio') {
                var radioGroup = document.querySelectorAll('input[name="' + input.name + '"]');
                var isChecked = false;
                radioGroup.forEach(function(radio) {
                    if (radio.checked) isChecked = true;
                });
                if (!isChecked) {
                    isValid = false;
                    if (!firstInvalid) firstInvalid = input;
                    // Highlight the radio group
                    var container = input.closest('.space-y-2') || input.closest('div');
                    if (container) {
                        container.classList.add('border-red-500/50');
                        container.classList.add('bg-red-500/5');
                        setTimeout(function() {
                            container.classList.remove('border-red-500/50');
                            container.classList.remove('bg-red-500/5');
                        }, 3000);
                    }
                }
                return;
            }

            // Check checkboxes (at least one selected for medical conditions)
            if (input.type === 'checkbox' && input.name === 'medicalConditions') {
                var checkboxGroup = document.querySelectorAll('input[name="medicalConditions"]');
                var isChecked = false;
                checkboxGroup.forEach(function(cb) {
                    if (cb.checked) isChecked = true;
                });
                if (!isChecked) {
                    isValid = false;
                    if (!firstInvalid) firstInvalid = input;
                    var container = input.closest('.space-y-2');
                    if (container) {
                        container.classList.add('border-red-500/50');
                        container.classList.add('bg-red-500/5');
                        setTimeout(function() {
                            container.classList.remove('border-red-500/50');
                            container.classList.remove('bg-red-500/5');
                        }, 3000);
                    }
                }
                return;
            }

            // Regular inputs
            if (input.type === 'checkbox' && input.name !== 'medicalConditions') {
                // Skip checkbox validation for consent (handled separately)
                return;
            }

            if (!input.value || input.value.trim() === '') {
                isValid = false;
                if (!firstInvalid) firstInvalid = input;
                input.classList.add('border-red-500');
                setTimeout(function() {
                    input.classList.remove('border-red-500');
                }, 3000);
            }
        });

        // Special validation for Step 3 - Consent checkboxes
        if (step === 3) {
            var consentGiven = document.querySelector('input[name="consentGiven"]');
            var dataPrivacyConsent = document.querySelector('input[name="dataPrivacyConsent"]');
            
            if (consentGiven && !consentGiven.checked) {
                isValid = false;
                consentGiven.closest('.bg-yellow-500/5')?.classList.add('border-red-500/50');
                setTimeout(function() {
                    consentGiven.closest('.bg-yellow-500/5')?.classList.remove('border-red-500/50');
                }, 3000);
            }
            
            if (dataPrivacyConsent && !dataPrivacyConsent.checked) {
                isValid = false;
                dataPrivacyConsent.closest('.bg-blue-500/5')?.classList.add('border-red-500/50');
                setTimeout(function() {
                    dataPrivacyConsent.closest('.bg-blue-500/5')?.classList.remove('border-red-500/50');
                }, 3000);
            }
        }

        if (!isValid) {
            showToast('Please fill in all required fields before proceeding.', 'error');
            if (firstInvalid) {
                firstInvalid.focus();
                if (firstInvalid.type === 'radio') {
                    var firstRadio = document.querySelector('input[name="' + firstInvalid.name + '"]');
                    if (firstRadio) firstRadio.focus();
                }
            }
        }

        return isValid;
    }

    // ============================================================
    // BMI Calculator
    // ============================================================
    function calculateBMI() {
        var heightCm = parseFloat(document.getElementById('heightCm').value);
        var weightKg = parseFloat(document.getElementById('weightKg').value);
        var bmiDisplay = document.getElementById('bmiDisplay');
        var bmiCategory = document.getElementById('bmiCategory');

        if (heightCm > 0 && weightKg > 0) {
            var heightM = heightCm / 100;
            var bmi = weightKg / (heightM * heightM);
            bmiDisplay.textContent = bmi.toFixed(1);

            if (bmi < 18.5) {
                bmiCategory.textContent = '(Underweight)';
                bmiCategory.className = 'text-xs ml-2 text-yellow-400';
            } else if (bmi >= 18.5 && bmi < 25) {
                bmiCategory.textContent = '(Normal)';
                bmiCategory.className = 'text-xs ml-2 text-green-400';
            } else if (bmi >= 25 && bmi < 30) {
                bmiCategory.textContent = '(Overweight)';
                bmiCategory.className = 'text-xs ml-2 text-orange-400';
            } else {
                bmiCategory.textContent = '(Obese)';
                bmiCategory.className = 'text-xs ml-2 text-red-400';
            }
        } else {
            bmiDisplay.textContent = '—';
            bmiCategory.textContent = '';
        }
    }

    // ============================================================
    // Toast Messages
    // ============================================================
    function showToast(message, type) {
        var existingToast = document.querySelector('.toast-message');
        if (existingToast) existingToast.remove();
        
        var toast = document.createElement('div');
        toast.className = 'toast-message fixed top-24 right-4 z-50 ' + (type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90') + ' text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3';
        toast.innerHTML = `
            <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
            <span>${message}</span>
            <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        `;
        document.body.appendChild(toast);
        
        setTimeout(function() {
            if (toast) toast.remove();
        }, 4000);
    }

    // ============================================================
    // Data Privacy Modal
    // ============================================================
    function openPrivacyModal() {
        var modal = document.getElementById('privacyModal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closePrivacyModal() {
        var modal = document.getElementById('privacyModal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closePrivacyModal();
        }
    });

    document.getElementById('privacyModal')?.addEventListener('click', function(e) {
        if (e.target === this) {
            closePrivacyModal();
        }
    });

    // ============================================================
    // Keyboard Navigation
    // ============================================================
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            var activeElement = document.activeElement;
            if (activeElement && activeElement.type !== 'submit' && activeElement.type !== 'button') {
                // Check if we're in a step
                var stepContent = activeElement.closest('.step-content');
                if (stepContent) {
                    if (currentStep === totalSteps) {
                        // Submit if on last step
                        document.getElementById('assessmentForm').submit();
                    } else {
                        nextStep();
                    }
                }
            }
        }
    });

    // ============================================================
    // Initialize
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
        updateStepUI();
        
        // Auto-calculate BMI on load if values exist
        calculateBMI();
    });
</script>