@model List<TrailGuard.Models.EventRegistration>
@{
    ViewData["Title"] = "My Registrations";
    
    var totalRegistrations = Model.Count;
    var pendingCount = Model.Count(r => r.Status == "Pending");
    var acceptedCount = Model.Count(r => r.Status == "Accepted");
    var declinedCount = Model.Count(r => r.Status == "Rejected" || r.Status == "Declined");
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-pink-400">My Registrations</h1>
            <p class="text-gray-400 mt-1 text-sm">Track your event registration requests and review each request status.</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div id="successMessage" class="mb-6 bg-green-500/20 border border-green-500/50 text-green-300 px-6 py-4 rounded-2xl flex items-center gap-3 backdrop-blur-sm">
            <i class="fa-solid fa-check-circle text-green-400 text-xl"></i>
            <span>@TempData["Success"]</span>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div id="errorMessage" class="mb-6 bg-red-500/20 border border-red-500/50 text-red-300 px-6 py-4 rounded-2xl flex items-center gap-3 backdrop-blur-sm">
            <i class="fa-solid fa-exclamation-triangle text-red-400 text-xl"></i>
            <span>@TempData["Error"]</span>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
    }

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@totalRegistrations</p>
            <p class="text-gray-400 text-xs">Total Requests</p>
            <p class="text-[10px] text-gray-500">All active</p>
        </div>
        <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-yellow-400">@pendingCount</p>
            <p class="text-gray-400 text-xs">Pending</p>
            <p class="text-[10px] text-gray-500">Requested</p>
        </div>
        <div class="bg-green-500/10 border border-green-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-green-400">@acceptedCount</p>
            <p class="text-gray-400 text-xs">Accepted</p>
            <p class="text-[10px] text-gray-500">Confirmed</p>
        </div>
        <div class="bg-red-500/10 border border-red-500/30 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-red-400">@declinedCount</p>
            <p class="text-gray-400 text-xs">Declined</p>
            <p class="text-[10px] text-gray-500">Not accepted</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden h-150 flex flex-col">
            <div class="px-4 py-3 border-b border-white/10 shrink-0">
                <h2 class="text-sm font-semibold text-white">Your Registration Requests</h2>
            </div>
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                @if (Model.Any())
                {
                    @foreach (var reg in Model.OrderByDescending(r => r.RegisteredAt))
                    {
                        var statusColor = reg.Status switch
                        {
                            "Pending" => "text-yellow-400 bg-yellow-500/20",
                            "Accepted" => "text-green-400 bg-green-500/20",
                            "Rejected" => "text-red-400 bg-red-500/20",
                            "Declined" => "text-red-400 bg-red-500/20",
                            "Alternative Recommended" => "text-blue-400 bg-blue-500/20",
                            _ => "text-gray-400 bg-gray-500/20"
                        };
                        
                        <div class="registration-item flex items-center justify-between p-4 border-b border-white/5 hover:bg-white/5 transition-colors cursor-pointer" 
                             onclick="loadRegistrationDetails(@reg.Id)" data-reg-id="@reg.Id">
                            <div class="flex-1 min-w-0">
                                <p class="text-white font-medium text-sm truncate">@reg.Event?.EventTitle</p>
                                <p class="text-gray-400 text-xs truncate">@reg.Event?.Trail?.Name</p>
                                <div class="flex flex-wrap gap-3 text-xs text-gray-500 mt-1">
                                    <span><i class="fa-regular fa-calendar mr-1"></i>@reg.Event?.EventDate.ToString("MMM dd, yyyy")</span>
                                    <span><i class="fa-regular fa-clock mr-1"></i>@reg.Event?.FormattedEventTime</span>
                                </div>
                            </div>
                            <div class="flex items-center gap-3 ml-4 shrink-0">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold @statusColor whitespace-nowrap">
                                    @reg.Status
                                </span>
                                <i class="fa-solid fa-chevron-right text-gray-500 text-xs"></i>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-12 text-gray-500">
                        <i class="fa-regular fa-calendar-plus text-3xl block mb-3 opacity-50"></i>
                        <p class="text-sm">No registrations yet.</p>
                        <a asp-controller="Participant" asp-action="Events" 
                           class="inline-block mt-3 text-sm text-purple-400 hover:text-purple-300 transition-colors">
                            Browse Events →
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5 h-150 overflow-y-auto custom-scrollbar flex flex-col">
            <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2 shrink-0">
                <i class="fa-regular fa-file-lines text-purple-400"></i>
                Request Details
            </h2>
            
            <div id="registrationDetails" class="flex-1">
                <div class="text-center text-gray-500 py-8">
                    <i class="fa-regular fa-hand-pointer text-3xl block mb-3 opacity-50"></i>
                    <p class="text-sm">Select a registration</p>
                    <p class="text-xs text-gray-600">to view details here</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script id="loadingTemplate" type="text/template">
    <div class="text-center py-8">
        <div class="inline-block w-8 h-8 border-4 border-purple-500 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-gray-400 text-sm mt-3">Loading...</p>
    </div>
</script>

<script id="detailsTemplate" type="text/template">
    <div class="space-y-4">
        <div>
            <h3 class="text-white font-bold text-lg">{eventTitle}</h3>
            <p class="text-gray-400 text-xs">{trailName}</p>
        </div>

        <div class="flex items-center gap-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold {statusClass}">{status}</span>
        </div>

        <div class="bg-[#111A2E] rounded-xl p-3">
            <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Event Details</p>
            <div class="grid grid-cols-2 gap-1 text-sm">
                <div>
                    <span class="text-gray-500 text-[10px]">Date</span>
                    <p class="text-white text-xs">{eventDate}</p>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px]">Time</span>
                    <p class="text-white text-xs">{eventTime}</p>
                </div>
                <div class="col-span-2">
                    <span class="text-gray-500 text-[10px]">Location</span>
                    <p class="text-white text-xs">{eventLocation}</p>
                </div>
            </div>
        </div>

        <div class="bg-[#111A2E] rounded-xl p-3">
            <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Trail Details</p>
            <div class="grid grid-cols-2 gap-1 text-sm">
                <div>
                    <span class="text-gray-500 text-[10px]">Distance</span>
                    <p class="text-white text-xs font-medium">{trailDistance} km</p>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px]">Elevation</span>
                    <p class="text-white text-xs font-medium">{trailElevation} m</p>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px]">Terrain</span>
                    <p class="text-white text-xs font-medium">{trailTerrain}</p>
                </div>
                <div>
                    <span class="text-gray-500 text-[10px]">Difficulty</span>
                    <p class="text-white text-xs font-medium">{eventDifficulty}</p>
                </div>
            </div>
        </div>

        <div class="bg-[#111A2E] rounded-xl p-3">
            <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Registration Details</p>
            <div class="space-y-1 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500 text-[10px]">Name</span>
                    <span class="text-white text-xs">{participantName}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500 text-[10px]">Pickup Point</span>
                    <span class="text-white text-xs">{pickupPoint}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500 text-[10px]">Payment</span>
                    <span class="text-white text-xs">{paymentStatus}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500 text-[10px]">Registered</span>
                    <span class="text-white text-xs">{registeredAt}</span>
                </div>
            </div>
        </div>

        <div class="bg-[#111A2E] rounded-xl p-3">
            <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Assessment Result</p>
            <div class="flex items-center gap-3 mb-3">
                <span class="text-sm font-bold {assessmentColor}">{assessmentResult}</span>
                <span class="text-gray-500 text-xs">Score: {assessmentScore}/44</span>
            </div>
            <div class="space-y-2">
                <div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-400">Fitness</span>
                        <span class="text-white font-medium">{fitnessScore}/12</span>
                    </div>
                    <div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-blue-500" style="width: {fitnessPercent}%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-400">Experience</span>
                        <span class="text-white font-medium">{experienceScore}/12</span>
                    </div>
                    <div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-green-500" style="width: {experiencePercent}%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-400">Health</span>
                        <span class="text-white font-medium">{healthScore}/12</span>
                    </div>
                    <div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-purple-500" style="width: {healthPercent}%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-400">Gear</span>
                        <span class="text-white font-medium">{gearScore}/8</span>
                    </div>
                    <div class="w-full h-1.5 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-orange-500" style="width: {gearPercent}%"></div>
                    </div>
                </div>
            </div>
            <div class="mt-3 pt-3 border-t border-white/10">
                <p class="text-gray-500 text-[10px] uppercase tracking-wider mb-2">Trail Demands</p>
                <div class="grid grid-cols-2 gap-1 text-xs">
                    <div>
                        <span class="text-gray-500 text-[10px]">Distance</span>
                        <p class="text-white font-medium">{trailDistance} km</p>
                    </div>
                    <div>
                        <span class="text-gray-500 text-[10px]">Elevation</span>
                        <p class="text-white font-medium">{trailElevation} m</p>
                    </div>
                    <div>
                        <span class="text-gray-500 text-[10px]">Duration</span>
                        <p class="text-white font-medium">{eventDuration} hrs</p>
                    </div>
                    <div>
                        <span class="text-gray-500 text-[10px]">Terrain</span>
                        <p class="text-white font-medium">{trailTerrain}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex flex-col gap-2 mt-4">
            <a href="/Participant/Details/{eventId}" class="w-full px-4 py-2.5 rounded-xl text-white text-sm font-medium bg-linear-to-r from-purple-500 to-pink-500 hover:opacity-90 transition-all text-center">
                <i class="fa-regular fa-eye mr-2"></i> View Event Details
            </a>
            {cancelButton}
            {retakeButton}
        </div>
    </div>
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 5px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(168, 85, 247, 0.4);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(168, 85, 247, 0.6);
    }
    
    .custom-scrollbar {
        scrollbar-width: thin;
        scrollbar-color: rgba(168, 85, 247, 0.4) rgba(255, 255, 255, 0.05);
    }
    
    .registration-item.active {
        background: rgba(168, 85, 247, 0.1);
        border-left: 3px solid #a855f7;
    }
</style>

<script>
    let currentRegistrationId = null;

    function loadRegistrationDetails(id) {
        document.querySelectorAll('.registration-item').forEach(function(el) {
            el.classList.remove('active');
        });
        var selectedItem = document.querySelector('.registration-item[data-reg-id="' + id + '"]');
        if (selectedItem) {
            selectedItem.classList.add('active');
        }

        currentRegistrationId = id;
        var detailsContainer = document.getElementById('registrationDetails');
        
        detailsContainer.innerHTML = document.getElementById('loadingTemplate').innerHTML;

        fetch('/Registration/GetRegistrationDetails?id=' + id)
            .then(function(response) {
                return response.json();
            })
            .then(function(data) {
                if (data.success) {
                    var reg = data.registration;
                    var statusClass = reg.status === 'Pending' ? 'text-yellow-400 bg-yellow-500/20' : 
                                       reg.status === 'Accepted' ? 'text-green-400 bg-green-500/20' : 
                                       reg.status === 'Alternative Recommended' ? 'text-blue-400 bg-blue-500/20' : 
                                       'text-red-400 bg-red-500/20';
                    
                    var assessmentColor = reg.assessmentResult === 'Good-Match' ? 'text-green-400' : 
                                           reg.assessmentResult === 'Borderline' ? 'text-yellow-400' : 'text-red-400';
                    
                    var paymentStatus = reg.isPaid ? '✅ Paid' : '⏳ Unpaid';
                    
                    var fitnessPercent = Math.round((reg.fitnessScore / 12) * 100);
                    var experiencePercent = Math.round((reg.experienceScore / 12) * 100);
                    var healthPercent = Math.round((reg.healthScore / 12) * 100);
                    var gearPercent = Math.round((reg.gearScore / 8) * 100);
                    
                    var cancelButton = '';
                    var retakeButton = '';
                    if (reg.status === 'Pending') {
                        cancelButton = '<button onclick="cancelRegistration(' + reg.id + ')" class="w-full px-4 py-2 rounded-xl text-red-400 text-sm font-medium border border-red-500/30 hover:bg-red-500/10 transition-all text-center">Cancel Request</button>';
                    }
                    if (reg.status === 'Rejected' || reg.status === 'Declined' || reg.status === 'Alternative Recommended') {
                        retakeButton = '<a href="/Assessment/Form/' + reg.eventId + '" class="w-full px-4 py-2 rounded-xl text-purple-400 text-sm font-medium border border-purple-500/30 hover:bg-purple-500/10 transition-all text-center">Retake Assessment</a>';
                    }
                    
                    var template = document.getElementById('detailsTemplate').innerHTML
                        .replace(/{eventTitle}/g, reg.eventTitle || 'N/A')
                        .replace(/{trailName}/g, reg.trailName || 'N/A')
                        .replace(/{status}/g, reg.status)
                        .replace(/{statusClass}/g, statusClass)
                        .replace(/{eventDate}/g, reg.eventDate || 'N/A')
                        .replace(/{eventTime}/g, reg.eventTime || 'N/A')
                        .replace(/{eventLocation}/g, reg.eventLocation || 'N/A')
                        .replace(/{trailDistance}/g, reg.trailDistance || '0')
                        .replace(/{trailElevation}/g, reg.trailElevation || '0')
                        .replace(/{trailTerrain}/g, reg.trailTerrain || 'N/A')
                        .replace(/{eventDifficulty}/g, reg.eventDifficulty || 'N/A')
                        .replace(/{participantName}/g, reg.participantName || 'N/A')
                        .replace(/{pickupPoint}/g, reg.pickupPoint || 'N/A')
                        .replace(/{paymentStatus}/g, paymentStatus)
                        .replace(/{registeredAt}/g, reg.registeredAt || 'N/A')
                        .replace(/{assessmentResult}/g, reg.assessmentResult || 'N/A')
                        .replace(/{assessmentScore}/g, reg.assessmentScore || '0')
                        .replace(/{assessmentColor}/g, assessmentColor)
                        .replace(/{fitnessScore}/g, reg.fitnessScore || 0)
                        .replace(/{experienceScore}/g, reg.experienceScore || 0)
                        .replace(/{healthScore}/g, reg.healthScore || 0)
                        .replace(/{gearScore}/g, reg.gearScore || 0)
                        .replace(/{fitnessPercent}/g, fitnessPercent)
                        .replace(/{experiencePercent}/g, experiencePercent)
                        .replace(/{healthPercent}/g, healthPercent)
                        .replace(/{gearPercent}/g, gearPercent)
                        .replace(/{eventDuration}/g, reg.eventDuration || '0')
                        .replace(/{eventId}/g, reg.eventId)
                        .replace(/{cancelButton}/g, cancelButton)
                        .replace(/{retakeButton}/g, retakeButton);
                    
                    detailsContainer.innerHTML = template;
                } else {
                    detailsContainer.innerHTML = '<div class="text-center py-8 text-red-400"><i class="fa-solid fa-circle-exclamation text-2xl block mb-2"></i><p class="text-sm">' + (data.message || 'Error loading details') + '</p></div>';
                }
            })
            .catch(function(error) {
                console.error('Error:', error);
                detailsContainer.innerHTML = '<div class="text-center py-8 text-red-400"><i class="fa-solid fa-circle-exclamation text-2xl block mb-2"></i><p class="text-sm">Error loading registration details</p></div>';
            });
    }

    function cancelRegistration(id) {
        if (!confirm('Are you sure you want to cancel this registration?')) return;

        fetch('/Registration/CancelRegistration', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id })
        })
        .then(function(response) {
            return response.json();
        })
        .then(function(result) {
            if (result.success) {
                showToast(result.message, 'success');
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else {
                showToast(result.message, 'error');
            }
        })
        .catch(function(error) {
            console.error('Error:', error);
            showToast('Error cancelling registration', 'error');
        });
    }

    function showToast(message, type) {
        var existingToast = document.querySelector('.toast-message');
        if (existingToast) {
            existingToast.remove();
        }
        
        var toast = document.createElement('div');
        toast.className = 'toast-message fixed top-24 right-4 z-50 ' + (type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90') + ' text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3';
        toast.innerHTML = '<i class="fa-solid ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle') + '"></i><span>' + message + '</span><button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors"><i class="fa-solid fa-xmark text-lg"></i></button>';
        document.body.appendChild(toast);
        
        setTimeout(function() {
            if (toast) {
                toast.remove();
            }
        }, 3000);
    }

    document.addEventListener('DOMContentLoaded', function() {
        var firstItem = document.querySelector('.registration-item');
        if (firstItem) {
            var id = firstItem.getAttribute('data-reg-id');
            loadRegistrationDetails(id);
        }
    });
</script>