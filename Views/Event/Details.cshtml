@model TrailGuard.Models.Event
@using TrailGuard.Models
@{
    ViewData["Title"] = Model.EventTitle;
    var trail = ViewBag.Trail as TrailGuard.Models.Trail;
    var registrations = ViewBag.Registrations as List<EventRegistration> ?? new List<EventRegistration>();
    var registeredCount = ViewBag.RegisteredCount ?? 0;
    var availableSlots = ViewBag.AvailableSlots ?? 0;
    var isFull = availableSlots <= 0;
    var organizer = ViewBag.Organizer as ApplicationUser;
    var isCompleted = Model.Status == "Completed";
    var isCancelled = Model.Status == "Cancelled";
    var isUpcoming = Model.Status == "Upcoming";
    
    var joinedParticipants = registrations
        .Where(r => r.Status == "Accepted" || r.Status == "Pending")
        .OrderBy(r => r.RegisteredAt)
        .ToList();
    var totalJoined = joinedParticipants.Count;
    var hasMoreParticipants = totalJoined > 5;
}

<div class="pt-24 px-4 max-w-6xl mx-auto min-h-screen text-white pb-12">
    
    @if (TempData["Success"] != null)
    {
        <div id="successMessage" class="mb-6 bg-green-500/20 border border-green-500/50 text-green-300 px-6 py-4 rounded-2xl flex items-center gap-3 backdrop-blur-sm">
            <i class="fa-solid fa-check-circle text-green-400 text-xl"></i>
            <span>@TempData["Success"]</span>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
    }
    
    @if (TempData["Error"] != null)
    {
        <div id="errorMessage" class="mb-6 bg-red-500/20 border border-red-500/50 text-red-300 px-6 py-4 rounded-2xl flex items-center gap-3 backdrop-blur-sm">
            <i class="fa-solid fa-exclamation-triangle text-red-400 text-xl"></i>
            <span>@TempData["Error"]</span>
            <button type="button" onclick="this.parentElement.remove()" class="ml-auto hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        </div>
    }

    <div class="mb-6">
        <a asp-action="Index" class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors group">
            <i class="fa-solid fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
            Back to Events
        </a>
    </div>

    <div class="relative rounded-3xl overflow-hidden mb-8">
        @if (!string.IsNullOrEmpty(trail?.ThumbnailUrl))
        {
            <img src="@trail.ThumbnailUrl" alt="@trail.Name" class="w-full h-80 object-cover">
        }
        else
        {
            <div class="w-full h-80 bg-linear-to-r from-orange-500/30 to-purple-500/30 flex items-center justify-center">
                <i class="fa-solid fa-mountain text-6xl text-white/50"></i>
            </div>
        }
        <div class="absolute inset-0 bg-linear-to-t from-[#0B1325] via-[#0B1325]/50 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8">
            <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold 
                    @(Model.Status == "Upcoming" ? "bg-green-500/20 text-green-400" : 
                      Model.Status == "Cancelled" ? "bg-red-500/20 text-red-400" : 
                      Model.Status == "Postponed" ? "bg-yellow-500/20 text-yellow-400" : 
                      "bg-gray-500/20 text-gray-400")">
                    @Model.Status
                </span>
                
                <select id="statusDropdown" class="bg-black/50 border border-white/20 text-white text-xs rounded-full px-3 py-1 focus:border-orange-500 focus:outline-none">
                    <option value="Upcoming" selected="@(Model.Status == "Upcoming")">Upcoming</option>
                    <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                    <option value="Postponed" selected="@(Model.Status == "Postponed")">Postponed</option>
                    <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
                </select>
                
                @if (isFull && isUpcoming)
                {
                    <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-red-500/20 text-red-400">
                        <i class="fa-solid fa-circle-exclamation mr-1"></i> Full
                    </span>
                }
            </div>
            <h1 class="text-4xl font-bold text-white mb-2">@Model.EventTitle</h1>
            <div class="flex flex-wrap gap-4 text-gray-300">
                <span><i class="fa-regular fa-calendar text-orange-400 mr-2"></i>@Model.EventDate.ToString("MMMM dd, yyyy")</span>
                <span><i class="fa-regular fa-clock text-orange-400 mr-2"></i>@($"{Model.EventTime.Hours:D2}:{Model.EventTime.Minutes:D2} {(Model.EventTime.Hours >= 12 ? "PM" : "AM")}")</span>
                <span><i class="fa-solid fa-location-dot text-orange-400 mr-2"></i>@Model.Location</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <div class="lg:col-span-2 space-y-6">
            
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-info-circle text-orange-400 mr-2"></i>Event Overview</h2>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-mountain text-orange-400 mr-1"></i>Trail</p>
                        <p class="text-white font-semibold">@trail?.Name</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-route text-orange-400 mr-1"></i>Distance</p>
                        <p class="text-white font-semibold">@trail?.DistanceKm km</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-tree text-orange-400 mr-1"></i>Terrain Type</p>
                        <p class="text-white font-semibold">@trail?.Terrain</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-signal text-orange-400 mr-1"></i>Difficulty</p>
                        <p class="text-white font-semibold">@Model.Difficulty</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-arrow-trend-up text-orange-400 mr-1"></i>Elevation Gain</p>
                        <p class="text-white font-semibold">@trail?.ElevationGainMeters m</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-mountain-city text-orange-400 mr-1"></i>MASL</p>
                        <p class="text-white font-semibold">@Model.MASL m</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-clock text-orange-400 mr-1"></i>Estimated Duration</p>
                        <p class="text-white font-semibold">@Model.EstimatedDuration hours</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider"><i class="fa-solid fa-cloud-sun text-orange-400 mr-1"></i>Weather Forecast</p>
                        <p class="text-white font-semibold text-sm">@(Model.WeatherForecastAdvisory?.Split('\n').FirstOrDefault() ?? "N/A")</p>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-file-lines text-orange-400 mr-2"></i>Event Description</h2>
                <p class="text-gray-300 leading-relaxed whitespace-pre-wrap">@Model.Description</p>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-regular fa-calendar-plus text-orange-400 mr-2"></i>Schedule and Capacity</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider">Date</p>
                        <p class="text-white font-semibold">@Model.EventDate.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider">Time</p>
                        <p class="text-white font-semibold">@($"{Model.EventTime.Hours:D2}:{Model.EventTime.Minutes:D2} {(Model.EventTime.Hours >= 12 ? "PM" : "AM")}")</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider">Total Capacity</p>
                        <p class="text-white font-semibold">@Model.Capacity slots</p>
                    </div>
                    <div>
                        <p class="text-gray-500 text-xs uppercase tracking-wider">Available Slots</p>
                        <p class="text-white font-semibold @(availableSlots <= 5 ? "text-orange-400" : "")">
                            @availableSlots
                            @if (availableSlots <= 5 && availableSlots > 0)
                            {
                                <span class="text-xs text-orange-400/70 ml-1">(limited)</span>
                            }
                            @if (availableSlots <= 0)
                            {
                                <span class="text-xs text-red-400 ml-1">(full)</span>
                            }
                        </p>
                    </div>
                </div>
                
                @if (Model.Capacity > 0)
                {
                    var fillPercentage = (registeredCount * 100) / Model.Capacity;
                    <div class="mt-4">
                        <div class="flex justify-between text-xs text-gray-400 mb-1">
                            <span>@registeredCount registered</span>
                            <span>@fillPercentage% full</span>
                        </div>
                        <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                            <div class="h-full rounded-full transition-all duration-500 @(fillPercentage >= 90 ? "bg-red-500" : fillPercentage >= 70 ? "bg-yellow-500" : "bg-green-500")" 
                                 style="width: @fillPercentage%"></div>
                        </div>
                    </div>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-credit-card text-orange-400 mr-2"></i>Payment Details</h2>
                @if (!string.IsNullOrEmpty(Model.PaymentDetails))
                {
                    <div class="prose prose-invert max-w-none">
                        <p class="text-gray-300 whitespace-pre-wrap">@Model.PaymentDetails</p>
                    </div>
                }
                else
                {
                    <p class="text-gray-500 italic">No payment details provided for this event.</p>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-bus text-orange-400 mr-2"></i>Pickup Points</h2>
                @if (!string.IsNullOrEmpty(Model.PickupPoints))
                {
                    <div class="prose prose-invert max-w-none">
                        <p class="text-gray-300 whitespace-pre-wrap">@Model.PickupPoints</p>
                    </div>
                }
                else
                {
                    <p class="text-gray-500 italic">No pickup points specified for this event.</p>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-bullhorn text-orange-400 mr-2"></i>Reminders and Announcements</h2>
                @if (!string.IsNullOrEmpty(Model.Announcements))
                {
                    <div class="prose prose-invert max-w-none">
                        <p class="text-gray-300 whitespace-pre-wrap">@Model.Announcements</p>
                    </div>
                }
                else
                {
                    <p class="text-gray-500 italic">No announcements for this event.</p>
                }
            </div>
        </div>

        <div class="space-y-6 flex flex-col">
            
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-chart-simple text-orange-400 mr-2"></i>Summary</h2>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-solid fa-mountain text-orange-400 mr-2"></i>Trail</span>
                        <span class="text-white font-semibold">@trail?.Name</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-solid fa-signal text-orange-400 mr-2"></i>Difficulty</span>
                        <span class="text-white font-semibold">@Model.Difficulty</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-regular fa-calendar text-orange-400 mr-2"></i>Date & Time</span>
                        <span class="text-white font-semibold text-right">@Model.EventDate.ToString("MMM dd, yyyy")<br />@($"{Model.EventTime.Hours:D2}:{Model.EventTime.Minutes:D2} {(Model.EventTime.Hours >= 12 ? "PM" : "AM")}")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-regular fa-clock text-orange-400 mr-2"></i>Duration</span>
                        <span class="text-white font-semibold">@Model.EstimatedDuration hrs</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-solid fa-users text-orange-400 mr-2"></i>Capacity</span>
                        <span class="text-white font-semibold">@Model.Capacity slots</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-solid fa-user-check text-orange-400 mr-2"></i>Registered</span>
                        <span class="text-white font-semibold">@registeredCount / @Model.Capacity</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-400"><i class="fa-solid fa-circle-exclamation text-orange-400 mr-2"></i>Status</span>
                        <span class="text-white font-semibold">@Model.Status</span>
                    </div>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
                <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-user-tie text-orange-400 mr-2"></i>Organizer Details</h2>
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-12 h-12 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center overflow-hidden shrink-0">
                        @if (organizer != null && !string.IsNullOrEmpty(organizer.ProfilePictureUrl))
                        {
                            <img src="@organizer.ProfilePictureUrl" alt="Organizer" class="w-12 h-12 rounded-full object-cover">
                        }
                        else
                        {
                            <i class="fa-solid fa-user text-white text-lg"></i>
                        }
                    </div>
                    <div>
                        <h3 class="text-white font-bold">
                            @if (organizer != null)
                            {
                                @(organizer.FirstName + " " + organizer.LastName)
                            }
                            else
                            {
                                @Model.OrganizedBy
                            }
                        </h3>
                        <p class="text-gray-500 text-xs">Event Organizer</p>
                    </div>
                </div>
                @if (organizer != null)
                {
                    <div class="space-y-2">
                        @if (!string.IsNullOrEmpty(organizer.FacebookLink))
                        {
                            <a href="@organizer.FacebookLink" target="_blank" class="flex items-center gap-2 text-gray-400 hover:text-orange-400 transition-colors text-sm break-all">
                                <i class="fa-brands fa-facebook w-5 shrink-0"></i> 
                                <span class="break-all">@organizer.FacebookLink</span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(organizer.Email))
                        {
                            <a href="mailto:@organizer.Email" class="flex items-center gap-2 text-gray-400 hover:text-orange-400 transition-colors text-sm">
                                <i class="fa-regular fa-envelope w-5 shrink-0"></i> 
                                <span class="break-all">@organizer.Email</span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(organizer.PhoneNumber))
                        {
                            <a href="tel:@organizer.PhoneNumber" class="flex items-center gap-2 text-gray-400 hover:text-orange-400 transition-colors text-sm">
                                <i class="fa-solid fa-phone w-5 shrink-0"></i> 
                                <span>@organizer.PhoneNumber</span>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(organizer.Bio))
                        {
                            <p class="text-gray-400 text-sm mt-2 border-t border-white/10 pt-2">@organizer.Bio</p>
                        }
                    </div>
                }
                else
                {
                    <p class="text-gray-500 text-sm">Organizer contact details not available.</p>
                }
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6 flex flex-col flex-1">
                <h2 class="text-lg font-bold text-white mb-4 shrink-0">
                    <i class="fa-solid fa-users-viewfinder text-orange-400 mr-2"></i>Registered Participants
                    <span class="text-sm font-normal text-gray-400 ml-2">(@totalJoined)</span>
                </h2>
                <div class="flex-1 min-h-70 max-h-125 overflow-y-auto custom-scrollbar">
                    @if (joinedParticipants.Any())
                    {
                        <div class="space-y-3">
                            @foreach (var reg in joinedParticipants.Take(5))
                            {
                                <div class="flex items-center gap-3 p-2 rounded-lg hover:bg-white/5 transition-colors">
                                    <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center overflow-hidden shrink-0">
                                        @if (!string.IsNullOrEmpty(reg.User?.ProfilePictureUrl))
                                        {
                                            <img src="@reg.User.ProfilePictureUrl" alt="Participant" class="w-8 h-8 rounded-full object-cover">
                                        }
                                        else
                                        {
                                            <i class="fa-solid fa-user text-gray-400 text-xs"></i>
                                        }
                                    </div>
                                    <div class="min-w-0 flex-1">
                                        <p class="text-white text-sm font-medium truncate">@reg.ParticipantName</p>
                                        <p class="text-gray-500 text-xs">
                                            @if (reg.Status == "Accepted")
                                            {
                                                <span class="text-green-400"><i class="fa-solid fa-check-circle"></i> Confirmed</span>
                                            }
                                            else if (reg.Status == "Pending")
                                            {
                                                <span class="text-yellow-400"><i class="fa-solid fa-clock"></i> Pending</span>
                                            }
                                            else if (reg.Status == "Rejected")
                                            {
                                                <span class="text-red-400"><i class="fa-solid fa-xmark-circle"></i> Rejected</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            }
                            
                            @if (hasMoreParticipants)
                            {
                                <div class="text-center text-gray-500 text-sm py-2">
                                    <i class="fa-solid fa-user-plus mb-1 block"></i>
                                    <span>+ @(totalJoined - 5) more participants</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="h-full flex items-center justify-center">
                            <div class="text-center text-gray-500">
                                <i class="fa-regular fa-user text-3xl mb-2 block"></i>
                                <p class="text-sm">No participants registered yet.</p>
                                <p class="text-xs text-gray-600">Waiting for participants to join.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-6">
        <div>
            <p class="text-gray-400 text-sm">
                <i class="fa-solid fa-users text-orange-400 mr-2"></i>
                <span class="font-semibold text-white">@registeredCount</span> participants registered
                @if (isUpcoming && !isFull)
                {
                    <span class="text-green-400 ml-2">• @availableSlots slots available</span>
                }
                @if (isFull && isUpcoming)
                {
                    <span class="text-red-400 ml-2">• Event is full</span>
                }
                @if (isCompleted)
                {
                    <span class="text-gray-400 ml-2">• This event has ended</span>
                }
                @if (isCancelled)
                {
                    <span class="text-red-400 ml-2">• This event has been cancelled</span>
                }
            </p>
        </div>
        
        <div class="flex gap-3">
            <button onclick="openEditModal(@Model.Id)" class="primary-btn px-6 py-3 rounded-xl text-white font-bold bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all flex items-center gap-2">
                <i class="fa-solid fa-pen"></i> Edit Event
            </button>
            <button onclick="deleteEvent(@Model.Id, '@Model.EventTitle.Replace("'", "\\'")')" class="px-6 py-3 rounded-xl text-white font-bold bg-red-500/20 border border-red-500/50 hover:bg-red-500 hover:border-red-500 transition-all flex items-center gap-2">
                <i class="fa-solid fa-trash"></i> Delete
            </button>
        </div>
    </div>

    @if (isCompleted)
    {
        <div class="flex justify-end mt-4">
            <button onclick="openFeedbackModal()" class="primary-btn px-6 py-3 rounded-xl text-white font-bold bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all flex items-center gap-2">
                <i class="fa-solid fa-comment"></i> View Feedback
            </button>
        </div>
    }
</div>

<div id="feedbackModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeFeedbackModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-lg overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                    <i class="fa-solid fa-comment text-white text-sm"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Event Feedback</h2>
            </div>
            <button onclick="closeFeedbackModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <div class="p-6">
            <p class="text-gray-300">Feedback list will be displayed here.</p>
        </div>

        <div class="px-6 py-4 border-t border-gray-800 shrink-0 flex justify-end bg-[#0B1325]">
            <button onclick="closeFeedbackModal()" class="px-5 py-2 rounded-lg text-sm font-medium text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all">
                Close
            </button>
        </div>
    </div>
</div>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
    .primary-btn {
        background: linear-gradient(to right, #f97316, #9333ea);
    }
    .primary-btn:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
    .min-h-\[350px\] {
        min-height: 350px;
    }
    .max-h-\[500px\] {
        max-height: 500px;
    }
    .truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .break-all {
        word-break: break-all;
    }
</style>

<script>
    document.getElementById('statusDropdown')?.addEventListener('change', async function() {
        const newStatus = this.value;
        const eventId = @Model.Id;
        
        try {
            const response = await fetch('/Event/UpdateStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: eventId, status: newStatus })
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('Status updated successfully!', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                showToast('Error: ' + result.message, 'error');
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Error updating status', 'error');
        }
    });

    function openFeedbackModal() {
        const modal = document.getElementById('feedbackModal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeFeedbackModal() {
        const modal = document.getElementById('feedbackModal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.body.style.overflow = 'auto';
    }

    function openEditModal(id) {
        window.location.href = '/Event/Edit/' + id;
    }

    function deleteEvent(id, title) {
        if (!confirm(`Are you sure you want to delete "${title}"? This action cannot be undone.`)) {
            return;
        }
        
        fetch('/Event/DeleteEvent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id })
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                showToast('Event deleted successfully', 'success');
                setTimeout(() => window.location.href = '/Event/Index', 1500);
            } else {
                showToast('Error: ' + result.message, 'error');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showToast('Error deleting event', 'error');
        });
    }

    function showToast(message, type) {
        const existingToast = document.querySelector('.toast-message');
        if (existingToast) existingToast.remove();
        
        const toast = document.createElement('div');
        toast.className = `toast-message fixed top-24 right-4 z-50 ${type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90'} text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3`;
        toast.innerHTML = `
            <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
            <span>${message}</span>
            <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        `;
        document.body.appendChild(toast);
        
        setTimeout(() => {
            if (toast) toast.remove();
        }, 3000);
    }
</script>