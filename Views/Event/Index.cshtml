<style>
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .primary-btn {
        background: linear-gradient(to right, #f97316, #9333ea);
    }
    .primary-btn:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    .animate-spin {
        animation: spin 1s linear infinite;
    }
</style>

<script>
    setTimeout(function() {
        const successMsg = document.getElementById('successMessage');
        const errorMsg = document.getElementById('errorMessage');
        if (successMsg) successMsg.remove();
        if (errorMsg) errorMsg.remove();
    }, 3000);

    let currentStep = 1;
    const totalSteps = 3;

    function filterAndSortEvents() {
        const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
        const trailFilter = document.getElementById('trailFilter')?.value || 'All';
        const difficultyFilter = document.getElementById('difficultyFilter')?.value || 'All';
        const statusFilter = document.getElementById('statusFilter')?.value || 'All';
        const sortFilter = document.getElementById('sortFilter')?.value || 'date_asc';
        
        const trailGroups = document.querySelectorAll('.trail-group');
        let totalVisibleTrails = 0;
        
        trailGroups.forEach(group => {
            const trailId = group.getAttribute('data-trail-id') || '';
            const trailName = group.getAttribute('data-trail-name') || '';
            const trailLocation = group.getAttribute('data-trail-location') || '';
            
            const trailMatchesSearch = trailName.includes(searchTerm) || trailLocation.includes(searchTerm);
            const matchesTrailFilter = trailFilter === 'All' || trailId === trailFilter;
            
            const eventCards = group.querySelectorAll('.event-card');
            let visibleEvents = [];
            
            eventCards.forEach(card => {
                const eventTitle = card.getAttribute('data-event-title') || '';
                const eventLocation = card.getAttribute('data-event-location') || '';
                const eventStatus = card.getAttribute('data-event-status') || '';
                const eventDifficulty = card.getAttribute('data-event-difficulty') || '';
                const eventDate = card.getAttribute('data-event-date') || '';
                
                const matchesSearch = trailMatchesSearch || eventTitle.includes(searchTerm) || eventLocation.includes(searchTerm);
                const matchesDifficulty = difficultyFilter === 'All' || eventDifficulty === difficultyFilter;
                const matchesStatus = statusFilter === 'All' || eventStatus === statusFilter;
                
                if (matchesSearch && matchesTrailFilter && matchesDifficulty && matchesStatus) {
                    visibleEvents.push(card);
                } else {
                    card.classList.add('hidden');
                }
            });
            
            visibleEvents.forEach(card => card.classList.remove('hidden'));
            
            visibleEvents.sort((a, b) => {
                if (sortFilter === 'date_asc') {
                    return new Date(a.getAttribute('data-event-date')) - new Date(b.getAttribute('data-event-date'));
                } else if (sortFilter === 'date_desc') {
                    return new Date(b.getAttribute('data-event-date')) - new Date(a.getAttribute('data-event-date'));
                } else if (sortFilter === 'title_asc') {
                    return (a.getAttribute('data-event-title') || '').localeCompare(b.getAttribute('data-event-title') || '');
                } else if (sortFilter === 'title_desc') {
                    return (b.getAttribute('data-event-title') || '').localeCompare(a.getAttribute('data-event-title') || '');
                }
                return 0;
            });
            
            const container = group.querySelector('.events-grid');
            if (container && visibleEvents.length > 0 && matchesTrailFilter) {
                visibleEvents.forEach(card => container.appendChild(card));
                group.classList.remove('hidden');
                const eventCountSpan = group.querySelector('.event-count');
                if (eventCountSpan) eventCountSpan.textContent = visibleEvents.length;
                totalVisibleTrails++;
            } else {
                group.classList.add('hidden');
            }
        });
        
        const totalTrailsSpan = document.getElementById('totalTrailsCount');
        if (totalTrailsSpan) totalTrailsSpan.textContent = totalVisibleTrails;
        
        const noResultsDiv = document.getElementById('noResultsMessage');
        if (totalVisibleTrails === 0) {
            if (!noResultsDiv) {
                const container = document.getElementById('eventsContainer');
                const noResult = document.createElement('div');
                noResult.id = 'noResultsMessage';
                noResult.className = 'text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl';
                noResult.innerHTML = `
                    <i class="fa-solid fa-calendar-times text-5xl text-gray-500 mb-4"></i>
                    <h3 class="text-xl font-bold text-gray-300">No events found</h3>
                    <p class="text-gray-500 mt-2">Try adjusting your search or filter criteria.</p>
                `;
                container.appendChild(noResult);
            }
        } else {
            if (noResultsDiv) noResultsDiv.remove();
        }
    }
    
    document.getElementById('searchInput')?.addEventListener('input', filterAndSortEvents);
    document.getElementById('trailFilter')?.addEventListener('change', filterAndSortEvents);
    document.getElementById('difficultyFilter')?.addEventListener('change', filterAndSortEvents);
    document.getElementById('statusFilter')?.addEventListener('change', filterAndSortEvents);
    document.getElementById('sortFilter')?.addEventListener('change', filterAndSortEvents);

    function validateStep(step) {
        if (step === 1) {
            const trailId = document.getElementById('eventTrailId')?.value;
            const duration = document.getElementById('eventDuration')?.value;
            const capacity = document.getElementById('eventCapacity')?.value;
            
            if (!trailId) {
                showToast('Please select a trail', 'error');
                return false;
            }
            if (!duration || duration <= 0) {
                showToast('Please enter estimated duration', 'error');
                return false;
            }
            if (!capacity || capacity <= 0) {
                showToast('Please enter valid capacity', 'error');
                return false;
            }
            return true;
        }
        
        if (step === 2) {
            const pickupPoints = document.getElementById('eventPickupPoints')?.value;
            const eventDate = document.getElementById('eventDate')?.value;
            const eventTime = document.getElementById('eventTime')?.value;
            
            if (!pickupPoints) {
                showToast('Please enter pickup points', 'error');
                return false;
            }
            if (!eventDate) {
                showToast('Please select event date', 'error');
                return false;
            }
            if (!eventTime) {
                showToast('Please select event time', 'error');
                return false;
            }
            return true;
        }
        
        if (step === 3) {
            const title = document.getElementById('eventTitle')?.value;
            const organizer = document.getElementById('eventOrganizer')?.value;
            const description = document.getElementById('eventDescription')?.value;
            
            if (!title) {
                showToast('Please enter event title', 'error');
                return false;
            }
            if (!organizer) {
                showToast('Please select an organizer', 'error');
                return false;
            }
            if (!description) {
                showToast('Please enter event description', 'error');
                return false;
            }
            return true;
        }
        
        return true;
    }

    function updateStepUI() {
        for (let i = 1; i <= totalSteps; i++) {
            const content = document.getElementById(`step${i}`);
            const circles = document.querySelectorAll('.step-circle');
            const lines = document.querySelectorAll('.step-line');
            
            if (content) {
                if (i === currentStep) {
                    content.classList.remove('hidden');
                    if (circles[i-1]) {
                        circles[i-1].classList.remove('bg-gray-700');
                        circles[i-1].classList.add('bg-orange-500');
                    }
                    if (lines[i-1] && i < totalSteps) {
                        lines[i-1].classList.remove('bg-gray-700');
                        lines[i-1].classList.add('bg-orange-500');
                    }
                } else {
                    content.classList.add('hidden');
                    if (circles[i-1] && i < currentStep) {
                        circles[i-1].classList.remove('bg-gray-700', 'bg-orange-500');
                        circles[i-1].classList.add('bg-green-500');
                    } else if (circles[i-1] && i > currentStep) {
                        circles[i-1].classList.remove('bg-orange-500', 'bg-green-500');
                        circles[i-1].classList.add('bg-gray-700');
                    }
                    if (lines[i-1] && i < currentStep && i < totalSteps) {
                        lines[i-1].classList.remove('bg-gray-700');
                        lines[i-1].classList.add('bg-green-500');
                    } else if (lines[i-1] && i >= currentStep && i < totalSteps) {
                        lines[i-1].classList.remove('bg-orange-500', 'bg-green-500');
                        lines[i-1].classList.add('bg-gray-700');
                    }
                }
            }
        }
        
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        
        if (currentStep === 1) {
            prevBtn.classList.add('hidden');
        } else {
            prevBtn.classList.remove('hidden');
        }
        
        if (currentStep === totalSteps) {
            nextBtn.classList.add('hidden');
            submitBtn.classList.remove('hidden');
        } else {
            nextBtn.classList.remove('hidden');
            submitBtn.classList.add('hidden');
        }
    }

    document.getElementById('nextBtn')?.addEventListener('click', () => {
        if (validateStep(currentStep)) {
            if (currentStep < totalSteps) {
                currentStep++;
                updateStepUI();
            }
        }
    });

    document.getElementById('prevBtn')?.addEventListener('click', () => {
        if (currentStep > 1) {
            currentStep--;
            updateStepUI();
        }
    });

    async function fetchWeatherForecast(trailId, eventDate) {
        if (!trailId || !eventDate) return;
        
        const weatherTextarea = document.getElementById('eventWeather');
        const loadingSpinner = document.getElementById('weatherLoadingSpinner');
        
        if (!weatherTextarea) return;
        
        weatherTextarea.classList.add('opacity-50');
        if (loadingSpinner) loadingSpinner.classList.remove('hidden');
        
        try {
            const response = await fetch(`/Event/GetWeatherForecast?trailId=${trailId}&eventDate=${eventDate}`);
            const data = await response.json();
            
            if (data.success && data.forecast) {
                weatherTextarea.value = data.forecast;
            } else {
                weatherTextarea.value = 'Weather forecast temporarily unavailable. Please check manually.';
            }
        } catch (error) {
            console.error('Error fetching weather:', error);
            weatherTextarea.value = 'Error loading weather forecast. Please check manually.';
        } finally {
            weatherTextarea.classList.remove('opacity-50');
            if (loadingSpinner) loadingSpinner.classList.add('hidden');
        }
    }

    document.getElementById('eventTrailId')?.addEventListener('change', async function() {
        const trailId = this.value;
        if (!trailId) return;
        
        try {
            const response = await fetch(`/Event/GetTrailDetails?trailId=${trailId}`);
            const data = await response.json();
            
            if (data.success) {
                document.getElementById('previewDifficulty').textContent = 'Calculating...';
                document.getElementById('previewDistance').textContent = data.distance + ' km';
                document.getElementById('previewElevation').textContent = data.masl + ' m';
                document.getElementById('previewLocation').textContent = data.location;
                document.getElementById('previewTerrain').textContent = data.terrain;
                document.getElementById('previewMASL').textContent = data.masl + ' m';
                
                const duration = document.getElementById('eventDuration').value;
                if (duration) {
                    const diffResponse = await fetch(`/Event/GetCalculatedDifficulty?trailId=${trailId}&duration=${duration}`);
                    const diffData = await diffResponse.json();
                    if (diffData.success) {
                        document.getElementById('previewDifficulty').textContent = diffData.difficulty;
                    }
                }
                
                const eventDate = document.getElementById('eventDate')?.value;
                if (eventDate) {
                    await fetchWeatherForecast(trailId, eventDate);
                }
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });

    document.getElementById('eventDuration')?.addEventListener('change', async function() {
        const trailId = document.getElementById('eventTrailId').value;
        const duration = this.value;
        if (!trailId || !duration) return;
        
        try {
            const response = await fetch(`/Event/GetCalculatedDifficulty?trailId=${trailId}&duration=${duration}`);
            const data = await response.json();
            if (data.success) {
                document.getElementById('previewDifficulty').textContent = data.difficulty;
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });

    document.getElementById('eventDate')?.addEventListener('change', async function() {
        const trailId = document.getElementById('eventTrailId')?.value;
        const eventDate = this.value;
        
        if (trailId && eventDate) {
            await fetchWeatherForecast(trailId, eventDate);
        }
    });

    document.getElementById('addEventForm')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const eventData = {
            EventTitle: document.getElementById('eventTitle')?.value,
            Description: document.getElementById('eventDescription')?.value,
            EventDate: document.getElementById('eventDate')?.value,
            EventTime: document.getElementById('eventTime')?.value,
            TrailId: parseInt(document.getElementById('eventTrailId')?.value),
            EstimatedDuration: parseFloat(document.getElementById('eventDuration')?.value),
            Capacity: parseInt(document.getElementById('eventCapacity')?.value),
            OrganizedBy: document.getElementById('eventOrganizer')?.value,
            WeatherForecastAdvisory: document.getElementById('eventWeather')?.value,
            Announcements: document.getElementById('eventAnnouncements')?.value,
            PaymentDetails: document.getElementById('eventPaymentDetails')?.value,
            PickupPoints: document.getElementById('eventPickupPoints')?.value
        };
        
        const submitBtn = document.getElementById('submitBtn');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';
        
        try {
            const response = await fetch('/Event/AddEvent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('Event added successfully!', 'success');
                closeAddEventModal();
                setTimeout(() => location.reload(), 1500);
            } else {
                showToast('Error: ' + result.message, 'error');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Add Event';
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Error adding event', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Add Event';
        }
    });

    function openAddEventModal() {
        const modal = document.getElementById('addEventModal');
        if (modal) {
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            currentStep = 1;
            updateStepUI();
            const scrollContainer = document.querySelector('#addEventModal .overflow-y-auto');
            if (scrollContainer) {
                scrollContainer.scrollTop = 0;
            }
        }
    }

    function closeAddEventModal() {
        const modal = document.getElementById('addEventModal');
        if (modal) {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            const form = document.getElementById('addEventForm');
            if (form) form.reset();
            
            const scrollContainer = document.querySelector('#addEventModal .overflow-y-auto');
            if (scrollContainer) {
                scrollContainer.scrollTop = 0;
            }
            
            document.getElementById('previewDifficulty').textContent = '-';
            document.getElementById('previewDistance').textContent = '-';
            document.getElementById('previewElevation').textContent = '-';
            document.getElementById('previewLocation').textContent = '-';
            document.getElementById('previewTerrain').textContent = '-';
            document.getElementById('previewMASL').textContent = '-';
        }
    }

    let editCurrentStep = 1;
    const editTotalSteps = 3;

    function editUpdateStepUI() {
        for (let i = 1; i <= editTotalSteps; i++) {
            const content = document.getElementById(`editStep${i}`);
            const circles = document.querySelectorAll('.step-circle-edit');
            const lines = document.querySelectorAll('.step-line-edit');
            
            if (content) {
                if (i === editCurrentStep) {
                    content.classList.remove('hidden');
                    if (circles[i-1]) {
                        circles[i-1].classList.remove('bg-gray-700');
                        circles[i-1].classList.add('bg-orange-500');
                    }
                    if (lines[i-1] && i < editTotalSteps) {
                        lines[i-1].classList.remove('bg-gray-700');
                        lines[i-1].classList.add('bg-orange-500');
                    }
                } else {
                    content.classList.add('hidden');
                    if (circles[i-1] && i < editCurrentStep) {
                        circles[i-1].classList.remove('bg-gray-700', 'bg-orange-500');
                        circles[i-1].classList.add('bg-green-500');
                    } else if (circles[i-1] && i > editCurrentStep) {
                        circles[i-1].classList.remove('bg-orange-500', 'bg-green-500');
                        circles[i-1].classList.add('bg-gray-700');
                    }
                    if (lines[i-1] && i < editCurrentStep && i < editTotalSteps) {
                        lines[i-1].classList.remove('bg-gray-700');
                        lines[i-1].classList.add('bg-green-500');
                    } else if (lines[i-1] && i >= editCurrentStep && i < editTotalSteps) {
                        lines[i-1].classList.remove('bg-orange-500', 'bg-green-500');
                        lines[i-1].classList.add('bg-gray-700');
                    }
                }
            }
        }
        
        const prevBtn = document.getElementById('editPrevBtn');
        const nextBtn = document.getElementById('editNextBtn');
        const submitBtn = document.getElementById('editSubmitBtn');
        
        if (editCurrentStep === 1) {
            prevBtn.classList.add('hidden');
        } else {
            prevBtn.classList.remove('hidden');
        }
        
        if (editCurrentStep === editTotalSteps) {
            nextBtn.classList.add('hidden');
            submitBtn.classList.remove('hidden');
        } else {
            nextBtn.classList.remove('hidden');
            submitBtn.classList.add('hidden');
        }
    }

    document.getElementById('editNextBtn')?.addEventListener('click', () => {
        if (editValidateStep(editCurrentStep)) {
            if (editCurrentStep < editTotalSteps) {
                editCurrentStep++;
                editUpdateStepUI();
            }
        }
    });

    document.getElementById('editPrevBtn')?.addEventListener('click', () => {
        if (editCurrentStep > 1) {
            editCurrentStep--;
            editUpdateStepUI();
        }
    });

    function editValidateStep(step) {
        if (step === 1) {
            const trailId = document.getElementById('editEventTrailId')?.value;
            const duration = document.getElementById('editEventDuration')?.value;
            const capacity = document.getElementById('editEventCapacity')?.value;
            
            if (!trailId) {
                showToast('Please select a trail', 'error');
                return false;
            }
            if (!duration || duration <= 0) {
                showToast('Please enter estimated duration', 'error');
                return false;
            }
            if (!capacity || capacity <= 0) {
                showToast('Please enter valid capacity', 'error');
                return false;
            }
            return true;
        }
        
        if (step === 2) {
            const pickupPoints = document.getElementById('editEventPickupPoints')?.value;
            const eventDate = document.getElementById('editEventDate')?.value;
            const eventTime = document.getElementById('editEventTime')?.value;
            
            if (!pickupPoints) {
                showToast('Please enter pickup points', 'error');
                return false;
            }
            if (!eventDate) {
                showToast('Please select event date', 'error');
                return false;
            }
            if (!eventTime) {
                showToast('Please select event time', 'error');
                return false;
            }
            return true;
        }
        
        if (step === 3) {
            const title = document.getElementById('editEventTitle')?.value;
            const description = document.getElementById('editEventDescription')?.value;
            
            if (!title) {
                showToast('Please enter event title', 'error');
                return false;
            }
            if (!description) {
                showToast('Please enter event description', 'error');
                return false;
            }
            return true;
        }
        
        return true;
    }

    async function editFetchWeatherForecast(trailId, eventDate) {
        if (!trailId || !eventDate) return;
        
        const weatherTextarea = document.getElementById('editEventWeather');
        const loadingSpinner = document.getElementById('editWeatherLoadingSpinner');
        
        if (!weatherTextarea) return;
        
        weatherTextarea.classList.add('opacity-50');
        if (loadingSpinner) loadingSpinner.classList.remove('hidden');
        
        try {
            const response = await fetch(`/Event/GetWeatherForecast?trailId=${trailId}&eventDate=${eventDate}`);
            const data = await response.json();
            
            if (data.success && data.forecast) {
                weatherTextarea.value = data.forecast;
            } else {
                weatherTextarea.value = 'Weather forecast temporarily unavailable. Please check manually.';
            }
        } catch (error) {
            console.error('Error fetching weather:', error);
            weatherTextarea.value = 'Error loading weather forecast. Please check manually.';
        } finally {
            weatherTextarea.classList.remove('opacity-50');
            if (loadingSpinner) loadingSpinner.classList.add('hidden');
        }
    }

    document.getElementById('editEventTrailId')?.addEventListener('change', async function() {
        const trailId = this.value;
        if (!trailId) return;
        
        try {
            const response = await fetch(`/Event/GetTrailDetails?trailId=${trailId}`);
            const data = await response.json();
            
            if (data.success) {
                document.getElementById('editPreviewDifficulty').textContent = 'Calculating...';
                document.getElementById('editPreviewDistance').textContent = data.distance + ' km';
                document.getElementById('editPreviewElevation').textContent = data.masl + ' m';
                document.getElementById('editPreviewLocation').textContent = data.location;
                document.getElementById('editPreviewTerrain').textContent = data.terrain;
                document.getElementById('editPreviewMASL').textContent = data.masl + ' m';
                
                const duration = document.getElementById('editEventDuration').value;
                if (duration) {
                    const diffResponse = await fetch(`/Event/GetCalculatedDifficulty?trailId=${trailId}&duration=${duration}`);
                    const diffData = await diffResponse.json();
                    if (diffData.success) {
                        document.getElementById('editPreviewDifficulty').textContent = diffData.difficulty;
                    }
                }
                
                const eventDate = document.getElementById('editEventDate')?.value;
                if (eventDate) {
                    await editFetchWeatherForecast(trailId, eventDate);
                }
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });

    document.getElementById('editEventDuration')?.addEventListener('change', async function() {
        const trailId = document.getElementById('editEventTrailId').value;
        const duration = this.value;
        if (!trailId || !duration) return;
        
        try {
            const response = await fetch(`/Event/GetCalculatedDifficulty?trailId=${trailId}&duration=${duration}`);
            const data = await response.json();
            if (data.success) {
                document.getElementById('editPreviewDifficulty').textContent = data.difficulty;
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });

    document.getElementById('editEventDate')?.addEventListener('change', async function() {
        const trailId = document.getElementById('editEventTrailId')?.value;
        const eventDate = this.value;
        
        if (trailId && eventDate) {
            await editFetchWeatherForecast(trailId, eventDate);
        }
    });

    async function openEditModal(id) {
        try {
            const response = await fetch(`/Event/GetEvent?id=${id}`);
            const event = await response.json();
            
            if (!event.success) {
                showToast('Error loading event data', 'error');
                return;
            }
            
            document.getElementById('editEventId').value = event.id;
            document.getElementById('editEventTitle').value = event.eventTitle;
            document.getElementById('editEventDescription').value = event.description;
            document.getElementById('editEventDate').value = event.eventDate;
            document.getElementById('editEventTime').value = event.eventTime;
            document.getElementById('editEventTrailId').value = event.trailId;
            document.getElementById('editEventDuration').value = event.estimatedDuration;
            document.getElementById('editEventCapacity').value = event.capacity;
            const organizerSelect = document.getElementById('editEventOrganizer');
            if (organizerSelect) {
                let optionFound = false;
                for (let i = 0; i < organizerSelect.options.length; i++) {
                    if (organizerSelect.options[i].value === event.organizedBy) {
                        organizerSelect.selectedIndex = i;
                        optionFound = true;
                        break;
                    }
                }
                if (!optionFound && event.organizedBy) {
                    const newOption = document.createElement('option');
                    newOption.value = event.organizedBy;
                    newOption.textContent = event.organizedBy;
                    organizerSelect.appendChild(newOption);
                    organizerSelect.value = event.organizedBy;
                }
            }
            document.getElementById('editEventWeather').value = event.weatherForecastAdvisory || '';
            document.getElementById('editEventAnnouncements').value = event.announcements || '';
            document.getElementById('editEventPaymentDetails').value = event.paymentDetails || '';
            document.getElementById('editEventPickupPoints').value = event.pickupPoints || '';
            document.getElementById('editEventStatus').value = event.status || 'Upcoming';
            
            const trailSelect = document.getElementById('editEventTrailId');
            const changeEvent = new Event('change');
            trailSelect.dispatchEvent(changeEvent);
            
            editCurrentStep = 1;
            editUpdateStepUI();
            
            const modal = document.getElementById('editEventModal');
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
            
            const scrollContainer = document.querySelector('#editEventModal .overflow-y-auto');
            if (scrollContainer) {
                scrollContainer.scrollTop = 0;
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Error loading event data', 'error');
        }
    }

    function closeEditEventModal() {
        const modal = document.getElementById('editEventModal');
        if (modal) {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
            const form = document.getElementById('editEventForm');
            if (form) form.reset();
        }
    }

    document.getElementById('editEventForm')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const eventData = {
            Id: parseInt(document.getElementById('editEventId')?.value),
            EventTitle: document.getElementById('editEventTitle')?.value,
            Description: document.getElementById('editEventDescription')?.value,
            EventDate: document.getElementById('editEventDate')?.value,
            EventTime: document.getElementById('editEventTime')?.value,
            TrailId: parseInt(document.getElementById('editEventTrailId')?.value),
            EstimatedDuration: parseFloat(document.getElementById('editEventDuration')?.value),
            Capacity: parseInt(document.getElementById('editEventCapacity')?.value),
            OrganizedBy: document.getElementById('editEventOrganizer')?.value,
            WeatherForecastAdvisory: document.getElementById('editEventWeather')?.value,
            Announcements: document.getElementById('editEventAnnouncements')?.value,
            PaymentDetails: document.getElementById('editEventPaymentDetails')?.value,
            PickupPoints: document.getElementById('editEventPickupPoints')?.value,
            Status: document.getElementById('editEventStatus')?.value
        };
        
        const submitBtn = document.getElementById('editSubmitBtn');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Saving...';
        
        try {
            const response = await fetch('/Event/EditEvent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(eventData)
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('Event updated successfully!', 'success');
                closeEditEventModal();
                setTimeout(() => location.reload(), 1500);
            } else {
                showToast('Error: ' + result.message, 'error');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Save Changes';
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Error updating event', 'error');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Save Changes';
        }
    });

    async function deleteEvent(id, title) {
        if (!confirm(`Are you sure you want to delete "${title}"? This action cannot be undone.`)) {
            return;
        }
        
        try {
            const response = await fetch('/Event/DeleteEvent', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ id: id })
            });
            
            const result = await response.json();
            
            if (result.success) {
                showToast('Event deleted successfully', 'success');
                setTimeout(() => {
                    location.reload();
                }, 1500);
            } else {
                showToast('Error deleting event: ' + result.message, 'error');
            }
        } catch (error) {
            console.error('Error:', error);
            showToast('Error deleting event', 'error');
        }
    }

    function showToast(message, type) {
        const existingToast = document.querySelector('.toast-message');
        if (existingToast) existingToast.remove();
        
        const toast = document.createElement('div');
        toast.className = `toast-message fixed top-24 right-4 z-50 ${type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90'} text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3`;
        toast.innerHTML = `
            <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
            <span>${message}</span>
            <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                <i class="fa-solid fa-xmark text-lg"></i>
            </button>
        `;
        document.body.appendChild(toast);
        
        setTimeout(() => {
            if (toast) toast.remove();
        }, 3000);
    }
</script>