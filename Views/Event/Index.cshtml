@model IEnumerable<TrailGuard.Models.EventGroupViewModel>
@{
    ViewData["Title"] = "Event Management";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@section PageHero {
    <div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Event Management</h1>
                <p class="text-gray-400 mt-1 text-sm">Manage hiking events grouped by trail.</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <div class="bg-white/5 border border-white/10 px-4 py-2.5 rounded-full flex items-center gap-2 backdrop-blur-sm shadow-lg">
                    <i class="fa-solid fa-calendar text-gray-400"></i>
                    <span class="text-sm font-medium text-gray-300">Total Trails with Events: <strong class="text-white" id="totalTrailsCount">@Model.Count()</strong></span>
                </div>
                
                <button onclick="openAddEventModal()" class="primary-btn group inline-flex items-center justify-center gap-2 px-7 py-3 text-sm rounded-full bg-linear-to-r from-orange-500 to-purple-600 text-white font-bold shadow-lg shadow-purple-500/30 hover:scale-105 hover:opacity-90 transform transition duration-300 ease-out">
                    <span>Add Event</span>
                    <i class="fa-solid fa-plus transition-transform duration-300 group-hover:translate-x-1"></i>
                </button>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-gray-800 shadow-2xl">
        <div class="relative grow">
            <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
            <input type="text" id="searchInput" placeholder="Search events by title or location..." 
                class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none transition-colors placeholder-gray-500">
        </div>

        <div class="flex flex-wrap sm:flex-nowrap gap-3">
            <div class="relative inline-block">
                <select id="trailFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white py-2">All Trails</option>
                    @{
                        var distinctTrails = ViewBag.Trails as List<TrailGuard.Models.Trail>;
                        if (distinctTrails != null)
                        {
                            foreach (var trail in distinctTrails)
                            {
                                <option value="@trail.Id" class="bg-[#0b1329] text-white py-2">@trail.Name</option>
                            }
                        }
                    }
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="difficultyFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white py-2">All Difficulties</option>
                    <option value="Easy" class="bg-[#0b1329] text-white py-2">Easy</option>
                    <option value="Moderate" class="bg-[#0b1329] text-white py-2">Moderate</option>
                    <option value="Difficult" class="bg-[#0b1329] text-white py-2">Difficult</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="statusFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="All" class="bg-[#0b1329] text-white py-2">All Status</option>
                    <option value="Upcoming" class="bg-[#0b1329] text-white py-2">Upcoming</option>
                    <option value="Cancelled" class="bg-[#0b1329] text-white py-2">Cancelled</option>
                    <option value="Postponed" class="bg-[#0b1329] text-white py-2">Postponed</option>
                    <option value="Completed" class="bg-[#0b1329] text-white py-2">Completed</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>

            <div class="relative inline-block">
                <select id="sortFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                    <option value="date_desc" class="bg-[#0b1329] text-white py-2">Sort by: Newest</option>
                    <option value="date_asc" class="bg-[#0b1329] text-white py-2">Sort by: Oldest</option>
                    <option value="title_asc" class="bg-[#0b1329] text-white py-2">Name (A-Z)</option>
                    <option value="title_desc" class="bg-[#0b1329] text-white py-2">Name (Z-A)</option>
                </select>
                <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                    <i class="fa-solid fa-chevron-down text-xs"></i>
                </div>
            </div>
        </div>
    </div>

        <div id="eventsContainer">
            @if (!Model.Any())
            {
                <div class="text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl">
                    <i class="fa-solid fa-calendar-plus text-5xl text-gray-500 mb-4"></i>
                    <h3 class="text-xl font-bold text-gray-300">No events found</h3>
                    <p class="text-gray-500 mt-2">Click "Add Event" to create your first hiking event.</p>
                </div>
            }
            else
            {
                @foreach (var group in Model)
                {
                    <div class="trail-group mb-10" data-trail-id="@group.TrailId" data-trail-name="@group.TrailName.ToLower()" data-trail-location="@group.TrailLocation.ToLower()">
                        <div class="flex items-center gap-3 mb-4 pb-3 border-b border-gray-700">
                            <div class="w-10 h-10 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                                <i class="fa-solid fa-mountain text-white text-sm"></i>
                            </div>
                            <div>
                                <h2 class="text-xl font-bold text-white trail-name">@group.TrailName</h2>
                                <p class="text-gray-400 text-sm"><i class="fa-solid fa-location-dot text-red-400 mr-1"></i> @group.TrailLocation</p>
                            </div>
                            <div class="ml-auto">
                                <span class="text-xs px-3 py-1 bg-white/10 rounded-full text-gray-300">
                                    <i class="fa-regular fa-calendar mr-1"></i> <span class="event-count">@group.Events.Count</span> event(s)
                                </span>
                            </div>
                        </div>

                        <div class="events-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                            @foreach (var eventItem in group.Events)
                            {
                                <div class="event-card bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-xl hover:bg-white/10 transition-all duration-300"
                                     data-event-title="@eventItem.EventTitle.ToLower()"
                                     data-event-location="@eventItem.Location.ToLower()"
                                     data-event-status="@eventItem.Status"
                                     data-event-difficulty="@eventItem.Difficulty"
                                     data-event-date="@eventItem.EventDate.ToString("yyyy-MM-dd")">
                                    
                                    <div class="relative h-40 overflow-hidden bg-gray-900">
                                        @if (!string.IsNullOrEmpty(eventItem.Trail?.ThumbnailUrl))
                                        {
                                            <img src="@eventItem.Trail.ThumbnailUrl" alt="@eventItem.Trail.Name" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center bg-gray-800">
                                                <i class="fa-solid fa-mountain text-4xl text-gray-600"></i>
                                            </div>
                                        }
                                        <div class="absolute inset-0 bg-linear-to-t from-[#0B1325] to-transparent opacity-80"></div>
                                       <div class="absolute top-3 right-3">
                                            <span class="text-xs px-2 py-1 rounded-full font-semibold 
                                                @(eventItem.Status == "Upcoming" ? "bg-green-600 text-white" : 
                                                eventItem.Status == "Cancelled" ? "bg-red-600 text-white" : 
                                                eventItem.Status == "Postponed" ? "bg-yellow-600 text-white" : 
                                                "bg-gray-600 text-white")">
                                                @eventItem.Status
                                            </span>
                                        </div>
                                        <div class="absolute bottom-3 left-3">
                                            <span class="text-xs text-white/80 bg-black/50 px-2 py-1 rounded-full">
                                                <i class="fa-regular fa-calendar mr-1"></i> @eventItem.EventDate.ToString("MMM dd, yyyy")
                                            </span>
                                        </div>
                                    </div>
                                    
                                    <div class="p-4">
                                        <div class="flex justify-between items-start mb-2">
                                            <h3 class="text-lg font-bold text-white">@eventItem.EventTitle</h3>
                                        </div>
                                        
                                        <div class="flex items-center gap-2 text-sm text-gray-400 mb-3">
                                            <i class="fa-solid fa-clock text-blue-400"></i>
                                            <span>@($"{eventItem.EventTime.Hours:D2}:{eventItem.EventTime.Minutes:D2} {(eventItem.EventTime.Hours >= 12 ? "PM" : "AM")}")</span>
                                            <span class="mx-1">•</span>
                                            <span class="text-xs px-2 py-1 bg-orange-500/20 text-orange-300 rounded-full">
                                                <i class="fa-solid fa-users"></i> 
                                                @(eventItem.Capacity - eventItem.RegisteredCount) / @eventItem.Capacity slots
                                            </span>
                                        </div>
                                        
                                        <div class="flex flex-wrap gap-2 mb-4">
                                            <span class="text-xs px-2 py-1 bg-purple-500/20 text-purple-300 rounded-full">
                                                <i class="fa-solid fa-signal"></i> @eventItem.Difficulty
                                            </span>
                                            <span class="text-xs px-2 py-1 bg-blue-500/20 text-blue-300 rounded-full">
                                                <i class="fa-regular fa-clock"></i> @eventItem.EstimatedDuration hrs
                                            </span>
                                        </div>

                                        <div class="flex gap-2">
                                            <a asp-controller="Event" asp-action="Details" asp-route-id="@eventItem.Id" 
                                               class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white py-2 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2">
                                                <i class="fa-regular fa-eye"></i> View
                                            </a>
                                            <button type="button" onclick="openEditModal(@eventItem.Id)" 
                                                    class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white py-2 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2">
                                                <i class="fa-solid fa-pen"></i> Edit
                                            </button>
                                            <button type="button" onclick="deleteEvent(@eventItem.Id, '@eventItem.EventTitle.Replace("'", "\\'")')" 
                                                    class="bg-red-500/20 hover:bg-red-500 border border-red-500/30 hover:border-red-500 text-red-400 hover:text-white py-2 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2 w-12">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

<div id="addEventModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeAddEventModal()"></div>
    <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-4xl max-h-[85vh] overflow-hidden flex flex-col" style="margin: auto; z-index: 10;">
        
        <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                    <i class="fa-solid fa-plus text-white text-sm"></i>
                </div>
                <h2 class="text-xl font-bold text-white">Add New Event</h2>
            </div>
            <button onclick="closeAddEventModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </button>
        </div>

        <div class="px-6 pt-4 shrink-0">
            <div class="flex items-center justify-between max-w-md mx-auto">
                <div class="step-indicator flex-1 text-center">
                    <div class="step-circle w-8 h-8 rounded-full bg-orange-500 text-white flex items-center justify-center mx-auto mb-1">1</div>
                    <span class="text-xs text-gray-400">Select Trail</span>
                </div>
                <div class="step-line flex-1 h-0.5 bg-gray-700 mx-2"></div>
                <div class="step-indicator flex-1 text-center">
                    <div class="step-circle w-8 h-8 rounded-full bg-gray-700 text-white flex items-center justify-center mx-auto mb-1">2</div>
                    <span class="text-xs text-gray-400">Pickup & Date</span>
                </div>
                <div class="step-line flex-1 h-0.5 bg-gray-700 mx-2"></div>
                <div class="step-indicator flex-1 text-center">
                    <div class="step-circle w-8 h-8 rounded-full bg-gray-700 text-white flex items-center justify-center mx-auto mb-1">3</div>
                    <span class="text-xs text-gray-400">Details</span>
                </div>
            </div>
        </div>

        <form id="addEventForm" class="flex flex-col flex-1 overflow-hidden">
            <div class="overflow-y-auto p-6 custom-scrollbar" style="flex: 1;">
                <!-- Step 1 -->
                <div id="step1" class="step-content">
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Select Trail <span class="text-red-400">*</span></label>
                        <select id="eventTrailId" name="TrailId" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none">
                            <option value="">-- Select a trail --</option>
                            @{
                                var trails = ViewBag.Trails as List<TrailGuard.Models.Trail>;
                                if (trails != null)
                                {
                                    foreach (var trail in trails)
                                    {
                                        <option value="@trail.Id">@trail.Name - @trail.Location</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">Difficulty</p>
                            <p id="previewDifficulty" class="text-white font-semibold">-</p>
                        </div>
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">Distance</p>
                            <p id="previewDistance" class="text-white font-semibold">-</p>
                        </div>
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">Elevation Gain</p>
                            <p id="previewElevation" class="text-white font-semibold">-</p>
                        </div>
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">Location</p>
                            <p id="previewLocation" class="text-white font-semibold">-</p>
                        </div>
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">Terrain Type</p>
                            <p id="previewTerrain" class="text-white font-semibold">-</p>
                        </div>
                        <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider">MASL</p>
                            <p id="previewMASL" class="text-white font-semibold">-</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Estimated Duration (Hours) <span class="text-red-400">*</span></label>
                            <input type="number" step="0.5" id="eventDuration" name="EstimatedDuration" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="e.g., 6">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Slots Available (Capacity) <span class="text-red-400">*</span></label>
                            <input type="number" id="eventCapacity" name="Capacity" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="e.g., 20">
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div id="step2" class="step-content hidden">
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Pickup Points <span class="text-red-400">*</span></label>
                        <textarea id="eventPickupPoints" name="PickupPoints" rows="3" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="Enter pickup points..."></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Event Date <span class="text-red-400">*</span></label>
                            <input type="date" id="eventDate" name="EventDate" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-300 mb-2">Event Time <span class="text-red-400">*</span></label>
                            <input type="time" id="eventTime" name="EventTime" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Weather Forecast Advisory</label>
                        <div class="relative">
                            <textarea id="eventWeather" name="WeatherForecastAdvisory" rows="6" readonly class="w-full bg-[#111A2E]/50 border border-gray-700 text-gray-300 rounded-lg px-4 py-2.5 focus:outline-none cursor-default" placeholder="Weather forecast will auto-fill when you select trail and date..."></textarea>
                            <div id="weatherLoadingSpinner" class="absolute inset-0 bg-[#111A2E]/80 rounded-lg items-center justify-center hidden">
                                <div class="flex flex-col items-center gap-2">
                                    <div class="w-8 h-8 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
                                    <span class="text-sm text-gray-300">Fetching weather forecast...</span>
                                </div>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Weather forecast auto-fills based on trail location and event date. Field is read-only.</p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div id="step3" class="step-content hidden">
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Event Title <span class="text-red-400">*</span></label>
                        <input type="text" id="eventTitle" name="EventTitle" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="e.g., Mount Pulag Sunrise Hike">
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Organizer <span class="text-red-400">*</span></label>
                        <select id="eventOrganizer" name="OrganizedBy" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none">
                            <option value="">-- Select organizer --</option>
                            @{
                                var organizers = ViewBag.Organizers as List<TrailGuard.Models.ApplicationUser>;
                                if (organizers != null)
                                {
                                    foreach (var org in organizers)
                                    {
                                        <option value="@org.Id">@org.FirstName @org.LastName - @org.Email</option>
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Payment Details</label>
                        <textarea id="eventPaymentDetails" name="PaymentDetails" rows="4" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="Enter registration fee, payment instructions, bank details, GCASH number, etc.&#10;&#10;Example:&#10;Registration Fee: ₱1,200&#10;Payment Methods: GCASH 0912xxxxxxx, BPI Account #xxxx"></textarea>
                        <p class="text-xs text-gray-500 mt-1">Include registration fee and payment instructions here.</p>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Event Description <span class="text-red-400">*</span></label>
                        <textarea id="eventDescription" name="Description" required rows="4" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="Provide a detailed description about the event..."></textarea>
                    </div>

                    <div class="mb-6">
                        <label class="block text-sm font-medium text-gray-300 mb-2">Notes & Announcements</label>
                        <textarea id="eventAnnouncements" name="Announcements" rows="3" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-orange-500 focus:outline-none" placeholder="Important reminders and things participants should know..."></textarea>
                    </div>
                </div>
            </div>

            <div class="px-6 py-4 border-t border-gray-800 shrink-0 flex justify-between gap-3 bg-[#0B1325]">
                <button type="button" id="prevBtn" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white bg-gray-800 hover:bg-gray-700 transition-colors hidden">
                    ← Back
                </button>
                <div class="flex-1"></div>
                <button type="button" id="nextBtn" class="primary-btn px-5 py-2 rounded-lg text-sm font-medium text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all">
                    Next →
                </button>
                <button type="submit" id="submitBtn" class="primary-btn px-5 py-2 rounded-lg text-sm font-medium text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all hidden">
                    Add Event
                </button>
                <button type="button" onclick="closeAddEventModal()" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white bg-gray-800 hover:bg-gray-700 transition-colors">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Event Modal -->
<div id="editEventModal" class="fixed inset-0 z-100 hidden items-center justify-center p-4" style="padding-top: 80px;">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="closeEditEventModal()"></div>
