@using Microsoft.AspNetCore.Identity
@using TrailGuard.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<nav class="fixed top-0 left-0 w-full z-50 px-4 py-4">
    <div class="max-w-4xl mx-auto">

        <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />

        <div class="relative flex items-center justify-between w-full rounded-full border border-white/15 bg-[#060B1A]/55 backdrop-blur-md shadow-lg shadow-black/20 px-4 py-1 min-h-11.5">

            <a asp-controller="Home" asp-action="Index"
                class="flex items-center gap-2 text-white font-bold whitespace-nowrap">
                    <img src="~/images/logo.png"
                        asp-append-version="true"
                        alt="TrailGuard Logo"
                        class="h-8 w-auto" />

                <span class="text-md leading-none">
                    TrailGuard
                </span>
            </a>

            <div class="hidden lg:flex absolute left-1/2 -translate-x-1/2 items-center justify-center gap-1 whitespace-nowrap">
                <a asp-controller="Admin" asp-action="Index"
                   class="nav-link px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Admin" && currentAction == "Index" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Dashboard
                </a>

                <a asp-controller="Trail" asp-action="Index"
                   class="nav-link px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Trail" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Trails
                </a>

                <a asp-controller="Event" asp-action="Index"
                   class="nav-link px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Event" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Events
                </a>

                <a asp-controller="Admin" asp-action="Accounts"
                   class="nav-link px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentAction == "Accounts" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Accounts
                </a>

                <a asp-controller="Records" asp-action="Index"
                   class="nav-link px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Records" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Records
                </a>
            </div>

            <div class="hidden lg:flex items-center justify-end gap-3 whitespace-nowrap">
                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var mainRole = "Admin"; 

                    <div class="relative">
                        <button id="profileDropdownBtn" class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 hover:bg-white/15 focus:outline-none transition-all">
                            <div class="w-8 h-8 rounded-full bg-linear-to-r from-purple-600 to-orange-500 flex items-center justify-center text-white text-xs font-bold shadow-lg shadow-purple-500/30">
                                @(currentUser?.FirstName?.Substring(0, 1).ToUpper())
                            </div>
                            
                            <div class="text-left hidden sm:block">
                                <div class="text-xs text-center font-bold text-white leading-tight">@currentUser?.FirstName</div>
                                <div class="text-[9px] text-center pt-1 font-medium text-orange-400 uppercase tracking-wide leading-tight">@mainRole</div>
                            </div>
                            
                            <i class="fa-solid fa-chevron-down text-gray-400 text-xs"></i>
                        </button>
                        
                        <div id="profileDropdownMenu" class="hidden absolute right-0 mt-3 w-48 bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl p-1.5 z-50 transform origin-top-right transition-all">
                            <a asp-controller="Admin" asp-action="Index" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-800/60 rounded-xl transition-colors">
                                <i class="fa-solid fa-layer-group text-gray-400 text-base w-4 text-center"></i> Dashboard
                            </a>
                            <a href="#" class="flex items-center gap-3 px-3 py-2.5 text-sm font-medium text-gray-300 hover:text-white hover:bg-gray-800/60 rounded-xl transition-colors">
                                <i class="fa-solid fa-gear text-gray-400 text-base w-4 text-center"></i> Settings
                            </a>
                            
                            <div class="h-px bg-gray-800 my-1 mx-2"></div>
                            
                            <form asp-controller="Account" asp-action="Logout" method="post" class="block w-full m-0 p-0">
                                <button type="submit" class="flex items-center gap-3 w-full text-left px-3 py-2.5 text-sm font-medium text-red-500 hover:text-red-400 hover:bg-red-500/10 rounded-xl transition-colors">
                                    <i class="fa-solid fa-arrow-right-from-bracket text-base w-4 text-center"></i> Sign out
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <label for="mobile-menu-toggle"
                   class="lg:hidden ml-auto w-8 h-8 rounded-full text-white/80 hover:text-white hover:bg-white/10 transition flex items-center justify-center cursor-pointer">
                <i class="fa-solid fa-bars text-sm"></i>
            </label>
        </div>

        <div class="lg:hidden hidden peer-checked:block mt-3 rounded-3xl bg-[#060B1A]/80 backdrop-blur-md shadow-lg shadow-black/20 p-3">
            <div class="flex flex-col gap-1">
                <a asp-controller="Admin" asp-action="Index"
                   class="px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Admin" && currentAction == "Index" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Dashboard
                </a>

                <a asp-controller="Trail" asp-action="Index"
                   class="px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Trail" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Trails
                </a>

                <a asp-controller="Event" asp-action="Index"
                   class="px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Event" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Events
                </a>

                <a asp-controller="Admin" asp-action="Accounts"
                   class="px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentAction == "Accounts" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Accounts
                </a>

                <a asp-controller="Records" asp-action="Index"
                   class="px-4 py-2 rounded-2xl text-sm font-medium transition-all duration-200
                          @(currentController == "Records" ? "bg-white/10 text-white" : "text-white/80 hover:text-white hover:bg-white/10")">
                    Records
                </a>

                <div class="h-px bg-white/10 my-2"></div>

                @if (SignInManager.IsSignedIn(User))
                {
                    <a href="#" class="px-4 py-2 rounded-2xl text-sm text-gray-300 hover:text-white hover:bg-white/5 transition">
                        <i class="fa-solid fa-gear w-5 text-white-80 pr-5"></i> Settings
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="block w-full m-0 p-0">
                        <button type="submit" class="w-full text-left px-4 py-2 rounded-2xl text-sm text-red-400 hover:text-red-300 hover:bg-red-500/10 transition">
                            <i class="fa-solid fa-arrow-right-from-bracket w-5"></i> Log out
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const profileBtn = document.getElementById("profileDropdownBtn");
        const profileMenu = document.getElementById("profileDropdownMenu");

        if (profileBtn && profileMenu) {
            profileBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                profileMenu.classList.toggle("hidden");
            });

            document.addEventListener("click", function (e) {
                if (!profileBtn.contains(e.target) && !profileMenu.contains(e.target)) {
                    profileMenu.classList.add("hidden");
                }
            });
        }
    });
</script>