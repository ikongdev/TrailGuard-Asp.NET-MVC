@model IEnumerable<TrailGuard.Models.Trail>
@{
    ViewData["Title"] = "Trail Management";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@section PageHero {
    <div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Trail Management</h1>
                <p class="text-gray-400 mt-1 text-sm">Manage trail listings, review trail details, and keep your hiking catalog up to date.</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <div class="bg-white/5 border border-white/10 px-4 py-2.5 rounded-full flex items-center gap-2 backdrop-blur-sm shadow-lg">
                    <i class="fa-solid fa-mountain text-gray-400"></i>
                    <span class="text-sm font-medium text-gray-300">Total Trails: <strong class="text-white">@Model.Count()</strong></span>
                </div>
                
                <button onclick="openAddTrailModal()" class="group inline-flex items-center justify-center gap-2 px-7 py-3 text-sm rounded-full bg-linear-to-r from-orange-400 via-pink-500 to-violet-500 text-white font-bold shadow-lg shadow-violet-500/30 hover:scale-105 hover:opacity-90 transform transition duration-300 ease-out">
                    <span>Add Trail</span>
                    <i class="fa-solid fa-plus transition-transform duration-300 group-hover:translate-x-1"></i>
                </button>
            </div>
        </div>

        <form method="get" asp-action="Index" id="filterForm">
            <div class="flex flex-col lg:flex-row gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-white/10 shadow-2xl">
                
                <div class="relative grow">
                    <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                    <input type="text" name="searchString" id="searchInput" value="@ViewData["CurrentFilter"]" placeholder="Search trails by name or location..." 
                        class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 focus:outline-none transition-colors placeholder-gray-500">
                </div>

                <div class="flex flex-wrap sm:flex-nowrap gap-3">
                    <div class="relative inline-block">
                        <select id="sortOrder" name="sortOrder" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                            <option value="newest" selected="@(ViewData["CurrentSort"]?.ToString() == "newest")" class="bg-[#0b1329] text-white py-2">Sort by: Newest</option>
                            <option value="oldest" selected="@(ViewData["CurrentSort"]?.ToString() == "oldest")" class="bg-[#0b1329] text-white py-2">Sort by: Oldest</option>
                            <option value="name_asc" selected="@(ViewData["CurrentSort"]?.ToString() == "name_asc")" class="bg-[#0b1329] text-white py-2">Name (A-Z)</option>
                            <option value="name_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "name_desc")" class="bg-[#0b1329] text-white py-2">Name (Z-A)</option>
                            <option value="distance_asc" selected="@(ViewData["CurrentSort"]?.ToString() == "distance_asc")" class="bg-[#0b1329] text-white py-2">Distance (Low to High)</option>
                            <option value="distance_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "distance_desc")" class="bg-[#0b1329] text-white py-2">Distance (High to Low)</option>
                            <option value="elevation_asc" selected="@(ViewData["CurrentSort"]?.ToString() == "elevation_asc")" class="bg-[#0b1329] text-white py-2">Elevation (Low to High)</option>
                            <option value="elevation_desc" selected="@(ViewData["CurrentSort"]?.ToString() == "elevation_desc")" class="bg-[#0b1329] text-white py-2">Elevation (High to Low)</option>
                        </select>
                        <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                            <i class="fa-solid fa-chevron-down text-xs"></i>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @if (!Model.Any())
            {
                <div class="col-span-full text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl">
                    <i class="fa-solid fa-mountain text-5xl text-gray-500 mb-4"></i>
                    <h3 class="text-xl font-bold text-gray-300">No trails found</h3>
                    <p class="text-gray-500 mt-2">Try searching a different name or clearing the filters.</p>
                </div>
            }
            else
            {
                @foreach (var trail in Model)
                {
                    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl overflow-hidden shadow-2xl hover:bg-white/10 transition-all duration-300 group flex flex-col">
                        <div class="relative h-48 overflow-hidden bg-gray-900">
                            @if (!string.IsNullOrEmpty(trail.ThumbnailUrl))
                            {
                                <img src="@trail.ThumbnailUrl" alt="@trail.Name" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center">
                                    <i class="fa-solid fa-image text-4xl text-gray-600"></i>
                                </div>
                            }
                            <div class="absolute inset-0 bg-linear-to-t from-[#0B1325] to-transparent opacity-90"></div>
                        </div>
                        
                        <div class="p-6 flex flex-col grow relative z-10 -mt-10">
                            <h3 class="text-xl font-bold text-white mb-1">@trail.Name</h3>
                            <p class="text-gray-400 text-sm mb-5 flex items-center gap-1.5"><i class="fa-solid fa-location-dot text-red-400"></i> @trail.Location</p>
                            
                            <div class="grid grid-cols-3 gap-4 mb-6">
                                <div>
                                    <p class="text-gray-500 text-[11px] uppercase tracking-wider mb-0.5">Distance</p>
                                    <p class="text-gray-200 text-sm font-medium flex items-center gap-2"><i class="fa-solid fa-route text-gray-400"></i> @trail.DistanceKm km</p>
                                </div>
                                <div>
                                    <p class="text-gray-500 text-[11px] uppercase tracking-wider mb-0.5">Elev. Gain</p>
                                    <p class="text-gray-200 text-sm font-medium flex items-center gap-2"><i class="fa-solid fa-arrow-trend-up text-gray-400"></i> @trail.ElevationGainMeters m</p>
                                </div>
                                <div>
                                    <p class="text-gray-500 text-[11px] uppercase tracking-wider mb-0.5">Terrain</p>
                                    <p class="text-gray-200 text-sm font-medium flex items-center gap-2 truncate" title="@trail.Terrain"><i class="fa-solid fa-tree text-emerald-400"></i> @trail.Terrain</p>
                                </div>
                            </div>

                            <div class="flex gap-3 mt-auto">
                                <button type="button" onclick="openViewModal(this)"
                                        data-id="@trail.Id"
                                        data-name="@trail.Name"
                                        data-location="@trail.Location"
                                        data-distance="@trail.DistanceKm"
                                        data-elevation="@trail.ElevationGainMeters"
                                        data-terrain="@trail.Terrain"
                                        data-description="@trail.Description"
                                        data-image="@(string.IsNullOrEmpty(trail.ThumbnailUrl) ? "" : trail.ThumbnailUrl)"
                                        data-date-added="@trail.DateAdded.ToString("MMM dd, yyyy")"
                                        class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white py-2.5 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2">
                                    <i class="fa-regular fa-eye"></i> View
                                </button>
                                <button type="button" onclick="openEditModal(this)"
                                        data-id="@trail.Id"
                                        data-name="@trail.Name"
                                        data-location="@trail.Location"
                                        data-distance="@trail.DistanceKm"
                                        data-elevation="@trail.ElevationGainMeters"
                                        data-terrain="@trail.Terrain"
                                        data-description="@trail.Description"
                                        data-image="@(string.IsNullOrEmpty(trail.ThumbnailUrl) ? "" : trail.ThumbnailUrl)"
                                        class="flex-1 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-gray-300 hover:text-white py-2.5 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2">
                                    <i class="fa-solid fa-pen"></i> Edit
                                </button>
                                <button type="button" onclick="deleteTrail(@trail.Id, '@trail.Name')" 
                                        class="delete-trail-btn bg-red-500/20 hover:bg-red-500 border border-red-500/30 hover:border-red-500 text-red-400 hover:text-white py-2.5 rounded-xl text-sm font-semibold transition-all flex items-center justify-center gap-2 w-12">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@section Modals {
    <div id="viewTrailModal" class="fixed inset-0 z-100 modal-hidden" style="padding-top: 30px;">
        <div class="fixed inset-0 bg-black/70 backdrop-blur-sm" onclick="closeViewModal()"></div>
        <div class="relative bg-[#0B1325] border border-gray-800 rounded-2xl shadow-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden flex flex-col mx-auto my-auto" style="z-index: 10;">
            
            <div class="flex justify-between items-center px-6 py-4 border-b border-gray-800 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-linear-to-r from-blue-500 to-cyan-500 flex items-center justify-center">
                        <i class="fa-solid fa-mountain text-white text-sm"></i>
                    </div>
                    <h2 class="text-xl font-bold text-white">Trail Details</h2>
                </div>
                <button onclick="closeViewModal()" class="text-gray-400 hover:text-white transition-colors">
                    <i class="fa-solid fa-xmark text-2xl"></i>
                </button>
            </div>

            <div class="overflow-y-auto p-6 custom-scrollbar">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="relative">
                        <img id="viewImage" src="" alt="Trail" class="w-full h-64 object-cover rounded-xl border border-gray-700">
                        <button onclick="closeViewModalAndOpenEdit()" class="absolute top-3 right-3 bg-gray-900/80 hover:bg-orange-500 text-white p-2.5 rounded-full transition-all shadow-lg">
                            <i class="fa-solid fa-pen text-sm"></i>
                        </button>
                    </div>
                    
                    <div>
                        <h3 id="viewName" class="text-2xl font-bold text-white mb-1"></h3>
                        <p class="text-gray-400 text-sm mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-location-dot text-red-400"></i>
                            <span id="viewLocation"></span>
                        </p>
                        
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                                <p class="text-gray-500 text-xs uppercase tracking-wider flex items-center gap-1"><i class="fa-solid fa-route"></i> Distance</p>
                                <p class="text-white font-semibold text-lg"><span id="viewDistance"></span> <span class="text-xs text-gray-400">km</span></p>
                            </div>
                            <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                                <p class="text-gray-500 text-xs uppercase tracking-wider flex items-center gap-1"><i class="fa-solid fa-arrow-trend-up"></i> Elevation</p>
                                <p class="text-white font-semibold text-lg"><span id="viewElevation"></span> <span class="text-xs text-gray-400">m</span></p>
                            </div>
                            <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                                <p class="text-gray-500 text-xs uppercase tracking-wider flex items-center gap-1"><i class="fa-solid fa-tree"></i> Terrain</p>
                                <p class="text-white font-semibold text-lg"><span id="viewTerrainType"></span></p>
                            </div>
                            <div class="bg-[#111A2E] rounded-lg p-3 border border-gray-700">
                                <p class="text-gray-500 text-xs uppercase tracking-wider flex items-center gap-1"><i class="fa-regular fa-calendar"></i> Date Added</p>
                                <p class="text-white font-semibold text-sm"><span id="viewDateAdded"></span></p>
                            </div>
                        </div>
                        
                        <div class="bg-[#111A2E] rounded-xl p-4 border border-gray-700">
                            <p class="text-gray-500 text-xs uppercase tracking-wider mb-2 flex items-center gap-1"><i class="fa-solid fa-file-lines"></i> Description</p>
                            <p id="viewDescriptionText" class="text-gray-300 text-sm leading-relaxed"></p>
                        </div>
                    </div>
                </div>
                
                <div class="mt-6">
                    <p class="text-gray-500 text-xs uppercase tracking-wider mb-3 flex items-center gap-2"><i class="fa-solid fa-images"></i> Additional Photos</p>
                    <div id="viewAdditionalPhotos" class="grid grid-cols-3 gap-3"></div>
                </div>
            </div>

            <div class="px-6 py-4 border-t border-gray-800 shrink-0 flex justify-end gap-3">
                <button onclick="closeViewModal()" class="px-5 py-2 rounded-lg text-sm font-medium text-gray-300 hover:text-white bg-gray-800 hover:bg-gray-700 transition-colors">
                    Close
                </button>
                <button onclick="closeViewModalAndOpenEdit()" class="px-5 py-2 rounded-lg text-sm font-medium text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all flex items-center gap-2">
                    <i class="fa-solid fa-pen"></i> Edit Trail
                </button>
            </div>
        </div>
    </div>

    <div id="addTrailModal" class="fixed inset-0 z-100 modal-hidden" style="padding-top: 30px;">
        <div class="fixed inset-0 bg-black/70 backdrop-blur-sm" onclick="closeAddTrailModal()"></div>
        <div class="relative bg-[#0B1325] border border-gray-800 rounded-xl shadow-2xl w-full max-w-6xl max-h-[90vh] overflow-hidden flex flex-col mx-auto my-auto" style="z-index: 10;">
            
            <div class="flex justify-between items-center px-8 py-5 border-b border-gray-800 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                        <i class="fa-solid fa-plus text-white text-sm"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">Add Trail</h3>
                        <p class="text-xs text-gray-400">Create a new trail listing for hikers and organizers.</p>
                    </div>
                </div>
                <button type="button" onclick="closeAddTrailModal()" class="text-gray-400 hover:text-white transition-colors">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>

            <form id="addTrailForm" asp-controller="Trail" asp-action="AddTrail" method="post" enctype="multipart/form-data" class="flex flex-col flex-1 overflow-hidden">
                <div class="p-8 overflow-y-auto custom-scrollbar">
                    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
                        <div class="lg:col-span-3 flex flex-col gap-5">
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-mountain text-purple-400 mr-1.5"></i> Trail Name</label>
                                <input name="Name" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., Mount Pulag" />
                            </div>
                            
                            <div class="grid grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-route text-purple-400 mr-1.5"></i> Trail Distance (km)</label>
                                    <input name="DistanceKm" type="number" step="0.1" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., 12" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-arrow-trend-up text-purple-400 mr-1.5"></i> Elevation Gain (m)</label>
                                    <input name="ElevationGainMeters" type="number" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., 850" />
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-layer-group text-purple-400 mr-1.5"></i> Terrain Type</label>
                                    <select name="Terrain" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none appearance-none text-sm cursor-pointer"
                                            style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%239CA3AF%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px;">
                                        <option value="" disabled selected class="text-gray-500">Select Terrain</option>
                                        <option value="Grassland" class="bg-[#0B1325]">Grassland</option>
                                        <option value="Mossy Forest" class="bg-[#0B1325]">Mossy Forest</option>
                                        <option value="Pine Forest" class="bg-[#0B1325]">Pine Forest</option>
                                        <option value="River Trek" class="bg-[#0B1325]">River Trek</option>
                                        <option value="Rocky" class="bg-[#0B1325]">Rocky</option>
                                        <option value="Rocky / Boulders" class="bg-[#0B1325]">Rocky / Boulders</option>
                                        <option value="Volcanic" class="bg-[#0B1325]">Volcanic</option>
                                        <option value="Muddy Trail" class="bg-[#0B1325]">Muddy Trail</option>
                                        <option value="Mixed Terrain" class="bg-[#0B1325]">Mixed Terrain</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-location-dot text-purple-400 mr-1.5"></i> Location</label>
                                    <input name="Location" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., Kabayan, Benguet" />
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-file-lines text-purple-400 mr-1.5"></i> Trail Description</label>
                                <textarea name="Description" required rows="4" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-3 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm resize-none" placeholder="Write a brief overview..."></textarea>
                                <p class="text-xs text-gray-500 mt-2">Provide details about the trail, highlights, and what hikers can expect.</p>
                            </div>
                        </div>

                        <div class="lg:col-span-2 flex flex-col gap-6">
                            <div class="flex flex-col">
                                <label class="block text-sm font-medium text-gray-300 mb-2"><i class="fa-solid fa-cloud-arrow-up text-purple-400 mr-1.5"></i> Upload Trail Photo <span class="text-red-500">*</span></label>
                                <div id="thumbnailBox" class="relative bg-[#111A2E] border border-dashed border-gray-600 rounded-xl flex flex-col items-center justify-center text-center hover:bg-gray-800 transition-all cursor-pointer group h-45">
                                    <i class="fa-solid fa-cloud-arrow-up text-4xl text-purple-500 mb-3 group-hover:text-purple-400 transition-colors"></i>
                                    <p class="text-sm text-gray-300 mb-1">Drag & drop image here or <span class="font-semibold text-purple-400">click to browse</span></p>
                                    <p class="text-xs text-gray-500">JPG, PNG up to 5MB</p>
                                    <input type="file" id="thumbnailInput" name="ThumbnailImage" accept="image/png, image/jpeg" required class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10" onchange="handleAddThumbnailPreview(this)" />
                                </div>
                                <div id="thumbnailPreviewContainer" class="relative hidden h-45 w-full rounded-xl overflow-hidden border border-gray-700 mt-2 group">
                                    <img id="thumbnailPreviewImage" class="w-full h-full object-cover" alt="Thumbnail Preview" />
                                    <button type="button" onclick="removeAddThumbnail()" class="absolute top-2 right-2 w-8 h-8 bg-gray-900/80 hover:bg-gray-700 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow-lg z-20">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                                <p class="text-xs text-gray-500 mt-2">This image will represent your trail on listings and search results.</p>
                            </div>

                            <div class="flex flex-col mt-4">
                                <label class="block text-sm font-medium text-gray-300 mb-2"><i class="fa-solid fa-image text-purple-400 mr-1.5"></i> Upload Additional Photos</label>
                                <div class="relative bg-[#111A2E] border border-dashed border-gray-600 rounded-xl flex flex-col items-center justify-center text-center hover:bg-gray-800 transition-all cursor-pointer group h-35">
                                    <i class="fa-solid fa-images text-3xl text-purple-500 mb-2 group-hover:text-purple-400 transition-colors"></i>
                                    <p class="text-sm text-gray-300 mb-1">Drag & drop images here or <span class="font-semibold text-purple-400">click to browse</span></p>
                                    <p class="text-xs text-gray-500">JPG, PNG up to 5MB each</p>
                                    <input type="file" id="additionalInput" name="AdditionalImages" accept="image/png, image/jpeg" multiple class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10" onchange="handleAdditionalPhotos(this)" />
                                </div>
                                <div id="additionalPhotosGrid" class="grid grid-cols-3 gap-3 mt-4 empty:hidden"></div>
                                <p class="text-xs text-gray-500 mt-2">Add up to 8 photos to showcase the trail. JPG or PNG, up to 5MB each.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="px-8 py-5 border-t border-gray-800 shrink-0 flex justify-end gap-3 bg-[#0B1325] rounded-b-xl">
                    <button type="button" onclick="closeAddTrailModal()" class="px-7 py-2.5 rounded-full text-sm font-bold text-gray-300 hover:text-white bg-transparent border border-gray-700 hover:bg-gray-800 transition-colors">
                        Cancel
                    </button>
                    <button type="submit" class="group inline-flex items-center justify-center gap-2 px-7 py-2.5 text-sm rounded-full bg-linear-to-r from-orange-500 to-purple-600 text-white font-bold shadow-lg hover:opacity-90 transition-all">
                        <i class="fa-regular fa-floppy-disk"></i>
                        <span>Save Trail</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="editTrailModal" class="fixed inset-0 z-100 modal-hidden" style="padding-top: 30px;">
        <div class="fixed inset-0 bg-black/70 backdrop-blur-sm" onclick="closeEditTrailModal()"></div>
        <div class="relative bg-[#0B1325] border border-gray-800 rounded-xl shadow-2xl w-full max-w-6xl max-h-[90vh] overflow-hidden flex flex-col mx-auto my-auto" style="z-index: 10;">
            
            <div class="flex justify-between items-center px-8 py-5 border-b border-gray-800 shrink-0">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-linear-to-r from-orange-500 to-purple-500 flex items-center justify-center">
                        <i class="fa-solid fa-pen text-white text-sm"></i>
                    </div>
                    <div>
                        <h3 class="text-xl font-bold text-white">Edit Trail</h3>
                        <p class="text-xs text-gray-400">Update trail details and manage photos.</p>
                    </div>
                </div>
                <button type="button" onclick="closeEditTrailModal()" class="text-gray-400 hover:text-white transition-colors">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>

            <form id="editTrailForm" asp-controller="Trail" asp-action="EditTrail" method="post" enctype="multipart/form-data" class="flex flex-col flex-1 overflow-hidden">
                <input type="hidden" id="editTrailId" name="Id" />
                <div class="p-8 overflow-y-auto custom-scrollbar">
                    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
                        <div class="lg:col-span-3 flex flex-col gap-5">
                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-mountain text-purple-400 mr-1.5"></i> Trail Name</label>
                                <input id="editName" name="Name" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., Mount Pulag" />
                            </div>
                            
                            <div class="grid grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-route text-purple-400 mr-1.5"></i> Trail Distance (km)</label>
                                    <input id="editDistance" name="DistanceKm" type="number" step="0.1" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., 12" />
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-arrow-trend-up text-purple-400 mr-1.5"></i> Elevation Gain (m)</label>
                                    <input id="editElevation" name="ElevationGainMeters" type="number" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., 850" />
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-layer-group text-purple-400 mr-1.5"></i> Terrain Type</label>
                                    <select id="editTerrain" name="Terrain" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none appearance-none text-sm cursor-pointer"
                                            style="background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2224%22%20height%3D%2224%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%239CA3AF%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E'); background-repeat: no-repeat; background-position: right 12px center; background-size: 16px;">
                                        <option value="" disabled class="text-gray-500">Select Terrain</option>
                                        <option value="Grassland" class="bg-[#0B1325]">Grassland</option>
                                        <option value="Mossy Forest" class="bg-[#0B1325]">Mossy Forest</option>
                                        <option value="Pine Forest" class="bg-[#0B1325]">Pine Forest</option>
                                        <option value="River Trek" class="bg-[#0B1325]">River Trek</option>
                                        <option value="Rocky" class="bg-[#0B1325]">Rocky</option>
                                        <option value="Rocky / Boulders" class="bg-[#0B1325]">Rocky / Boulders</option>
                                        <option value="Volcanic" class="bg-[#0B1325]">Volcanic</option>
                                        <option value="Muddy Trail" class="bg-[#0B1325]">Muddy Trail</option>
                                        <option value="Mixed Terrain" class="bg-[#0B1325]">Mixed Terrain</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-location-dot text-purple-400 mr-1.5"></i> Location</label>
                                    <input id="editLocation" name="Location" required class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-2.5 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm" placeholder="e.g., Kabayan, Benguet" />
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-300 mb-1.5"><i class="fa-solid fa-file-lines text-purple-400 mr-1.5"></i> Trail Description</label>
                                <textarea id="editDescription" name="Description" required rows="4" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-lg px-4 py-3 focus:border-purple-500 focus:outline-none transition-all placeholder-gray-500 text-sm resize-none" placeholder="Write a brief overview..."></textarea>
                                <p class="text-xs text-gray-500 mt-2">Provide details about the trail, highlights, and what hikers can expect.</p>
                            </div>
                        </div>

                        <div class="lg:col-span-2 flex flex-col gap-6">
                            <div class="flex flex-col">
                                <label class="block text-sm font-medium text-gray-300 mb-2"><i class="fa-solid fa-cloud-arrow-up text-purple-400 mr-1.5"></i> Upload Trail Photo</label>
                                <div id="editThumbnailBox" class="relative bg-[#111A2E] border border-dashed border-gray-600 rounded-xl flex flex-col items-center justify-center text-center hover:bg-gray-800 transition-all cursor-pointer group h-45">
                                    <i class="fa-solid fa-cloud-arrow-up text-4xl text-purple-500 mb-3 group-hover:text-purple-400 transition-colors"></i>
                                    <p class="text-sm text-gray-300 mb-1">Drag & drop image here or <span class="font-semibold text-purple-400">click to browse</span></p>
                                    <p class="text-xs text-gray-500">JPG, PNG up to 5MB</p>
                                    <input type="file" id="editThumbnailInput" name="ThumbnailImage" accept="image/png, image/jpeg" class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10" onchange="handleEditThumbnailPreview(this)" />
                                </div>
                                <div id="editThumbnailPreviewContainer" class="relative h-45 w-full rounded-xl overflow-hidden border border-gray-700 mt-2 group hidden">
                                    <img id="editThumbnailPreviewImage" class="w-full h-full object-cover" alt="Thumbnail Preview" />
                                    <button type="button" onclick="removeEditThumbnail()" class="absolute top-2 right-2 w-8 h-8 bg-gray-900/80 hover:bg-gray-700 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow-lg z-20">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="flex flex-col mt-4">
                                <label class="block text-sm font-medium text-gray-300 mb-2"><i class="fa-solid fa-image text-purple-400 mr-1.5"></i> Existing Photos</label>
                                <div id="existingPhotosGrid" class="grid grid-cols-3 gap-3 mb-4"></div>
                                
                                <label class="block text-sm font-medium text-gray-300 mb-2 mt-2"><i class="fa-solid fa-plus text-purple-400 mr-1.5"></i> Add New Photos</label>
                                <div class="relative bg-[#111A2E] border border-dashed border-gray-600 rounded-xl flex flex-col items-center justify-center text-center hover:bg-slate-800/50 transition-all cursor-pointer group h-44 px-4 py-6">
                                    <i class="fa-solid fa-images text-4xl text-purple-500 mb-3 group-hover:text-purple-400 transition-colors"></i>
                                    <p class="text-sm text-gray-300 mb-1">
                                        Drag & drop images here or <span class="font-semibold text-purple-400 hover:underline">click to browse</span>
                                    </p>
                                    <p class="text-xs text-gray-500">JPG, PNG up to 5MB each</p>
                                    <input type="file" id="editAdditionalInput" name="AdditionalImages" accept="image/png, image/jpeg" multiple class="absolute inset-0 opacity-0 cursor-pointer w-full h-full z-10" onchange="handleEditAdditionalPhotos(this)" />
                                </div>
                                <div id="editAdditionalPhotosGrid" class="grid grid-cols-3 gap-3 mt-4 empty:hidden"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="px-8 py-5 border-t border-gray-800 shrink-0 flex justify-end gap-3 bg-[#0B1325] rounded-b-xl">
                    <button type="button" onclick="closeEditTrailModal()" class="px-7 py-2.5 rounded-full text-sm font-bold text-gray-300 hover:text-white bg-transparent border border-gray-700 hover:bg-gray-800 transition-colors">
                        Cancel
                    </button>
                    <button type="submit" class="group inline-flex items-center justify-center gap-2 px-7 py-2.5 text-sm rounded-full bg-linear-to-r from-orange-500 to-purple-600 text-white font-bold shadow-lg hover:opacity-90 transition-all">
                        <i class="fa-regular fa-floppy-disk"></i>
                        <span>Save Changes</span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 6px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
        
        .modal-hidden {
            display: none !important;
        }
        
        .modal-visible {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }

        #addTrailModal.modal-visible,
        #editTrailModal.modal-visible,
        #viewTrailModal.modal-visible {
            padding: 1rem;
            padding-top: 80px;
        }
        
        .modal-visible .relative {
            margin: auto;
            max-height: 85vh;
        }
        
        @@keyframes fadeOut {
            from { opacity: 1; transform: scale(1); }
            to { opacity: 0; transform: scale(0.95); }
        }
    </style>

    <script>
        setTimeout(function() {
            const successMsg = document.getElementById('successMessage');
            const errorMsg = document.getElementById('errorMessage');
            if (successMsg) successMsg.remove();
            if (errorMsg) errorMsg.remove();
        }, 3000);

        let currentEditTrailId = null;

        function openViewModal(button) {
            currentEditTrailId = button.getAttribute('data-id');
            
            const name = button.getAttribute('data-name');
            const location = button.getAttribute('data-location');
            const distance = button.getAttribute('data-distance');
            const elevation = button.getAttribute('data-elevation');
            const terrain = button.getAttribute('data-terrain');
            const description = button.getAttribute('data-description');
            const image = button.getAttribute('data-image');
            const dateAdded = button.getAttribute('data-date-added') || 'N/A';

            document.getElementById('viewName').textContent = name;
            document.getElementById('viewLocation').textContent = location;
            document.getElementById('viewDistance').textContent = distance;
            document.getElementById('viewElevation').textContent = elevation;
            document.getElementById('viewTerrainType').textContent = terrain;
            document.getElementById('viewDescriptionText').textContent = description || 'No description provided.';
            document.getElementById('viewDateAdded').textContent = dateAdded;

            const heroImg = document.getElementById('viewImage');
            const fallbackImg = 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1000&q=80';
            heroImg.src = image ? image : fallbackImg;

            const modal = document.getElementById('viewTrailModal');
            const additionalContainer = document.getElementById('viewAdditionalPhotos');
            additionalContainer.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">Loading photos...</div>';
            
            modal.classList.remove('modal-hidden');
            modal.classList.add('modal-visible');
            document.body.style.overflow = 'hidden';

            fetch(`/Trail/GetTrailPhotos?trailId=${currentEditTrailId}`)
                .then(response => response.json())
                .then(data => {
                    additionalContainer.innerHTML = '';
                    
                    if (data && data.length > 0) {
                        data.forEach(photo => {
                            const imgDiv = document.createElement('div');
                            imgDiv.className = 'aspect-square rounded-lg overflow-hidden border border-gray-700';
                            imgDiv.innerHTML = `<img src="${photo.url}" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/400x400?text=Error'">`;
                            additionalContainer.appendChild(imgDiv);
                        });
                    } else {
                        additionalContainer.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">No additional photos</div>';
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    additionalContainer.innerHTML = '<div class="col-span-3 text-center text-red-500 text-sm py-4">Error loading photos</div>';
                });
        }

        function closeViewModal() {
            const modal = document.getElementById('viewTrailModal');
            modal.classList.remove('modal-visible');
            modal.classList.add('modal-hidden');
            document.body.style.overflow = 'auto';
        }

        function closeViewModalAndOpenEdit() {
            closeViewModal();
            
            setTimeout(() => {
                if (currentEditTrailId) {
                    const fakeButton = document.createElement('button');
                    fakeButton.setAttribute('data-id', currentEditTrailId);
                    fakeButton.setAttribute('data-name', document.getElementById('viewName').textContent);
                    fakeButton.setAttribute('data-location', document.getElementById('viewLocation').textContent);
                    fakeButton.setAttribute('data-distance', document.getElementById('viewDistance').textContent);
                    fakeButton.setAttribute('data-elevation', document.getElementById('viewElevation').textContent);
                    fakeButton.setAttribute('data-terrain', document.getElementById('viewTerrainType').textContent);
                    fakeButton.setAttribute('data-description', document.getElementById('viewDescriptionText').textContent);
                    
                    const imageSrc = document.getElementById('viewImage').src;
                    if (imageSrc && !imageSrc.includes('unsplash')) {
                        fakeButton.setAttribute('data-image', imageSrc);
                    } else {
                        fakeButton.setAttribute('data-image', '');
                    }
                    
                    openEditModal(fakeButton);
                }
            }, 300);
        }

        function handleAddThumbnailPreview(input) {
            const box = document.getElementById('thumbnailBox');
            const previewContainer = document.getElementById('thumbnailPreviewContainer');
            const previewImage = document.getElementById('thumbnailPreviewImage');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    box.classList.add('hidden');
                    previewContainer.classList.remove('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removeAddThumbnail() {
            document.getElementById('thumbnailInput').value = '';
            document.getElementById('thumbnailPreviewContainer').classList.add('hidden');
            document.getElementById('thumbnailPreviewImage').src = '';
            document.getElementById('thumbnailBox').classList.remove('hidden');
        }

        let additionalFilesArray = [];
        function handleAdditionalPhotos(input) {
            if (!input.files || input.files.length === 0) return;
            for (let i = 0; i < input.files.length; i++) {
                additionalFilesArray.push(input.files[i]);
            }
            updateAdditionalUIAndInput();
        }

        function removeAdditionalPhoto(index) {
            additionalFilesArray.splice(index, 1);
            updateAdditionalUIAndInput();
        }

        function updateAdditionalUIAndInput() {
            const grid = document.getElementById('additionalPhotosGrid');
            const input = document.getElementById('additionalInput');
            grid.innerHTML = '';

            const dataTransfer = new DataTransfer();
            additionalFilesArray.forEach((file, index) => {
                dataTransfer.items.add(file);
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-lg overflow-hidden border border-gray-600 group';
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <button type="button" onclick="removeAdditionalPhoto(${index})" class="absolute top-1 right-1 w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition-opacity z-20">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    `;
                    grid.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
            input.files = dataTransfer.files;
        }

        function openAddTrailModal() {
            const modal = document.getElementById('addTrailModal');
            modal.classList.remove('modal-hidden');
            modal.classList.add('modal-visible');
        }

        function closeAddTrailModal() {
            const modal = document.getElementById('addTrailModal');
            modal.classList.remove('modal-visible');
            modal.classList.add('modal-hidden');
            document.getElementById('addTrailForm').reset();
            removeAddThumbnail();
            additionalFilesArray = [];
            updateAdditionalUIAndInput();
        }

        async function openEditModal(button) {
            const id = button.getAttribute('data-id');
            const name = button.getAttribute('data-name');
            const location = button.getAttribute('data-location');
            const distance = button.getAttribute('data-distance');
            const elevation = button.getAttribute('data-elevation');
            const terrain = button.getAttribute('data-terrain');
            const description = button.getAttribute('data-description');
            const image = button.getAttribute('data-image');

            document.getElementById('editTrailId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editLocation').value = location;
            document.getElementById('editDistance').value = distance;
            document.getElementById('editElevation').value = elevation;

            const terrainSelect = document.getElementById('editTerrain');
            for(let i=0; i < terrainSelect.options.length; i++) {
                if(terrainSelect.options[i].value === terrain || terrainSelect.options[i].text === terrain) {
                    terrainSelect.selectedIndex = i;
                    break;
                }
            }

            document.getElementById('editDescription').value = description;

            const box = document.getElementById('editThumbnailBox');
            const previewContainer = document.getElementById('editThumbnailPreviewContainer');
            const previewImage = document.getElementById('editThumbnailPreviewImage');

            if (image && image !== '') {
                previewImage.src = image;
                box.classList.add('hidden');
                previewContainer.classList.remove('hidden');
            } else {
                removeEditThumbnail();
            }

            editAdditionalFilesArray = [];
            updateEditAdditionalUIAndInput();

            const existingGrid = document.getElementById('existingPhotosGrid');
            existingGrid.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">Loading existing photos...</div>';

            try {
                const response = await fetch(`/Trail/GetTrailPhotos?trailId=${id}`);
                const photos = await response.json();
                
                existingGrid.innerHTML = '';
                
                if (photos && photos.length > 0) {
                    for (let i = 0; i < photos.length; i++) {
                        const photo = photos[i];
                        const div = document.createElement('div');
                        div.className = 'relative aspect-square rounded-lg overflow-hidden border border-gray-600 group';
                        div.innerHTML = `
                            <img src="${photo.url}" class="w-full h-full object-cover" />
                            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <button type="button" class="delete-photo-btn absolute top-1 right-1 w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition-opacity z-20" data-photo-id="${photo.id}">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        `;
                        existingGrid.appendChild(div);
                    }
                } else {
                    existingGrid.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">No additional photos yet</div>';
                }
            } catch (error) {
                console.error('Error loading existing photos:', error);
                existingGrid.innerHTML = '<div class="col-span-3 text-center text-red-500 text-sm py-4">Error loading photos</div>';
            }

            const modal = document.getElementById('editTrailModal');
            modal.classList.remove('modal-hidden');
            modal.classList.add('modal-visible');
        }

        async function deleteExistingPhoto(buttonElement, event) {
            if (event) event.preventDefault();
            if (event) event.stopPropagation();
            
            const photoId = parseInt(buttonElement.getAttribute('data-photo-id'));
            const photoDiv = buttonElement.closest('.group');
            
            buttonElement.disabled = true;
            photoDiv.style.opacity = '0.5';
            
            try {
                const response = await fetch('/Trail/DeleteTrailPhoto', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ photoId: photoId })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    photoDiv.style.animation = 'fadeOut 0.3s ease-out forwards';
                    setTimeout(() => {
                        photoDiv.remove();
                        const existingGrid = document.getElementById('existingPhotosGrid');
                        if (existingGrid && existingGrid.children.length === 0) {
                            existingGrid.innerHTML = '<div class="col-span-3 text-center text-gray-500 text-sm py-4">No additional photos yet</div>';
                        }
                        showToast('Photo deleted successfully', 'success');
                    }, 300);
                } else {
                    buttonElement.disabled = false;
                    photoDiv.style.opacity = '1';
                    showToast('Error deleting photo: ' + (result.message || 'Unknown error'), 'error');
                }
            } catch (error) {
                console.error('Error deleting photo:', error);
                buttonElement.disabled = false;
                photoDiv.style.opacity = '1';
                showToast('Error deleting photo', 'error');
            }
        }

        async function deleteTrail(id, name) {
            if (!confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) {
                return;
            }
            
            try {
                const response = await fetch('/Trail/DeleteTrail', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ id: id })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast('Trail deleted successfully', 'success');
                    setTimeout(() => {
                        location.reload();
                    }, 1500);
                } else {
                    showToast('Error deleting trail: ' + result.message, 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error deleting trail', 'error');
            }
        }

        function showToast(message, type) {
            const existingToast = document.querySelector('.toast-message');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = `toast-message fixed top-24 right-4 z-50 ${type === 'success' ? 'bg-green-500/90' : 'bg-red-500/90'} text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3`;
            toast.innerHTML = `
                <i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'}"></i>
                <span>${message}</span>
                <button onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            `;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                if (toast) toast.remove();
            }, 3000);
        }
        
        document.addEventListener('click', function(e) {
            const deleteBtn = e.target.closest('.delete-photo-btn');
            if (deleteBtn) {
                e.preventDefault();
                e.stopPropagation();
                deleteExistingPhoto(deleteBtn, e);
            }
        });

        function closeEditTrailModal() {
            const modal = document.getElementById('editTrailModal');
            modal.classList.remove('modal-visible');
            modal.classList.add('modal-hidden');
            document.getElementById('editTrailForm').reset();
            removeEditThumbnail();
            editAdditionalFilesArray = [];
            updateEditAdditionalUIAndInput();
        }

        function handleEditThumbnailPreview(input) {
            const box = document.getElementById('editThumbnailBox');
            const previewContainer = document.getElementById('editThumbnailPreviewContainer');
            const previewImage = document.getElementById('editThumbnailPreviewImage');

            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImage.src = e.target.result;
                    box.classList.add('hidden');
                    previewContainer.classList.remove('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            }
        }

        function removeEditThumbnail() {
            document.getElementById('editThumbnailInput').value = '';
            document.getElementById('editThumbnailPreviewContainer').classList.add('hidden');
            document.getElementById('editThumbnailPreviewImage').src = '';
            document.getElementById('editThumbnailBox').classList.remove('hidden');
        }

        let editAdditionalFilesArray = [];
        function handleEditAdditionalPhotos(input) {
            if (!input.files || input.files.length === 0) return;
            for (let i = 0; i < input.files.length; i++) {
                editAdditionalFilesArray.push(input.files[i]);
            }
            updateEditAdditionalUIAndInput();
        }

        function removeEditAdditionalPhoto(index) {
            editAdditionalFilesArray.splice(index, 1);
            updateEditAdditionalUIAndInput();
        }

        function updateEditAdditionalUIAndInput() {
            const grid = document.getElementById('editAdditionalPhotosGrid');
            const input = document.getElementById('editAdditionalInput');
            grid.innerHTML = '';

            const dataTransfer = new DataTransfer();
            editAdditionalFilesArray.forEach((file, index) => {
                dataTransfer.items.add(file);
                const reader = new FileReader();
                reader.onload = function(e) {
                    const div = document.createElement('div');
                    div.className = 'relative aspect-square rounded-lg overflow-hidden border border-gray-600 group';
                    div.innerHTML = `
                        <img src="${e.target.result}" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        <button type="button" onclick="removeEditAdditionalPhoto(${index})" class="absolute top-1 right-1 w-6 h-6 bg-red-600 hover:bg-red-700 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition-opacity z-20">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    `;
                    grid.appendChild(div);
                };
                reader.readAsDataURL(file);
            });
            input.files = dataTransfer.files;
        }

        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') { 
                closeAddTrailModal(); 
                closeViewModal(); 
                closeEditTrailModal();
            }
        });

        const searchInput = document.getElementById('searchInput');
        const sortSelect = document.getElementById('sortOrder');
        let trailCards = [];
        let originalDisplay = [];

        function refreshTrailCards() {
            trailCards = Array.from(document.querySelectorAll('.grid > div[class*="bg-white/5"]'));
            originalDisplay = trailCards.map(card => window.getComputedStyle(card).display);
        }

        function filterTrails() {
            refreshTrailCards();
            const searchTerm = searchInput.value.toLowerCase();
            const sortValue = sortSelect.value;
            
            let filteredTrails = trailCards.filter((card, index) => {
                const name = card.querySelector('h3')?.textContent.toLowerCase() || '';
                const location = card.querySelector('.text-gray-400.text-sm')?.textContent.toLowerCase() || '';
                const matches = name.includes(searchTerm) || location.includes(searchTerm);
                if (!matches) {
                    card.style.display = 'none';
                }
                return matches;
            });

            trailCards.forEach((card, idx) => {
                card.style.display = 'none';
            });

            filteredTrails.sort((a, b) => {
                if (sortValue === 'newest') {
                    const dateA = a.getAttribute('data-date-added') || '';
                    const dateB = b.getAttribute('data-date-added') || '';
                    return new Date(dateB) - new Date(dateA);
                } else if (sortValue === 'oldest') {
                    const dateA = a.getAttribute('data-date-added') || '';
                    const dateB = b.getAttribute('data-date-added') || '';
                    return new Date(dateA) - new Date(dateB);
                } else if (sortValue === 'name_asc') {
                    const nameA = a.querySelector('h3')?.textContent || '';
                    const nameB = b.querySelector('h3')?.textContent || '';
                    return nameA.localeCompare(nameB);
                } else if (sortValue === 'name_desc') {
                    const nameA = a.querySelector('h3')?.textContent || '';
                    const nameB = b.querySelector('h3')?.textContent || '';
                    return nameB.localeCompare(nameA);
                } else if (sortValue === 'distance_asc') {
                    const distA = parseFloat(a.querySelector('.grid-cols-3 > div:first-child p:last-child')?.textContent) || 0;
                    const distB = parseFloat(b.querySelector('.grid-cols-3 > div:first-child p:last-child')?.textContent) || 0;
                    return distA - distB;
                } else if (sortValue === 'distance_desc') {
                    const distA = parseFloat(a.querySelector('.grid-cols-3 > div:first-child p:last-child')?.textContent) || 0;
                    const distB = parseFloat(b.querySelector('.grid-cols-3 > div:first-child p:last-child')?.textContent) || 0;
                    return distB - distA;
                } else if (sortValue === 'elevation_asc') {
                    const elevA = parseFloat(a.querySelector('.grid-cols-3 > div:nth-child(2) p:last-child')?.textContent) || 0;
                    const elevB = parseFloat(b.querySelector('.grid-cols-3 > div:nth-child(2) p:last-child')?.textContent) || 0;
                    return elevA - elevB;
                } else if (sortValue === 'elevation_desc') {
                    const elevA = parseFloat(a.querySelector('.grid-cols-3 > div:nth-child(2) p:last-child')?.textContent) || 0;
                    const elevB = parseFloat(b.querySelector('.grid-cols-3 > div:nth-child(2) p:last-child')?.textContent) || 0;
                    return elevB - elevA;
                }
                return 0;
            });

            filteredTrails.forEach(card => {
                card.style.display = 'flex';
            });

            const totalCountSpan = document.querySelector('.bg-white\\/5.border.border-white\\/10 .text-white strong');
            if (totalCountSpan) {
                totalCountSpan.textContent = filteredTrails.length;
            }

            const grid = document.querySelector('.grid');
            let noResultsDiv = document.getElementById('noResultsMessage');
            
            if (filteredTrails.length === 0) {
                if (!noResultsDiv) {
                    noResultsDiv = document.createElement('div');
                    noResultsDiv.id = 'noResultsMessage';
                    noResultsDiv.className = 'col-span-full text-center py-20 bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl';
                    noResultsDiv.innerHTML = `
                        <i class="fa-solid fa-mountain text-5xl text-gray-500 mb-4"></i>
                        <h3 class="text-xl font-bold text-gray-300">No trails found</h3>
                        <p class="text-gray-500 mt-2">Try searching a different name or clearing the filters.</p>
                    `;
                    grid.appendChild(noResultsDiv);
                }
            } else {
                if (noResultsDiv) noResultsDiv.remove();
            }
        }

        if (searchInput) {
            searchInput.addEventListener('input', filterTrails);
        }
        if (sortSelect) {
            sortSelect.addEventListener('change', filterTrails);
        }

        setTimeout(() => {
            refreshTrailCards();
        }, 500);
    </script>
}