@using TrailGuard.Models
@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

@section PageHero {
    <div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Admin Dashboard</h1>
            <p class="text-gray-400 mt-1 text-sm">Overview of trails, events, participants, and revenue.</p>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-mountain text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Trails</p>
                        <p class="text-2xl font-bold text-white">@Model.TotalTrails</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-calendar text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Events</p>
                        <p class="text-2xl font-bold text-white">@Model.TotalEvents</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-users text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Participants</p>
                        <p class="text-2xl font-bold text-white">@Model.TotalParticipants.ToString("N0")</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-chart-line text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Revenue</p>
                        <p class="text-2xl font-bold text-green-400">₱ @Model.TotalRevenue.ToString("N0")</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts Row - 3 columns -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4">
                <h2 class="text-sm font-bold text-white mb-3"><i class="fa-solid fa-chart-line text-orange-400 mr-2"></i>Events per Month</h2>
                <div style="height: 220px;">
                    <canvas id="eventsChart"></canvas>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4">
                <h2 class="text-sm font-bold text-white mb-3"><i class="fa-solid fa-mountain text-orange-400 mr-2"></i>Popular Trails</h2>
                <div style="height: 220px;">
                    <canvas id="popularTrailsChart"></canvas>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4">
                <h2 class="text-sm font-bold text-white mb-3"><i class="fa-solid fa-chart-pie text-orange-400 mr-2"></i>Event Status</h2>
                <div style="height: 220px; display: flex; align-items: center; justify-content: center;">
                    <canvas id="statusChart" style="max-width: 200px; max-height: 200px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Recent Data Tables -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
                <div class="px-4 py-3 border-b border-gray-700">
                    <h2 class="text-sm font-bold text-white"><i class="fa-solid fa-calendar-week text-orange-400 mr-2"></i>Upcoming Events</h2>
                </div>
                <div class="p-3 space-y-2 max-h-64 overflow-y-auto custom-scrollbar">
                    @if (Model.UpcomingEvents.Any())
                    {
                        @foreach (var e in Model.UpcomingEvents)
                        {
                            <div class="flex justify-between items-center p-2 hover:bg-white/5 rounded-lg transition-colors">
                                <div>
                                    <p class="text-white font-medium text-sm">@e.EventTitle</p>
                                    <p class="text-gray-400 text-xs">@e.EventDate.ToString("MMM dd, yyyy")</p>
                                </div>
                                <span class="text-xs px-2 py-1 rounded-full bg-green-600 text-white">@e.Status</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-gray-500 text-sm text-center py-4">No upcoming events</p>
                    }
                </div>
                <div class="px-4 py-2 border-t border-gray-700">
                    <a asp-controller="Event" asp-action="Index" class="text-xs text-orange-400 hover:text-orange-300 transition">View all events →</a>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
                <div class="px-4 py-3 border-b border-gray-700">
                    <h2 class="text-sm font-bold text-white"><i class="fa-solid fa-user-plus text-orange-400 mr-2"></i>Recent Registrations</h2>
                </div>
                <div class="p-3 space-y-2 max-h-64 overflow-y-auto custom-scrollbar">
                    @if (Model.RecentRegistrations.Any())
                    {
                        @foreach (var r in Model.RecentRegistrations)
                        {
                            <div class="flex justify-between items-center p-2 hover:bg-white/5 rounded-lg transition-colors">
                                <div>
                                    <p class="text-white font-medium text-sm">@r.ParticipantName</p>
                                    <p class="text-gray-400 text-xs">@r.Event?.EventTitle</p>
                                </div>
                                <span class="text-xs px-2 py-1 rounded-full @(r.IsPaid ? "bg-green-600 text-white" : "bg-yellow-600 text-white")">
                                    @(r.IsPaid ? "Paid" : "Pending")
                                </span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-gray-500 text-sm text-center py-4">No registrations yet</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.1); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.2); }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // Events per Month Chart
    const eventsCtx = document.getElementById('eventsChart')?.getContext('2d');
    if (eventsCtx) {
        new Chart(eventsCtx, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.EventsPerMonth.Select(m => m.Month))),
                datasets: [{
                    label: 'Number of Events',
                    data: @Html.Raw(Json.Serialize(Model.EventsPerMonth.Select(m => m.Count))),
                    borderColor: '#f97316',
                    backgroundColor: 'rgba(249, 115, 22, 0.1)',
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: '#f97316',
                    pointBorderColor: '#fff',
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { labels: { color: '#9ca3af', font: { size: 10 } } }
                },
                scales: {
                    y: { 
                        grid: { color: '#374151' }, 
                        ticks: { color: '#9ca3af', font: { size: 10 }, stepSize: 1 } 
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { color: '#9ca3af', font: { size: 10 }, maxRotation: 45, minRotation: 45 } 
                    }
                }
            }
        });
    }

    // Popular Trails Chart
    const trailsCtx = document.getElementById('popularTrailsChart')?.getContext('2d');
    if (trailsCtx) {
        new Chart(trailsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.PopularTrails.Select(t => t.TrailName))),
                datasets: [{
                    label: 'Number of Events',
                    data: @Html.Raw(Json.Serialize(Model.PopularTrails.Select(t => t.EventCount))),
                    backgroundColor: '#f97316',
                    borderRadius: 6,
                    barPercentage: 0.7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { labels: { color: '#9ca3af', font: { size: 10 } } }
                },
                scales: {
                    y: { 
                        grid: { color: '#374151' }, 
                        ticks: { color: '#9ca3af', font: { size: 10 }, stepSize: 1, precision: 0 } 
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { color: '#9ca3af', font: { size: 10 } } 
                    }
                }
            }
        });
    }

    const statusCtx = document.getElementById('statusChart')?.getContext('2d');
    if (statusCtx) {
        const statusLabels = @Html.Raw(Json.Serialize(Model.EventStatusDistribution.Select(s => s.Status)));
        const statusData = @Html.Raw(Json.Serialize(Model.EventStatusDistribution.Select(s => s.Count)));
        
        new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{
                    data: statusData,
                    backgroundColor: ['#10b981', '#3b82f6', '#ef4444', '#f59e0b'],
                    borderWidth: 0,
                    cutout: '60%'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { 
                        position: 'bottom', 
                        labels: { 
                            color: '#e5e7eb', 
                            font: { size: 13, weight: '500' },
                            boxWidth: 12,
                            padding: 10
                        } 
                    }
                }
            }
        });
    }
</script>