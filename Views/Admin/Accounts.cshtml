@model TrailGuard.Models.AccountManagementViewModel
@{
    ViewData["Title"] = "Account Management";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@section PageHero {
    <div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
            <div>
                <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Account Management</h1>
                <p class="text-gray-400 mt-1 text-sm">Manage user roles, statuses, and system access.</p>
            </div>
            
            <div class="flex flex-wrap items-center gap-4">
                <div class="bg-white/5 border border-white/10 px-4 py-2.5 rounded-full flex items-center gap-2 backdrop-blur-sm shadow-lg">
                    <i class="fa-solid fa-users text-gray-400"></i>
                    <span class="text-sm font-medium text-gray-300">Total Accounts: <strong class="text-white">@(Model?.TotalAccounts ?? 0)</strong></span>
                </div>
                
                <a asp-controller="Admin" asp-action="AddAccount"
                   class="group inline-flex items-center justify-center gap-2 px-7 py-3 text-sm rounded-full bg-linear-to-r from-orange-400 via-pink-500 to-violet-500 text-white font-bold shadow-lg shadow-violet-500/30 hover:scale-105 hover:opacity-90 transform transition duration-300 ease-out">
                    <span>Add Account</span>
                    <i class="fa-solid fa-plus transition-transform duration-300 group-hover:translate-x-1"></i>
                </a>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-white/10 shadow-2xl">
            <div class="relative grow">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                <input type="text" id="searchInput" placeholder="Search by name or email..." 
                    class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-orange-500 focus:outline-none transition-colors placeholder-gray-500">
            </div>

            <div class="flex flex-wrap sm:flex-nowrap gap-3">
                <div class="relative inline-block">
                    <select id="roleFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                        <option value="all" class="bg-[#0b1329] text-white py-2">All Roles</option>
                        <option value="admin" class="bg-[#0b1329] text-white py-2">Admin</option>
                        <option value="organizer" class="bg-[#0b1329] text-white py-2">Organizer</option>
                        <option value="participant" class="bg-[#0b1329] text-white py-2">Participant</option>
                    </select>
                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                        <i class="fa-solid fa-chevron-down text-xs"></i>
                    </div>
                </div>

                <div class="relative inline-block">
                    <select id="statusFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                        <option value="all" class="bg-[#0b1329] text-white py-2">All Status</option>
                        <option value="active" class="bg-[#0b1329] text-white py-2">Active</option>
                        <option value="disabled" class="bg-[#0b1329] text-white py-2">Disabled</option>
                    </select>
                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                        <i class="fa-solid fa-chevron-down text-xs"></i>
                    </div>
                </div>

                <div class="relative inline-block">
                    <select id="sortFilter" class="bg-black/20 border border-white/10 text-white text-sm rounded-full pl-5 pr-10 py-3 focus:border-orange-500 focus:outline-none cursor-pointer appearance-none hover:bg-white/10 transition-colors w-full">
                        <option value="newest" class="bg-[#0b1329] text-white py-2">Sort by: Newest</option>
                        <option value="oldest" class="bg-[#0b1329] text-white py-2">Sort by: Oldest</option>
                        <option value="name" class="bg-[#0b1329] text-white py-2">Name (A-Z)</option>
                    </select>
                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400">
                        <i class="fa-solid fa-chevron-down text-xs"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-users text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Accounts</p>
                        <p class="text-2xl font-bold text-white">@(Model?.TotalAccounts ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-user-tie text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Organizers</p>
                        <p class="text-2xl font-bold text-white">@(Model?.TotalOrganizers ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-person-hiking text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Total Participants</p>
                        <p class="text-2xl font-bold text-white">@(Model?.TotalParticipants ?? 0)</p>
                    </div>
                </div>
            </div>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
                        <i class="fa-solid fa-user-check text-orange-400 text-lg"></i>
                    </div>
                    <div>
                        <p class="text-gray-400 text-xs">Active Accounts</p>
                        <p class="text-2xl font-bold text-white">@(Model?.ActiveAccounts ?? 0)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="border-b border-gray-700">
                        <tr>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Name</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Email</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Role</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Status</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase">Date Created</th>
                            <th class="px-6 py-4 text-xs font-medium text-gray-400 uppercase text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @if (Model?.Accounts != null && Model.Accounts.Any())
                        {
                            @foreach (var account in Model.Accounts)
                            {
                                var roleClass = account.Role == "Admin" ? "bg-orange-500/20 text-orange-400" : 
                                                account.Role == "Organizer" ? "bg-blue-500/20 text-blue-400" : 
                                                "bg-purple-500/20 text-purple-400";
                                
                                <tr class="account-row border-b border-gray-800 hover:bg-white/5 transition-colors"
                                    data-name="@account.FullName"
                                    data-email="@account.Email"
                                    data-role="@(account.Role?.ToLower())"
                                    data-status="@(account.IsActive ? "active" : "disabled")"
                                    data-date="@account.DateCreated">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-8 h-8 rounded-full bg-linear-to-r from-orange-500 to-purple-600 flex items-center justify-center text-white text-xs font-bold shadow-lg">
                                                @account.Initials
                                            </div>
                                            <span class="text-white font-medium">@account.FullName</span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-gray-400">@account.Email</td>
                                    <td class="px-6 py-4">
                                        <span class="text-xs px-2 py-1 rounded-full @roleClass">@account.Role</span>
                                    </td>
                                    <td class="px-6 py-4">
                                        @if (account.IsActive)
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full bg-green-600 text-white">Active</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-1 rounded-full bg-red-600 text-white">Disabled</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-gray-400">@account.DateCreated</td>
                                    <td class="px-6 py-4 text-right">
                                        <form method="post" asp-action="ToggleAccountStatus" class="inline" onsubmit="return confirm('Are you sure?');">
                                            <input type="hidden" name="id" value="@account.Id" />
                                            @if (account.IsActive)
                                            {
                                                <button type="submit" class="bg-red-500/20 hover:bg-red-500 border border-red-500/30 hover:border-red-500 text-red-400 hover:text-white px-4 py-1.5 rounded-lg text-xs font-semibold transition-all">
                                                    Disable
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="bg-green-500/20 hover:bg-green-500 border border-green-500/30 hover:border-green-500 text-green-400 hover:text-white px-4 py-1.5 rounded-lg text-xs font-semibold transition-all">
                                                    Enable
                                                </button>
                                            }
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-12 text-center text-gray-500">
                                    <i class="fa-solid fa-users-slash text-3xl mb-2 block opacity-50"></i>
                                    <p>No accounts found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById('searchInput');
        const roleFilter = document.getElementById('roleFilter');
        const statusFilter = document.getElementById('statusFilter');
        const sortFilter = document.getElementById('sortFilter');
        const tableBody = document.getElementById('tableBody');
        
        if (!searchInput || !tableBody) return;

        function filterAndSort() {
            let rows = Array.from(document.querySelectorAll('.account-row'));
            if (rows.length === 0) return;

            const searchTerm = searchInput.value.toLowerCase();
            const role = roleFilter.value;
            const status = statusFilter.value;
            const sort = sortFilter.value;

            let visibleRows = rows.filter(row => {
                const name = row.getAttribute('data-name')?.toLowerCase() || '';
                const email = row.getAttribute('data-email')?.toLowerCase() || '';
                const roleAttr = row.getAttribute('data-role') || '';
                const statusAttr = row.getAttribute('data-status') || '';

                const matchesSearch = name.includes(searchTerm) || email.includes(searchTerm);
                const matchesRole = role === 'all' || roleAttr === role;
                const matchesStatus = status === 'all' || statusAttr === status;

                row.style.display = (matchesSearch && matchesRole && matchesStatus) ? '' : 'none';
                return matchesSearch && matchesRole && matchesStatus;
            });

            if (sort === 'name') {
                visibleRows.sort((a, b) => (a.getAttribute('data-name') || '').localeCompare(b.getAttribute('data-name') || ''));
            } else if (sort === 'newest') {
                visibleRows.sort((a, b) => new Date(b.getAttribute('data-date') || 0) - new Date(a.getAttribute('data-date') || 0));
            } else if (sort === 'oldest') {
                visibleRows.sort((a, b) => new Date(a.getAttribute('data-date') || 0) - new Date(b.getAttribute('data-date') || 0));
            }

            visibleRows.forEach(row => tableBody.appendChild(row));
        }

        searchInput.addEventListener('input', filterAndSort);
        roleFilter.addEventListener('change', filterAndSort);
        statusFilter.addEventListener('change', filterAndSort);
        sortFilter.addEventListener('change', filterAndSort);
    });
</script>