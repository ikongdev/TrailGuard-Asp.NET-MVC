@model TrailGuard.Controllers.RecordsViewModel
@{
    ViewData["Title"] = "Records";
}

@if (TempData["Success"] != null)
{
    <div id="successMessage" class="fixed top-24 right-4 z-50 bg-green-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-check-circle"></i>
        <span>@TempData["Success"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div id="errorMessage" class="fixed top-24 right-4 z-50 bg-red-500/90 text-white px-6 py-3 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3">
        <i class="fa-solid fa-exclamation-triangle"></i>
        <span>@TempData["Error"]</span>
        <button type="button" onclick="this.parentElement.remove()" class="hover:text-gray-200 transition-colors">
            <i class="fa-solid fa-xmark text-lg"></i>
        </button>
    </div>
}

@section PageHero {
    <div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-orange-400 to-purple-400">Records</h1>
            <p class="text-gray-400 mt-1 text-sm">View event history, participant registrations, trail usage, financial records, and feedback.</p>
        </div>

        <!-- Filters - Responsive -->
        <div class="flex flex-col gap-4 mb-8 bg-white/5 backdrop-blur-xl p-5 rounded-3xl border border-white/10 shadow-2xl">
            <div class="relative w-full">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                <input type="text" id="searchInput" placeholder="Search records..." value="@ViewData["CurrentFilter"]"
                     class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full pl-11 pr-4 py-3 focus:border-orange-500 focus:outline-none transition-colors placeholder-gray-500">
            </div>

            <div class="flex flex-col sm:flex-row gap-4">
                <div class="flex items-center gap-2 flex-1">
                    <span class="text-xs text-gray-400 w-8">From</span>
                    <div class="relative flex-1">
                        <input type="date" id="dateFrom" value="@ViewData["DateFrom"]"
                               class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full px-4 py-3 focus:border-orange-500 focus:outline-none">
                    </div>
                </div>

                <div class="flex items-center gap-2 flex-1">
                    <span class="text-xs text-gray-400 w-8">To</span>
                    <div class="relative flex-1">
                        <input type="date" id="dateTo" value="@ViewData["DateTo"]"
                               class="w-full bg-black/20 border border-white/10 text-white text-sm rounded-full px-4 py-3 focus:border-orange-500 focus:outline-none">
                    </div>
                </div>

                <button id="exportBtn" class="primary-btn px-6 py-3 rounded-full text-sm font-bold text-white bg-linear-to-r from-orange-500 to-purple-600 hover:opacity-90 transition-all flex items-center justify-center gap-2">
                    <i class="fa-solid fa-download"></i> Export
                </button>
            </div>
        </div>

        <!-- Event History Section -->
        <div id="eventsSection" class="mb-12">
            <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-calendar text-orange-400 mr-2"></i>Event History</h2>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-gray-700">
                            <tr>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Event Title</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Trail</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Date</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Status</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Capacity</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Registered</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var eventItem in Model.Events)
                            {
                                var registeredCount = Model.Registrations.Count(r => r.EventId == eventItem.Id);
                                <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 text-white">@eventItem.EventTitle</td>
                                    <td class="px-6 py-4 text-gray-300">@eventItem.Trail?.Name</td>
                                    <td class="px-6 py-4 text-gray-300">@eventItem.EventDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4">
                                        <span class="text-xs px-2 py-1 rounded-full font-semibold 
                                            @(eventItem.Status == "Upcoming" ? "bg-green-600 text-white" : 
                                              eventItem.Status == "Completed" ? "bg-blue-600 text-white" : 
                                              eventItem.Status == "Cancelled" ? "bg-red-600 text-white" : 
                                              "bg-gray-600 text-white")">
                                            @eventItem.Status
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-gray-300">@eventItem.Capacity</td>
                                    <td class="px-6 py-4 text-gray-300">@registeredCount</td>
                                </tr>
                            }
                            @if (!Model.Events.Any())
                            {
                                <tr>
                                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">No events found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Participant Registrations Section -->
        <div id="registrationsSection" class="mb-12">
            <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-users text-orange-400 mr-2"></i>Participant Registrations</h2>
            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-gray-700">
                            <tr>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Participant</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Event</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Pickup Point</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Registered At</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Payment Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reg in Model.Registrations)
                            {
                                <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 text-white">@reg.ParticipantName</td>
                                    <td class="px-6 py-4 text-gray-300">@reg.Event?.EventTitle</td>
                                    <td class="px-6 py-4 text-gray-300">@reg.PickupPoint</td>
                                    <td class="px-6 py-4 text-gray-300">@reg.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4">
                                        <span class="text-xs px-2 py-1 rounded-full font-semibold @(reg.IsPaid ? "bg-green-600 text-white" : "bg-yellow-600 text-white")">
                                            @(reg.IsPaid ? "Paid" : "Pending")
                                        </span>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Registrations.Any())
                            {
                                <tr>
                                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">No registrations found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Trail Usage Section -->
        <div id="trailsSection" class="mb-12">
            <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-mountain text-orange-400 mr-2"></i>Trail Usage & Popularity</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var trail in Model.TrailUsage)
                {
                    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-10 h-10 rounded-full bg-purple-500/20 flex items-center justify-center">
                                <i class="fa-solid fa-mountain text-purple-400"></i>
                            </div>
                            <h3 class="text-lg font-bold text-white">@trail.TrailName</h3>
                        </div>
                        <div class="space-y-2">
                            <div class="flex justify-between">
                                <span class="text-gray-400">Total Events</span>
                                <span class="text-white font-semibold">@trail.TotalEvents</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-400">Total Participants</span>
                                <span class="text-white font-semibold">@trail.TotalParticipants</span>
                            </div>
                        </div>
                    </div>
                }
                @if (!Model.TrailUsage.Any())
                {
                    <div class="col-span-full text-center py-8 text-gray-500">No trail usage data available</div>
                }
            </div>
        </div>

        <!-- Financial Records Section -->
        <div id="financialSection" class="mb-12">
            <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-chart-line text-orange-400 mr-2"></i>Financial Records</h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div class="bg-linear-to-r from-green-500/20 to-emerald-500/20 border border-green-500/30 rounded-2xl p-5">
                    <p class="text-gray-400 text-sm">Total Revenue</p>
                    <p class="text-2xl font-bold text-green-400">₱ @Model.FinancialRecords.Sum(f => f.TotalRevenue).ToString("N0")</p>
                </div>
                <div class="bg-linear-to-r from-blue-500/20 to-cyan-500/20 border border-blue-500/30 rounded-2xl p-5">
                    <p class="text-gray-400 text-sm">Total Completed Events</p>
                    <p class="text-2xl font-bold text-blue-400">@Model.FinancialRecords.Count</p>
                </div>
                <div class="bg-linear-to-r from-purple-500/20 to-pink-500/20 border border-purple-500/30 rounded-2xl p-5">
                    <p class="text-gray-400 text-sm">Total Participants</p>
                    <p class="text-2xl font-bold text-purple-400">@Model.FinancialRecords.Sum(f => f.TotalParticipants).ToString("N0")</p>
                </div>
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="border-b border-gray-700">
                            <tr>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Event</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Date</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Registration Fee</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Participants</th>
                                <th class="px-6 py-3 text-xs font-medium text-gray-400 uppercase">Revenue</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in Model.FinancialRecords)
                            {
                                <tr class="border-b border-gray-800 hover:bg-white/5 transition-colors">
                                    <td class="px-6 py-4 text-white">@record.EventTitle</td>
                                    <td class="px-6 py-4 text-gray-300">@record.EventDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4 text-gray-300">₱ @record.RegistrationFee.ToString("N0")</td>
                                    <td class="px-6 py-4 text-gray-300">@record.TotalParticipants</td>
                                    <td class="px-6 py-4 text-green-400 font-semibold">₱ @record.TotalRevenue.ToString("N0")</td>
                                </tr>
                            }
                            @if (!Model.FinancialRecords.Any())
                            {
                                <tr>
                                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">No financial records found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Feedback & Ratings Section -->
        <div id="feedbackSection">
            <h2 class="text-xl font-bold text-white mb-4"><i class="fa-solid fa-star text-orange-400 mr-2"></i>Feedback & Ratings</h2>
            
            @{
                var avgRating = Model.Feedbacks.Any() ? Model.Feedbacks.Average(f => f.Rating) : 0;
            }
            <div class="bg-linear-to-r from-yellow-500/20 to-orange-500/20 border border-yellow-500/30 rounded-2xl p-5 mb-6 text-center">
                <p class="text-gray-400 text-sm">Average Rating</p>
                <div class="text-4xl font-bold text-yellow-400">@avgRating.ToString("F1")</div>
                <div class="text-yellow-400 mt-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Floor(avgRating))
                        {
                            <i class="fa-solid fa-star"></i>
                        }
                        else if (i - 0.5 <= avgRating)
                        {
                            <i class="fa-solid fa-star-half-alt"></i>
                        }
                        else
                        {
                            <i class="fa-regular fa-star"></i>
                        }
                    }
                    <span class="text-gray-400 text-sm ml-2">(@Model.Feedbacks.Count reviews)</span>
                </div>
            </div>

            <div class="space-y-4">
                @foreach (var feedback in Model.Feedbacks)
                {
                    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <div class="flex items-center gap-2">
                                    <div class="w-8 h-8 rounded-full bg-orange-500/20 flex items-center justify-center">
                                        <i class="fa-solid fa-user text-orange-400 text-sm"></i>
                                    </div>
                                    <div>
                                        <p class="text-white font-semibold">@(feedback.User?.FirstName ?? "Anonymous")</p>
                                        <p class="text-xs text-gray-500">@feedback.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                </div>
                            </div>
                            <div class="text-yellow-400">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= feedback.Rating)
                                    {
                                        <i class="fa-solid fa-star text-xs"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-regular fa-star text-xs"></i>
                                    }
                                }
                            </div>
                        </div>
                        <p class="text-gray-300 text-sm ml-10">@feedback.Comment</p>
                        <p class="text-xs text-gray-500 mt-2 ml-10">Event: @feedback.Event?.EventTitle</p>
                    </div>
                }
                @if (!Model.Feedbacks.Any())
                {
                    <div class="text-center py-8 text-gray-500">No feedback submitted yet</div>
                }
            </div>
        </div>
    </div>
}

<style>
    .primary-btn {
        background: linear-gradient(to right, #f97316, #9333ea);
    }
    .primary-btn:hover {
        opacity: 0.9;
        transform: scale(1.02);
    }
</style>

<script>
    let debounceTimer;

    function applyFilters() {
        const search = document.getElementById('searchInput')?.value || '';
        const dateFrom = document.getElementById('dateFrom')?.value || '';
        const dateTo = document.getElementById('dateTo')?.value || '';
        
        window.location.href = `/Records/Index?searchString=${encodeURIComponent(search)}&dateFrom=${dateFrom}&dateTo=${dateTo}`;
    }

    document.getElementById('searchInput')?.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(applyFilters, 500);
    });

    document.getElementById('dateFrom')?.addEventListener('change', applyFilters);
    document.getElementById('dateTo')?.addEventListener('change', applyFilters);

    document.getElementById('exportBtn')?.addEventListener('click', function() {
        const search = document.getElementById('searchInput')?.value || '';
        const dateFrom = document.getElementById('dateFrom')?.value || '';
        const dateTo = document.getElementById('dateTo')?.value || '';
        
        window.location.href = `/Records/Export?searchString=${encodeURIComponent(search)}&dateFrom=${dateFrom}&dateTo=${dateTo}`;
    });
</script>