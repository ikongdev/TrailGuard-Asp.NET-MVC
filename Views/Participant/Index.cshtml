@using Microsoft.AspNetCore.Identity
@model ParticipantDashboardViewModel
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Participant Dashboard";
    var user = await UserManager.GetUserAsync(User);
    var firstName = user?.FirstName ?? "Participant";
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-transparent bg-clip-text bg-linear-to-r from-purple-400 to-pink-400">Participant Dashboard</h1>
            <p class="text-gray-400 mt-1 text-sm">Track your hikes, registrations, assessment results, and recommended adventures.</p>
        </div>
        <div class="bg-white/5 border border-white/10 px-4 py-2 rounded-full flex items-center gap-2">
            <i class="fa-regular fa-calendar text-purple-400"></i>
            <span class="text-sm text-gray-300">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
        </div>
    </div>

    <div class="flex items-center gap-4 mb-8">
        <div class="w-16 h-16 rounded-full bg-linear-to-r from-purple-500 to-pink-500 flex items-center justify-center text-white text-2xl font-bold shrink-0 overflow-hidden">
            @if (!string.IsNullOrEmpty(user?.ProfilePictureUrl))
            {
                <img src="@user.ProfilePictureUrl" alt="@firstName" class="w-full h-full object-cover" />
            }
            else
            {
                @(firstName[0].ToString().ToUpper())
            }
        </div>
        <div>
            <h2 class="text-2xl font-bold text-white">Welcome back, @firstName!</h2>
            <p class="text-gray-400">Every trail is a new story. Let's find your next great adventure.</p>
        </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@Model.UpcomingEventsCount</p>
            <p class="text-gray-400 text-xs">Upcoming Events</p>
        </div>
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@Model.TotalRegistrations</p>
            <p class="text-gray-400 text-xs">Total Registrations</p>
        </div>
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@Model.PendingRegistrations</p>
            <p class="text-gray-400 text-xs">Pending</p>
        </div>
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-4 text-center">
            <p class="text-2xl font-bold text-white">@Model.CompletedHikes</p>
            <p class="text-gray-400 text-xs">Completed</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
        
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden h-100 flex flex-col">
            <div class="px-4 py-3 border-b border-white/10 shrink-0">
                <h2 class="text-sm font-semibold text-white flex items-center gap-2">
                    <i class="fa-regular fa-calendar text-purple-400"></i>
                    Upcoming Events
                </h2>
            </div>
            <div class="flex-1 overflow-y-auto custom-scrollbar">
                @if (Model.UpcomingEvents != null && Model.UpcomingEvents.Any())
                {
                    @foreach (var ev in Model.UpcomingEvents)
                    {
                        var statusColor = ev.Status == "Pending" ? "text-yellow-400 bg-yellow-500/20" : 
                                          ev.Status == "Accepted" ? "text-green-400 bg-green-500/20" : 
                                          "text-gray-400 bg-gray-500/20";
                        
                        <div class="flex items-center justify-between p-4 border-b border-white/5 hover:bg-white/5 transition-colors">
                            <div class="flex-1 min-w-0">
                                <p class="text-white font-medium text-sm truncate">@ev.EventTitle</p>
                                <p class="text-gray-400 text-xs truncate">@ev.Location</p>
                                <div class="flex flex-wrap gap-3 text-xs text-gray-500 mt-1">
                                    <span><i class="fa-regular fa-calendar mr-1"></i>@ev.EventDate.ToString("MMM dd, yyyy")</span>
                                    <span><i class="fa-regular fa-clock mr-1"></i>@ev.FormattedEventTime</span>
                                </div>
                            </div>
                            <div class="ml-4 shrink-0">
                                <span class="px-3 py-1 rounded-full text-xs font-semibold @statusColor whitespace-nowrap">
                                    @ev.Status
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8 text-gray-500">
                        <i class="fa-regular fa-calendar-plus text-2xl block mb-2 opacity-50"></i>
                        <p class="text-sm">No upcoming events</p>
                    </div>
                }
            </div>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5 h-100flex flex-col">
            <h2 class="text-sm font-semibold text-white mb-3 flex items-center gap-2 shrink-0">
                <i class="fa-solid fa-cloud-sun text-purple-400"></i>
                Weather Forecast
            </h2>
            <div class="mb-3 shrink-0">
                <select id="weatherEventSelect" class="w-full bg-[#111A2E] border border-gray-700 text-white rounded-xl px-4 py-2.5 text-sm focus:border-purple-500 focus:outline-none transition-colors">
                    @if (Model.UpcomingEvents != null && Model.UpcomingEvents.Any())
                    {
                        @foreach (var ev in Model.UpcomingEvents)
                        {
                            <option value="@ev.Id" class="bg-[#0B1325]">@ev.EventTitle</option>
                        }
                    }
                    else
                    {
                        <option value="">No events available</option>
                    }
                </select>
            </div>
            <div class="flex-1" id="weatherDisplay">
                @if (Model.WeatherForecast != null)
                {
                    <div class="space-y-2">
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Date</span>
                            <span class="text-white">@Model.WeatherForecast.Date.ToString("MMMM dd, yyyy")</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Expected Weather</span>
                            <span class="text-white">@Model.WeatherForecast.Condition</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Temperature</span>
                            <span class="text-white">@Model.WeatherForecast.Temperature</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Chance of Rain</span>
                            <span class="text-white">@Model.WeatherForecast.RainChance%</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-400">Wind Speed</span>
                            <span class="text-white">@Model.WeatherForecast.WindSpeed</span>
                        </div>
                        <div class="flex justify-between text-sm border-t border-white/10 pt-2">
                            <span class="text-gray-400">Weather Risk Level</span>
                            <span class="text-yellow-400 font-medium">@Model.WeatherForecast.RiskLevel</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-8 text-gray-500">
                        <i class="fa-solid fa-cloud text-2xl block mb-2 opacity-50"></i>
                        <p class="text-sm">Weather forecast unavailable</p>
                    </div>
                }
            </div>
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5 h-100 flex flex-col">
            <h2 class="text-sm font-semibold text-white mb-3 flex items-center gap-2 shrink-0">
                <i class="fa-solid fa-clipboard-check text-purple-400"></i>
                Latest Assessment Result
            </h2>
            <div class="flex-1 flex flex-col items-center justify-center">
                @if (Model.LatestAssessment != null)
                {
                    var resultColor = Model.LatestAssessment.Result == "Good-Match" ? "#10b981" : 
                                      Model.LatestAssessment.Result == "Borderline" ? "#f59e0b" : "#ef4444";
                    var resultTextColor = Model.LatestAssessment.Result == "Good-Match" ? "text-green-400" : 
                                          Model.LatestAssessment.Result == "Borderline" ? "text-yellow-400" : "text-red-400";
                    var score = Model.LatestAssessment.TotalScore;
                    var maxScore = 44;
                    
                    <div class="relative" style="width: 160px; height: 160px;">
                        <canvas id="assessmentDonutChart"></canvas>
                        <div class="absolute inset-0 flex flex-col items-center justify-center">
                            <span class="text-2xl font-bold text-white">@score</span>
                            <span class="text-[10px] text-gray-400">/ @maxScore</span>
                        </div>
                    </div>
                    <div class="text-center mt-4">
                        <p class="text-lg font-bold @resultTextColor">@Model.LatestAssessment.Result</p>
                        <p class="text-gray-400 text-xs mt-1">
                            <i class="fa-regular fa-clock mr-1"></i>@Model.LatestAssessment.SubmittedAt.ToString("MMM dd, yyyy")
                        </p>
                        <p class="text-gray-500 text-xs mt-1">@Model.LatestAssessment.Description</p>
                    </div>
                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            var ctx = document.getElementById('assessmentDonutChart')?.getContext('2d');
                            if (ctx) {
                                var score = @score;
                                var maxScore = @maxScore;
                                var remaining = maxScore - score;
                                var color = '@resultColor';
                                
                                new Chart(ctx, {
                                    type: 'doughnut',
                                    data: {
                                        labels: ['Your Score', 'Remaining'],
                                        datasets: [{
                                            data: [score, remaining],
                                            backgroundColor: [color, '#374151'],
                                            borderWidth: 0,
                                            cutout: '72%'
                                        }]
                                    },
                                    options: {
                                        responsive: true,
                                        maintainAspectRatio: false,
                                        plugins: {
                                            legend: { display: false },
                                            tooltip: {
                                                callbacks: {
                                                    label: function(context) {
                                                        var label = context.label || '';
                                                        var value = context.parsed || 0;
                                                        return label + ': ' + value + ' / ' + maxScore;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                });
                            }
                        });
                    </script>
                }
                else
                {
                    <div class="text-center text-gray-500">
                        <i class="fa-regular fa-file-lines text-3xl block mb-3 opacity-50"></i>
                        <p class="text-sm">No assessment taken yet</p>
                        <a asp-controller="Participant" asp-action="Events" 
                           class="inline-block mt-2 text-sm text-purple-400 hover:text-purple-300 transition-colors">
                            Take Assessment →
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <div class="lg:col-span-2 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
            <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
                <i class="fa-solid fa-arrows-rotate text-purple-400"></i>
                Recommended Events for You
            </h2>
            @if (Model.RecommendedEvents != null && Model.RecommendedEvents.Any())
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var ev in Model.RecommendedEvents)
                    {
                        <div class="bg-white/5 rounded-xl p-4 hover:bg-white/10 transition-colors">
                            <p class="text-white font-medium text-sm">@ev.EventTitle</p>
                            <p class="text-gray-400 text-xs">@ev.Location</p>
                            <div class="flex flex-wrap gap-2 text-xs text-gray-400 mt-1">
                                <span><i class="fa-regular fa-calendar mr-1"></i>@ev.EventDate.ToString("MMM dd, yyyy")</span>
                                <span><i class="fa-regular fa-clock mr-1"></i>@ev.FormattedEventTime</span>
                                <span class="px-2 py-0.5 rounded-full bg-purple-500/20 text-purple-300">@ev.Difficulty</span>
                            </div>
                            <a asp-controller="Participant" asp-action="Details" asp-route-id="@ev.Id"
                               class="mt-2 inline-block text-xs text-purple-400 hover:text-purple-300 transition-colors">
                                View Details →
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 text-gray-500">
                    <i class="fa-regular fa-calendar-plus text-2xl block mb-2 opacity-50"></i>
                    <p class="text-sm">No recommendations yet. Take an assessment to get personalized recommendations!</p>
                </div>
            }
        </div>

        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-5">
            <h2 class="text-sm font-semibold text-white mb-4 flex items-center gap-2">
                <i class="fa-solid fa-trophy text-purple-400"></i>
                Progress & Achievements
            </h2>
            <div class="space-y-4">
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-gray-400 text-sm">Hikes Completed</span>
                        <span class="text-white font-semibold">@Model.CompletedHikes</span>
                    </div>
                    <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-linear-to-r from-purple-500 to-pink-500" style="width: @(Math.Min(Model.CompletedHikes * 10, 100))%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-gray-400 text-sm">Registrations</span>
                        <span class="text-white font-semibold">@Model.TotalRegistrations</span>
                    </div>
                    <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-linear-to-r from-blue-500 to-cyan-500" style="width: @(Math.Min(Model.TotalRegistrations * 10, 100))%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between items-center mb-1">
                        <span class="text-gray-400 text-sm">Badges Earned</span>
                        <span class="text-white font-semibold">@Model.BadgesEarned</span>
                    </div>
                    <div class="w-full h-2 bg-gray-700 rounded-full overflow-hidden">
                        <div class="h-full rounded-full bg-linear-to-r from-yellow-500 to-orange-500" style="width: @(Math.Min(Model.BadgesEarned * 20, 100))%"></div>
                    </div>
                </div>
                <div class="pt-3 border-t border-white/10">
                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-gray-400 text-sm">Top Hiker Rank</p>
                            <p class="text-white font-semibold">@Model.HikerRank</p>
                        </div>
                        <span class="text-gray-500 text-xs">@Model.NextMilestone</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var eventSelect = document.getElementById('weatherEventSelect');
        var weatherDisplay = document.getElementById('weatherDisplay');
        
        if (eventSelect) {
            eventSelect.addEventListener('change', function() {
                var eventId = this.value;
                if (!eventId) return;
                
                weatherDisplay.innerHTML = `
                    <div class="text-center py-8">
                        <div class="inline-block w-8 h-8 border-4 border-purple-500 border-t-transparent rounded-full animate-spin"></div>
                        <p class="text-gray-400 text-sm mt-2">Loading forecast...</p>
                    </div>
                `;
                
                fetch('/Participant/GetWeatherForecast?eventId=' + eventId)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            weatherDisplay.innerHTML = `
                                <div class="space-y-2">
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Date</span>
                                        <span class="text-white">${data.forecast.date}</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Expected Weather</span>
                                        <span class="text-white">${data.forecast.condition}</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Temperature</span>
                                        <span class="text-white">${data.forecast.temperature}</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Chance of Rain</span>
                                        <span class="text-white">${data.forecast.rainChance}%</span>
                                    </div>
                                    <div class="flex justify-between text-sm">
                                        <span class="text-gray-400">Wind Speed</span>
                                        <span class="text-white">${data.forecast.windSpeed}</span>
                                    </div>
                                    <div class="flex justify-between text-sm border-t border-white/10 pt-2">
                                        <span class="text-gray-400">Weather Risk Level</span>
                                        <span class="${data.forecast.riskLevel === 'Low' ? 'text-green-400' : data.forecast.riskLevel === 'Moderate' ? 'text-yellow-400' : 'text-red-400'} font-medium">${data.forecast.riskLevel}</span>
                                    </div>
                                </div>
                            `;
                        } else {
                            weatherDisplay.innerHTML = `
                                <div class="text-center py-8 text-gray-500">
                                    <i class="fa-solid fa-cloud text-2xl block mb-2 opacity-50"></i>
                                    <p class="text-sm">${data.message || 'Weather forecast unavailable'}</p>
                                </div>
                            `;
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        weatherDisplay.innerHTML = `
                            <div class="text-center py-8 text-red-400">
                                <i class="fa-solid fa-circle-exclamation text-2xl block mb-2"></i>
                                <p class="text-sm">Error loading weather forecast</p>
                            </div>
                        `;
                    });
            });
        }
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(168, 85, 247, 0.3);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(168, 85, 247, 0.6);
    }
</style>