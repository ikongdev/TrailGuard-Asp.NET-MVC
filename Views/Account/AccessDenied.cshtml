@{
    ViewData["Title"] = "Access Denied";
}

<div class="pt-24 px-4 max-w-7xl mx-auto min-h-screen text-white pb-12">
    <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-3xl p-12 text-center max-w-2xl mx-auto">
        <div class="w-24 h-24 rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center mx-auto mb-6">
            <i class="fa-solid fa-lock text-5xl text-red-400"></i>
        </div>

        <h1 class="text-3xl font-bold text-white mb-2">Access Denied</h1>

        <p class="text-gray-400 text-lg mb-2">You do not have permission to view this page.</p>
        <p class="text-gray-500 text-sm">Please contact the administrator if you think this is a mistake.</p>

        <div class="w-16 h-0.5 bg-gray-700 mx-auto my-6"></div>

        <div class="flex flex-wrap items-center justify-center gap-4">
            <a asp-controller="Home" asp-action="Index" 
               class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-white font-medium bg-linear-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 transition-all hover:-translate-y-0.5 shadow-lg shadow-orange-500/20">
                <i class="fa-solid fa-house"></i>
                Return to Home
            </a>
            
            <button onclick="history.back()" 
                    class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-gray-400 font-medium border border-gray-700 hover:border-gray-500 hover:text-white transition-all">
                <i class="fa-solid fa-arrow-left"></i>
                Go Back
            </button>
        </div>

        <p class="text-gray-600 text-xs mt-6">
            <i class="fa-regular fa-circle-question mr-1"></i>
            Need help? <a href="#" class="text-orange-400 hover:underline">Contact Support</a>
        </p>
    </div>
</div>